<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Scoped control styles for the View Achievements window. Pulls the shared implicit control
        styles plus this window's keyed styles. Scoped per-window (like the Settings/ManageAchievements
        equivalents) so the implicit styles never leak into theme-integration contexts.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/PlayAchImplicitControlStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
