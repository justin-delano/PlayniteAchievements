<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Scoped control styles for the Custom Refresh window. Pulls the shared implicit control styles.
        Scoped per-window so the implicit styles never leak into theme-integration contexts that merge
        CommonResources directly.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/PlayAchImplicitControlStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
