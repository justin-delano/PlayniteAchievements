<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Scoped control styles for the Manage Achievements window. Pulls the shared implicit control
        styles plus this window's keyed styles (ManageAchievementsStyles). DatePicker is declared here
        rather than in the shared dictionary because its base-style cluster (Calendar/CalendarItem/etc.)
        lives in ManageAchievementsStyles and is used only by this window. Scoped per-window so the
        implicit styles never leak into theme-integration contexts.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/ManageAchievementsStyles.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/PlayAchImplicitControlStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="DatePicker" BasedOn="{StaticResource PlayAch.DatePicker.BaseStyle}"/>

</ResourceDictionary>
