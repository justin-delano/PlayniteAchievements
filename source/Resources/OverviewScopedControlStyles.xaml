<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Scoped control styles for the Overview window. Pulls the shared implicit control styles plus
        this window's keyed styles (OverviewStyles). Scoped per-window so the implicit styles never
        leak into theme-integration contexts that merge AchievementResources/OverviewStyles directly.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewStyles.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/PlayAchImplicitControlStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
