<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Fallback resources for desktop-only keys used by the plugin.
         Merged into popup windows when running in Playnite fullscreen mode,
         where the default theme does not define these keys. -->

    <SolidColorBrush x:Key="NormalBorderBrush" Color="{StaticResource PlayAch.Color.Fullscreen.Chrome}" />
    <SolidColorBrush x:Key="HighlightGlyphBrush" Color="{StaticResource PlayAch.Color.Fullscreen.Highlight}" />
    <SolidColorBrush x:Key="NormalBrush" Color="{StaticResource PlayAch.Color.Fullscreen.Chrome}" />
    <SolidColorBrush x:Key="TextBrushDarker" Color="{StaticResource PlayAch.Color.Fullscreen.SecondaryText}" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="{StaticResource PlayAch.Color.Fullscreen.PopupBackground}" />

    <sys:Double x:Key="FontSizeLarge">28</sys:Double>

    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}" />
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}" />
    </Style>

    <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundDarkBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Selection}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}" />
        <Setter Property="CaretBrush" Value="{DynamicResource PlayAch.Brush.Text}" />
    </Style>

    <!-- Override menu highlight for dark fullscreen backgrounds.
         The desktop overlay is too faint on fullscreen backgrounds. -->
    <SolidColorBrush x:Key="MenuHighlightBrush" Color="{StaticResource PlayAch.Color.Fullscreen.Highlight.88}" />

    <!-- DataGrid selection overrides for fullscreen visibility.
         The default white overlay is too faint on dark backgrounds. -->
    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.25}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.35}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.18}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.10}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- MenuItem selection override for fullscreen visibility. -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.88}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ContextMenu template override for fullscreen dark background.
         Default ContextMenu popup has white chrome that bleeds through. -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Selection}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Popup background for fullscreen (ContextMenu uses Popup internally). -->
    <Style TargetType="Popup">
        <Setter Property="PopupAnimation" Value="Fade" />
    </Style>

    <!-- ListBoxItem selection override for fullscreen visibility. -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,2" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.20}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PlayAch.Brush.Fullscreen.Highlight.15}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
