<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="ManageAchievementsCardBorderStyle" TargetType="Border" BasedOn="{StaticResource PlayAch.CardBorderStyle}"/>
    <Style x:Key="CardBorderStyle" TargetType="Border" BasedOn="{StaticResource ManageAchievementsCardBorderStyle}"/>

    <!-- DatePicker + dropdown Calendar (manual tracking unlock date), themed with plugin tokens. -->

    <!-- Borderless transparent calendar header / prev / next buttons (override the scoped Button style). -->
    <Style x:Key="PlayAch.Calendar.NavButton" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.Calendar.Item" TargetType="CalendarItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.PopupSurface}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarItem">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="4">
                        <DockPanel Name="PART_Root" LastChildFill="True">
                            <Button x:Name="PART_PreviousButton" DockPanel.Dock="Left"
                                    Style="{StaticResource PlayAch.Calendar.NavButton}"
                                    FontFamily="Marlett" Padding="4,2" Content="3"/>
                            <Button x:Name="PART_NextButton" DockPanel.Dock="Right"
                                    Style="{StaticResource PlayAch.Calendar.NavButton}"
                                    FontFamily="Marlett" Padding="4,2" Content="4"/>
                            <Button x:Name="PART_HeaderButton" DockPanel.Dock="Top"
                                    Style="{StaticResource PlayAch.Calendar.NavButton}"
                                    Padding="2" Height="30"/>
                            <Grid>
                                <Grid x:Name="PART_MonthView" Visibility="Visible">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                                <Grid x:Name="PART_YearView" Visibility="Hidden">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </Grid>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type Calendar}}, Path=DisplayMode}" Value="Year">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type Calendar}}, Path=DisplayMode}" Value="Decade">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.Calendar.Button" TargetType="CalendarButton">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="Bd" Background="Transparent"
                            CornerRadius="{StaticResource PlayAch.Radius.Small}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.Calendar.DayButton" TargetType="CalendarDayButton">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="Bd" Background="Transparent"
                            CornerRadius="{StaticResource PlayAch.Radius.Small}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsToday" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text.Secondary}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Selected}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.Calendar.BaseStyle" TargetType="Calendar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource PlayAch.Calendar.DayButton}"/>
        <Setter Property="CalendarButtonStyle" Value="{StaticResource PlayAch.Calendar.Button}"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.PopupSurface}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Calendar">
                    <Grid Name="PART_Root">
                        <CalendarItem Name="PART_CalendarItem"
                                      Style="{StaticResource PlayAch.Calendar.Item}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Calendar dropdown toggle (override the scoped ToggleButton style). -->
    <Style x:Key="PlayAch.DatePicker.DropDownButton" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.DatePickerTextBox.BaseStyle" TargetType="DatePickerTextBox">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.DatePicker.BaseStyle" TargetType="DatePicker">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Input.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Input.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="CalendarStyle" Value="{StaticResource PlayAch.Calendar.BaseStyle}"/>
        <Setter Property="Padding" Value="6,0,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource PlayAch.Radius.Small}"
                            SnapsToDevicePixels="True">
                        <DockPanel>
                            <Popup x:Name="PART_Popup" StaysOpen="False"
                                   AllowsTransparency="True" Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=PART_TextBox}"/>
                            <ToggleButton x:Name="PART_Button" DockPanel.Dock="Right"
                                          Style="{StaticResource PlayAch.DatePicker.DropDownButton}"
                                          Content="6" FontFamily="Marlett" FontSize="11"
                                          Padding="6,0"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <DatePickerTextBox x:Name="PART_TextBox" DockPanel.Dock="Left"
                                               Style="{StaticResource PlayAch.DatePickerTextBox.BaseStyle}"
                                               Padding="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_TextBox" Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}" TargetName="Border"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}" TargetName="Border"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="{StaticResource PlayAch.Opacity.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ManageAchievementsUnlockTimeCellStyle"
           TargetType="DataGridCell"
           BasedOn="{StaticResource ManageAchievementsControllerCellStyle}">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ManageAchievementsUnlockDatePickerStyle"
           TargetType="DatePicker"
           BasedOn="{StaticResource PlayAch.DatePicker.BaseStyle}">
        <Setter Property="Width" Value="132"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="6,0,2,0"/>
    </Style>

    <Style x:Key="ManageAchievementsUnlockTimeTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource PlayAch.TextBox.BaseStyle}">
        <Setter Property="Width" Value="62"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ManageAchievementsUnlockTimeModeComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource PlayAch.ComboBox.BaseStyle}">
        <Setter Property="Width" Value="82"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ManageAchievementsHeaderCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
    </Style>

    <Style x:Key="ManageAchievementsHeaderTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="ManageAchievementsHeaderHintStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Hint}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Top.Compact}"/>
    </Style>

    <Style x:Key="ManageAchievementsHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Left.Md}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="ManageAchievementsToolbarRowStyle" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="ManageAchievementsSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ClearableSearchTextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Muted}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="FieldValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.SectionHeaderTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="MetaChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Chrome.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.ControlBorder}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.ButtonPadding.Compact}"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.ChipMargin}"/>
    </Style>

    <Style x:Key="ChipTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="0.92"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Caption}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="InlineLinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Caption}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Left.Md}"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Subtle}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Full}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ManageAchievementsSearchPlaceholderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SearchPlaceholderTextStyle}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Left.Sm}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Placeholder}"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <Style x:Key="ManageAchievementsEditSearchPlaceholderTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource ManageAchievementsSearchPlaceholderTextStyle}">
        <Setter Property="Visibility" Value="Collapsed"/>
    </Style>

    <DataTemplate x:Key="ManageAchievementInfoTemplate">
        <StackPanel Margin="{StaticResource PlayAch.Thickness.InfoCellPadding}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Background="Transparent">
            <TextBlock FontWeight="SemiBold"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       TextWrapping="Wrap"
                       TextAlignment="Left">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
                        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
                        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Subtle}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Unlocked}" Value="True">
                                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Full}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsTitleHidden}" Value="True">
                                <Setter Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Full}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="{Binding DisplayNameResolved, Mode=OneWay}"/>
                <Run Text="{Binding HiddenTitleSuffix, Mode=OneWay}"
                     FontStyle="Italic"
                     Foreground="{DynamicResource PlayAch.Brush.Text.Secondary}"/>
            </TextBlock>

            <TextBlock Text="{Binding DescriptionResolved}"
                       FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                       TextWrapping="Wrap"
                       TextAlignment="Left"
                       MaxHeight="{StaticResource PlayAch.Size.Text.DescriptionPreviewMaxHeight}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,3,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDescriptionHidden}" Value="True">
                                <Setter Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Emphasis}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding ApiNameResolved}"
                       FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       Opacity="0.58"
                       TextWrapping="Wrap"
                       TextAlignment="Left"
                       Margin="{StaticResource PlayAch.Thickness.Top.Xs}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                <Setter Property="Opacity" Value="0.9"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <Style x:Key="HiddenAchievementTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="Cursor" Value="Arrow"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding CanReveal}" Value="True">
                <Setter Property="Cursor" Value="Hand"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsHidden}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Muted}"/>
                <Setter Property="FontStyle" Value="Italic"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ClickableCellStyle" TargetType="Grid">
        <Setter Property="Cursor" Value="Arrow"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding CanReveal}" Value="True">
                <Setter Property="Cursor" Value="Hand"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StretchCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="InlineBrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
        <Setter Property="Width" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="KeyboardNavigation.IsTabStop" Value="True"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Left.Sm}"/>
        <Setter Property="FontSize" Value="{StaticResource PlayAch.FontSize.InlineIcon}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Button.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Pressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ClearableSearchTextBoxStyle}">
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="KeyboardNavigation.IsTabStop" Value="True"/>
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.EditorTextBoxPadding}"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Input.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Input.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Secondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource PlayAch.Brush.ErrorText}"/>
                <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Full}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VariantBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource PlayAch.Size.Icon.Small}"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Icon.Small}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PlayAch.Radius.PillSmall}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Chrome.Background}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PreviewBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Control.LargeHeight}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PlayAch.Radius.Small}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Panel}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="IconCardListItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.IconCardPadding}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding CanReveal}" Value="True">
                <Setter Property="Cursor" Value="Hand"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
