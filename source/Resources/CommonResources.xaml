    <Style x:Key="PlayAch.CheckBox.BaseStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Margin="0,0,7,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource PlayAch.Brush.Input.Background}"
                                BorderBrush="{DynamicResource PlayAch.Brush.Input.Border}"
                                BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                CornerRadius="{StaticResource PlayAch.Radius.Tiny}">
                            <Path x:Name="CheckMark"
                                  Width="10"
                                  Height="8"
                                  Data="M 0,4 L 3.5,7.5 L 10,0"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Fill"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Selection}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Selected}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter TargetName="CheckMark" Property="Width" Value="8"/>
                            <Setter TargetName="CheckMark" Property="Height" Value="2"/>
                            <Setter TargetName="CheckMark" Property="Data" Value="M 0,0 L 8,0"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayAch.RadioButton.BaseStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Outer"
                                Width="16"
                                Height="16"
                                Margin="0,1,7,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource PlayAch.Brush.Input.Background}"
                                BorderBrush="{DynamicResource PlayAch.Brush.Input.Border}"
                                BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                CornerRadius="{StaticResource PlayAch.Radius.Circle18}">
                            <Ellipse x:Name="Dot"
                                     Width="8"
                                     Height="8"
                                     Fill="{DynamicResource PlayAch.Brush.Accent}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Selection}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

