<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
                    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/DesignTokens.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility"/>
    <converters:BooleanConverter x:Key="BooleanToVisibilityConverter" Mode="ToVisibility"/>
    <converters:BooleanConverter x:Key="InverseBoolToVis" Mode="InvertedToVisibility"/>
    <converters:BooleanConverter x:Key="InverseBoolToVisConverter" Mode="InvertedToVisibility"/>
    <converters:BooleanConverter x:Key="InvertedBooleanToVisibilityConverter" Mode="InvertedToVisibility"/>
    <converters:BooleanConverter x:Key="InvertBoolConverter" Mode="Inverted"/>
    <converters:BooleanConverter x:Key="InvertedBooleanConverter" Mode="Inverted"/>
    <converters:EnumToBoolConverter x:Key="EnumToBool"/>
    <converters:IntToVisibilityConverter x:Key="IntToVis"/>
    <converters:ResourceKeyToImageSourceConverter x:Key="ResourceKeyToImage"/>
    <converters:ProviderIconConverter x:Key="ProviderIconConverter"/>
    <converters:DefaultGameImageConverter x:Key="DefaultGameImage"/>
    <converters:PercentToRarityGlowConverter x:Key="PercentToRarityGlow"/>
    <converters:PercentToRarityGlowConverter x:Key="PercentToRarityGlowConverter"/>
    <converters:PercentToCompactRarityGlowConverter x:Key="CompactPercentToRarityGlow"/>
    <converters:PercentToRarityBadgeConverter x:Key="PercentToRarityBadgeConverter"/>
    <converters:LockedIconSelectorConverter x:Key="LockedIconSelectorConverter"/>
    <converters:ImageFitDimensionConverter x:Key="ImageFitDimension"/>
    <converters:DataGridCompletedBorderThicknessConverter x:Key="OverviewCompletedBorderThickness"/>
    <converters:LocalDateTimeConverter x:Key="LocalDateTimeConverter"/>
    <converters:HeightToFontSizeConverter x:Key="HeightToFontSizeConverter"/>
    <converters:ValueOperationConverter x:Key="ValueOperationConverter"/>
    <converters:NullableDoubleTextConverter x:Key="NullableDoubleTextConverter"/>
    <converters:NullableIntTextConverter x:Key="NullableIntTextConverter"/>
    <converters:HiddenAchievementConverter x:Key="HiddenIconConverter" ConversionMode="Icon"/>
    <converters:HiddenAchievementConverter x:Key="HiddenTitleConverter" ConversionMode="Title"/>
    <converters:HiddenAchievementConverter x:Key="HiddenDescriptionConverter" ConversionMode="Description"/>

    <!-- PlayAch theme tokens are populated at runtime by PlayAchResourceService. -->
    <Style x:Key="PlayAch.TextBlock.BaseStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
    </Style>

    <Style x:Key="PlayAch.CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PlayAch.Radius.Card}"/>
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.CardPadding}"/>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border" BasedOn="{StaticResource PlayAch.CardBorderStyle}"/>

    <Style x:Key="PlayAch.MutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Muted}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Caption}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PlayAch.SecondaryMetadataTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.MutedTextStyle}">
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="SecondaryMetadataTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.SecondaryMetadataTextStyle}"/>

    <Style x:Key="PlayAch.ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Control.Height}"/>
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.ButtonPadding}"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Right.Sm}"/>
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayAch.ToolbarButtonStyle}"/>

    <Style x:Key="PlayAch.SectionHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{StaticResource PlayAch.FontSize.SectionHeader}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Full}"/>
    </Style>

    <Style x:Key="PlayAch.SectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Surface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PlayAch.Radius.Section}"/>
        <Setter Property="Padding" Value="{StaticResource PlayAch.Thickness.SectionPadding}"/>
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.Xl}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{StaticResource PlayAch.Thickness.Border}"/>
    </Style>

    <Style x:Key="PlayAch.SettingRowStyle" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource PlayAch.Thickness.Bottom.SettingRow}"/>
    </Style>

    <Style x:Key="SearchPlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding SearchText}" Value="">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PlayAch.ChartColumnSeriesStyle" TargetType="lvc:ColumnSeries">
        <Setter Property="Fill" Value="{DynamicResource PlayAch.Brush.Accent}"/>
    </Style>

</ResourceDictionary>
