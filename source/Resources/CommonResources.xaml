    <converters:ValueOperationConverter x:Key="ValueOperationConverter"/>
    <converters:NullableDoubleTextConverter x:Key="NullableDoubleTextConverter"/>
    <converters:NullableIntTextConverter x:Key="NullableIntTextConverter"/>
