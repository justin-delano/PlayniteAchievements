<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                    xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
                    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="OverviewCompletedCellFrameStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid UseLayoutRounding="{TemplateBinding UseLayoutRounding}"
                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <Border BorderBrush="{DynamicResource PlayAch.Brush.CompletedGame}"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Border.BorderThickness>
                                <MultiBinding Converter="{StaticResource OverviewCompletedBorderThickness}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="Column.DisplayIndex"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                </MultiBinding>
                            </Border.BorderThickness>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsCompleted}" Value="True"/>
                                                <Condition Binding="{Binding ShowCompletionBorder, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GameSummariesGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowBackground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="IsTabStop" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ContentPresenter VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=ContextMenu.IsOpen}" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsKeyboardFocusWithin}" Value="True">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsKeyboardFocusWithin}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GameSummariesImageCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource GameSummariesGridCellStyle}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="GameSummariesGridRowBaseStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="112"/>
    </Style>

    <Style x:Key="GameImageBorderBaseStyle" TargetType="Border">
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush Stretch="Uniform"
                            helpers:AsyncImage.Uri="{Binding GameLogo, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"
                            helpers:AsyncImage.DecodePixel="96"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GameSummaryNameTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
    </Style>

    <Style x:Key="OverviewGameMetadataTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Muted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
    </Style>

    <Style x:Key="GameSummaryProviderIconStyle" TargetType="Image">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="HorizontalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"/>
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor"/>
    </Style>

    <Style x:Key="OverviewProgressContainerStyle" TargetType="Grid">
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
    </Style>

    <Style x:Key="OverviewProgressStackStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="VerticalAlignment" Value="Center">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverviewProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource GameProgressBar}">
        <Setter Property="Height" Value="22"/>
    </Style>

    <Style x:Key="OverviewProgressPercentTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="OverviewProgressMetaRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="OverviewProgressFooterStyle" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeItemStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="4,0"/>
        <!-- Keep each badge's image+count physically left-to-right even when the badge row is
             flipped to RightToLeft (Left progress alignment) to reverse the rarity order. -->
        <Setter Property="FlowDirection" Value="LeftToRight"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeImageStyle" TargetType="Image" BasedOn="{StaticResource RarityIcon}">
        <Setter Property="Effect" Value="{StaticResource BadgeShadow}"/>
        <Setter Property="Width" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="3,0,0,0"/>
    </Style>

    <Style x:Key="OverviewCompletedFooterIconStyle" TargetType="Image" BasedOn="{StaticResource OverviewMiniBadgeImageStyle}">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>

    <!-- Shared rarity/trophy badge row for the Progress column footer. Only one of the two
         panels is visible at a time (rarity vs. PlayStation trophies). The host positions and
         (for Left alignment) flips this row; the row itself stays alignment-neutral so the same
         markup serves every alignment without duplication. -->
    <DataTemplate x:Key="ProgressBadgeRowTemplate">
        <Grid VerticalAlignment="Center">
            <StackPanel Style="{StaticResource OverviewProgressMetaRowStyle}"
                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UltraRareCount, Converter={StaticResource IntToVis}}" ToolTip="Ultra Rare">
                    <Image Source="{DynamicResource BadgeRarityUltraRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding UltraRareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding RareCount, Converter={StaticResource IntToVis}}" ToolTip="Rare">
                    <Image Source="{DynamicResource BadgeRarityRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding RareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UncommonCount, Converter={StaticResource IntToVis}}" ToolTip="Uncommon">
                    <Image Source="{DynamicResource BadgeRarityUncommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding UncommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding CommonCount, Converter={StaticResource IntToVis}}" ToolTip="Common">
                    <Image Source="{DynamicResource BadgeRarityCommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding CommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Style="{StaticResource OverviewProgressMetaRowStyle}"
                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource BoolToVis}}">
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyPlatinumCount, Converter={StaticResource IntToVis}}" ToolTip="Platinum">
                    <Image Source="{DynamicResource TrophyPlatinum}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyPlatinumCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyGoldCount, Converter={StaticResource IntToVis}}" ToolTip="Gold">
                    <Image Source="{DynamicResource TrophyGold}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyGoldCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophySilverCount, Converter={StaticResource IntToVis}}" ToolTip="Silver">
                    <Image Source="{DynamicResource TrophySilver}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophySilverCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyBronzeCount, Converter={StaticResource IntToVis}}" ToolTip="Bronze">
                    <Image Source="{DynamicResource TrophyBronze}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyBronzeCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!-- Right alignment (default / legacy look): completed badge pinned far left, badge row
         pinned far right in descending-rarity order. -->
    <DataTemplate x:Key="ProgressFooterRightTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
            <ContentControl Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
        </Grid>
    </DataTemplate>

    <!-- Center alignment: a single centered row of completed badge then descending-rarity badges. -->
    <DataTemplate x:Key="ProgressFooterCenterTemplate">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Image Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
            <ContentControl VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
        </StackPanel>
    </DataTemplate>

    <!-- Left alignment (inverse of Right): badge row pinned far left in ascending-rarity order
         (FlowDirection flip reverses the shared row), completed badge pinned far right. -->
    <DataTemplate x:Key="ProgressFooterLeftTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FlowDirection="RightToLeft"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
            <Image Grid.Column="1"
                   Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   HorizontalAlignment="Right"
                   Margin="0,0,4,0"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </DataTemplate>

    <Style x:Key="OverviewChartColumnSeriesStyle" TargetType="lvc:ColumnSeries" BasedOn="{StaticResource PlayAch.ChartColumnSeriesStyle}"/>

</ResourceDictionary>
