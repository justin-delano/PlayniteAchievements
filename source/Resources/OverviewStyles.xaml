<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
                    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Cell content wrapper providing consistent per-cell padding. -->
    <Style x:Key="OverviewCellFrameStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid UseLayoutRounding="{TemplateBinding UseLayoutRounding}"
                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GameSummariesGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="IsTabStop" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ContentPresenter VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GameSummariesImageCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource GameSummariesGridCellStyle}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="GameSummariesGridRowBaseStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="112"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRow}">
                    <Border x:Name="DGR_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <SelectiveScrollingGrid>
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <SelectiveScrollingGrid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </SelectiveScrollingGrid.RowDefinitions>

                            <DataGridCellsPresenter Grid.Column="1"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                            <DataGridDetailsPresenter Grid.Column="1"
                                                      Grid.Row="1"
                                                      SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                      Visibility="{TemplateBinding DetailsVisibility}"/>

                            <DataGridRowHeader Grid.RowSpan="2"
                                               SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                                               Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>

                        </SelectiveScrollingGrid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ContextMenu.IsOpen, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowSelectedBackground}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GameSummaryNameTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
    </Style>

    <Style x:Key="OverviewGameMetadataTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="Opacity" Value="{StaticResource PlayAch.Opacity.Muted}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
    </Style>

    <Style x:Key="GameSummaryProviderIconStyle" TargetType="Image">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="HorizontalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"/>
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor"/>
    </Style>

    <Style x:Key="OverviewProgressContainerStyle" TargetType="Grid">
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
    </Style>

    <Style x:Key="OverviewProgressStackStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment"
                Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="VerticalAlignment" Value="Center">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverviewProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource GameProgressBar}">
        <Setter Property="Height" Value="22"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding ProgressTier}" Value="Common">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Progress.TierFill.Common}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Rarity.Common}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ProgressTier}" Value="Uncommon">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Progress.TierFill.Uncommon}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Rarity.Uncommon}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ProgressTier}" Value="Rare">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Progress.TierFill.Rare}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Rarity.Rare}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ProgressTier}" Value="UltraRare">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Progress.TierFill.UltraRare}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Rarity.UltraRare}"/>
            </DataTrigger>
            <!-- Declared last: later matching triggers win, so completion overrides the tier color. -->
            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Progress.CompletedFill}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Progress.CompletedFill}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverviewProgressPercentTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="OverviewProgressMetaRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="OverviewProgressFooterStyle" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="MinHeight" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeItemStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="4,0"/>
        <!-- Keep each badge's image+count physically left-to-right even when the badge row is
             flipped to RightToLeft (Left progress alignment) to reverse the rarity order. -->
        <Setter Property="FlowDirection" Value="LeftToRight"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeImageStyle" TargetType="Image" BasedOn="{StaticResource RarityIcon}">
        <Setter Property="Effect" Value="{StaticResource BadgeShadow}"/>
        <Setter Property="Width" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
        <Setter Property="Height" Value="{StaticResource PlayAch.Size.Icon.Tiny}"/>
    </Style>

    <Style x:Key="OverviewMiniBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
        <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="3,0,0,0"/>
    </Style>

    <Style x:Key="OverviewCompletedFooterIconStyle" TargetType="Image" BasedOn="{StaticResource OverviewMiniBadgeImageStyle}">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>

    <!-- Shared rarity/trophy badge row for the Progress column footer. Only one of the two
         panels is visible at a time (rarity vs. PlayStation trophies). The host positions and
         (for Left alignment) flips this row; the row itself stays alignment-neutral so the same
         markup serves every alignment without duplication. -->
    <DataTemplate x:Key="ProgressBadgeRowTemplate">
        <Grid VerticalAlignment="Center">
            <StackPanel Style="{StaticResource OverviewProgressMetaRowStyle}"
                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UltraRareCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Rarity_UltraRare}">
                    <Image Source="{DynamicResource BadgeRarityUltraRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding UltraRareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding RareCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Rarity_Rare}">
                    <Image Source="{DynamicResource BadgeRarityRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding RareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UncommonCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Rarity_Uncommon}">
                    <Image Source="{DynamicResource BadgeRarityUncommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding UncommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding CommonCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Rarity_Common}">
                    <Image Source="{DynamicResource BadgeRarityCommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding CommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Style="{StaticResource OverviewProgressMetaRowStyle}"
                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource BoolToVis}}">
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyPlatinumCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Trophy_Platinum}">
                    <Image Source="{DynamicResource TrophyPlatinum}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyPlatinumCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyGoldCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Trophy_Gold}">
                    <Image Source="{DynamicResource TrophyGold}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyGoldCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophySilverCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Trophy_Silver}">
                    <Image Source="{DynamicResource TrophySilver}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophySilverCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyBronzeCount, Converter={StaticResource IntToVis}}" ToolTip="{DynamicResource LOCPlayAch_Trophy_Bronze}">
                    <Image Source="{DynamicResource TrophyBronze}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                    <TextBlock Text="{Binding TrophyBronzeCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!-- Right alignment (default / legacy look): completed badge pinned far left, badge row
         pinned far right in descending-rarity order. -->
    <DataTemplate x:Key="ProgressFooterRightTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
            <ContentControl Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
        </Grid>
    </DataTemplate>

    <!-- Center alignment: a single centered row in ascending-rarity order (badge row reversed via
         the same FlowDirection flip as the Left layout) followed by the completed badge. -->
    <DataTemplate x:Key="ProgressFooterCenterTemplate">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <ContentControl VerticalAlignment="Center"
                            FlowDirection="RightToLeft"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
            <Image Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </DataTemplate>

    <!-- Left alignment (inverse of Right): badge row pinned far left in ascending-rarity order
         (FlowDirection flip reverses the shared row), completed badge pinned far right. -->
    <DataTemplate x:Key="ProgressFooterLeftTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FlowDirection="RightToLeft"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource ProgressBadgeRowTemplate}"/>
            <Image Grid.Column="1"
                   Source="{DynamicResource BadgeRarityCompleted}"
                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                   HorizontalAlignment="Right"
                   Margin="0,0,4,0"
                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </DataTemplate>

    <Style x:Key="OverviewChartColumnSeriesStyle" TargetType="lvc:ColumnSeries" BasedOn="{StaticResource PlayAch.ChartColumnSeriesStyle}"/>

    <!-- Compact, square close button for selected-item headers (kept small so it
         does not expand the header row like the larger circular NavigationButtonStyle). -->
    <Style x:Key="ClearGameSelectionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Opacity" Value="0.72"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource PlayAch.Radius.Small}"
                            SnapsToDevicePixels="True">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Draggable center divider used to split the Overview/Friends columns. Draws its own themed
         vertical line so a single element serves as both the visible seam and the resize handle. -->
    <Style x:Key="CenterLineSplitterStyle" TargetType="GridSplitter">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="ResizeDirection" Value="Columns"/>
        <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
        <Setter Property="ShowsPreview" Value="False"/>
        <Setter Property="Cursor" Value="SizeWE"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                            BorderThickness="1,0,0,0"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
