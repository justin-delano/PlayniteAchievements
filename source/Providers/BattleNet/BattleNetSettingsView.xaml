<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.BattleNet.BattleNetSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="BattleNetFieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,12,8"/>
            </Style>

            <Style x:Key="BattleNetStatusIconStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Text" Value="&#xE783;"/>
                <Setter Property="Foreground" Value="{StaticResource PlayAch.Brush.AuthError}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoBattleNet}" Fill="{StaticResource PlayAch.Brush.ProviderBattleNet}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_BattleNet}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}"
                    Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                <StackPanel>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_UseExophaseForMetadata}"
                              IsChecked="{Binding Settings.UseExophaseForRarity, Mode=TwoWay}"
                              FontWeight="SemiBold"
                              FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UseExophaseForMetadata_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="24,8,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowSection}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Background="{DynamicResource PlayAch.Brush.Panel}"
                            CornerRadius="8"
                            Padding="16"
                            BorderThickness="{StaticResource PlayAch.Thickness.Border}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.AuthError}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WowConfigured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.AuthSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BattleNetStatusIconStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WowConfigured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PlayAch.Brush.AuthSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding WowStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRegion}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              x:Name="WowRegionCombo"
                                              SelectionChanged="WowRegion_SelectionChanged"
                                              FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRealm}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              x:Name="WowRealmCombo"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="WowRealm_SelectionChanged"
                                              FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowCharacter}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Settings.WowCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

                <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Section}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Background="{DynamicResource PlayAch.Brush.Panel}"
                            CornerRadius="8"
                            Padding="16"
                            BorderThickness="{StaticResource PlayAch.Thickness.Border}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.AuthError}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Sc2Configured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.AuthSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BattleNetStatusIconStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Sc2Configured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="Foreground" Value="{StaticResource PlayAch.Brush.AuthSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Sc2Status, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientId}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding Settings.BattleNetClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                             Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientSecret}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <PasswordBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 x:Name="ClientSecretBox"
                                                 PasswordChanged="ClientSecret_Changed"
                                                 FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Region}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2RegionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                             Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Realm}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2RealmId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                             Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Profile}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2ProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
