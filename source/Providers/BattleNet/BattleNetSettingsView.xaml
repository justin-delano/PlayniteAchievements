<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.BattleNet.BattleNetSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
 d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Viewbox Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Data="{StaticResource GeoBattleNet}" Fill="#14B8A6"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_BattleNet}"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <!-- Provider Enable Toggle -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource FontSize}"/>
            </Border>

            <!-- Provider Disabled Message -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}"
                       Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- WoW Configuration -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,12,0,12"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowSection}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRegion}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="WowRegionCombo"
                                  SelectionChanged="WowRegion_SelectionChanged"
 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRealm}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="WowRealmCombo"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="WowRealm_SelectionChanged"
                                  Margin="0,8,0,0"
                                  FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowCharacter}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="WowCharacterBox"
                                 Text="{Binding Settings.WowCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"
                                 FontSize="{DynamicResource FontSize}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SC2 Configuration -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Section}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientId}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding Settings.BattleNetClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"
                                 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientSecret}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="ClientSecretBox"
                                     PasswordChanged="ClientSecret_Changed"
                                     Margin="0,8,0,0"
                                     FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Region}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding Settings.Sc2RegionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"
                                 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Realm}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding Settings.Sc2RealmId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"
                                 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Profile}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding Settings.Sc2ProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"
                                 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Common_Status_Linked}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="Sc2StatusText"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
