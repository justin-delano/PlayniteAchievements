<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.BattleNet.BattleNetSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
 d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="AuthActionButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource {x:Type Button}}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding AuthBusy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </Style.Triggers>
                </Style>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
 HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Viewbox Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Data="{StaticResource GeoBattleNet}" Fill="#14B8A6"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_BattleNet}"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <!-- Provider Enable Toggle -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource FontSize}"/>
            </Border>

            <!-- Provider Disabled Message -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}"
                       Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Authentication -->
            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock x:Name="ConnectionLabel"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="AuthLabel"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,8,0,0"/>

                        <!-- Auth Card -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#F72585"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="BorderBrush" Value="#06FFA5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <!-- Status Row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               FontFamily="Segoe MDL2 Assets"
 Color="{DynamicResource TextBrush}"
                                               FontSize="{DynamicResource FontSize}" Margin="0,0,12,0"
 VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE783;"/>
                                                <Setter Property="Foreground" Value="#F72585"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthenticated, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 Value="True">
                                                        <Setter Property="Text" Value="&#xE73E;"/>
                                                        <Setter Property="Foreground" Value="#06FFA5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Login}"
                                            Click="LoginWeb_Click"
 Style="{StaticResource AuthActionButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Clear}"
 Click="Logout_Click" Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- WoW Configuration -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,12,0,12"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowSection}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRegion}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="WowRegionCombo"
                                  SelectionChanged="WowRegion_SelectionChanged"
 FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRealm}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="WowRealmCombo"
                                  FontSize="{DynamicResource FontSize}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowCharacter}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="WowCharacterBox"
                                 Text="{Binding Settings.WowCharacter, Mode=TwoWay}"
                                 FontSize="{DynamicResource FontSize}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SC2 Status -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Section}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Region}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="Sc2StatusText"
                                   Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
