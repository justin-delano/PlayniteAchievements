<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.BattleNet.BattleNetSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="BattleNetFieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,12,8"/>
            </Style>

            <Style x:Key="BattleNetStatusIconStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Text" Value="&#xE783;"/>
                <Setter Property="Foreground" Value="#F72585"/>
            </Style>

            <Style x:Key="AuthActionButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource {x:Type Button}}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding AuthBusy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Viewbox Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Data="{StaticResource GeoBattleNet}" Fill="#14B8A6"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_BattleNet}"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource FontSize}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}"
                       Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

                <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowSection}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            CornerRadius="8"
                            Padding="16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#F72585"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WowConfigured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="BorderBrush" Value="#06FFA5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BattleNetStatusIconStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WowConfigured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="Foreground" Value="#06FFA5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding WowStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRegion}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              x:Name="WowRegionCombo"
                                              SelectionChanged="WowRegion_SelectionChanged"
                                              FontSize="{DynamicResource FontSize}"
                                              Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowRealm}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              x:Name="WowRealmCombo"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="WowRealm_SelectionChanged"
                                              FontSize="{DynamicResource FontSize}"
                                              Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_WowCharacter}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"
                                               Margin="0,0,12,0"/>
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Settings.WowCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientId}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"
                                               Margin="0,12,12,8"/>
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding Settings.BattleNetClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"
                                             Margin="0,12,0,8"/>

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientSecret}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <PasswordBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 x:Name="WowClientSecretBox"
                                                 PasswordChanged="WowClientSecret_Changed"
                                                 FontSize="{DynamicResource FontSize}"
                                                 Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="5"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_RedirectUri}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="5"
                                             Grid.Column="1"
                                             Text="{Binding Settings.BattleNetRedirectUri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"
                                             Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="6"
                                              Grid.Column="1"
                                              Content="{DynamicResource LOCPlayAch_Settings_BattleNet_AggregateAccountCharacters}"
                                              IsChecked="{Binding Settings.WowAggregateAccountCharacters, Mode=TwoWay}"
                                              FontSize="{DynamicResource FontSize}"/>
                                </Grid>
                            </Border>

                            <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0"
                                    Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_OAuthHelp}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0">
                                            <TextBlock.RenderTransform>
                                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BattleNetStatusIconStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOAuthAuthenticated, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                     Value="True">
                                                            <Setter Property="Text" Value="&#xE73E;"/>
                                                            <Setter Property="Foreground" Value="#06FFA5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Login}"
                                                Click="LoginWeb_Click"
                                                Style="{StaticResource AuthActionButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Common_Check}"
                                                Click="Auth_Check_Click"
                                                Style="{StaticResource AuthActionButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                Click="Logout_Click"
                                                Style="{StaticResource AuthActionButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

                <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Section}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            CornerRadius="8"
                            Padding="16"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#F72585"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Sc2Configured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="BorderBrush" Value="#06FFA5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BattleNetStatusIconStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Sc2Configured, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="Foreground" Value="#06FFA5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Sc2Status, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientId}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding Settings.BattleNetClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"
                                             Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_ClientSecret}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <PasswordBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 x:Name="ClientSecretBox"
                                                 PasswordChanged="ClientSecret_Changed"
                                                 FontSize="{DynamicResource FontSize}"
                                                 Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Region}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2RegionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"
                                             Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Realm}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"/>
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2RealmId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"
                                             Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="{DynamicResource LOCPlayAch_Settings_BattleNet_Sc2Profile}"
                                               Style="{StaticResource BattleNetFieldLabelStyle}"
                                               Margin="0,0,12,0"/>
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding Settings.Sc2ProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="{DynamicResource FontSize}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
