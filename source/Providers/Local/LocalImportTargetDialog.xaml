<UserControl x:Class="PlayniteAchievements.Providers.Local.LocalImportTargetDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PlayniteAchievements.Providers.Local"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="520"
             FocusManager.FocusedElement="{Binding ElementName=TargetComboBox}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Choose the Playnite library target for newly imported Local-folder games."
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Target library"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="TargetComboBox"
                      Grid.Column="1"
                      SelectedValue="{Binding SelectedTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Tag"
                      SelectionChanged="TargetComboBox_SelectionChanged"
                      MinHeight="30">
                <ComboBoxItem Content="None (manual game)"
                              Tag="{x:Static local:LocalImportedGameLibraryTarget.None}" />
                <ComboBoxItem Content="Steam library"
                              Tag="{x:Static local:LocalImportedGameLibraryTarget.Steam}" />
                <ComboBoxItem Content="Playnite source"
                              Tag="{x:Static local:LocalImportedGameLibraryTarget.CustomSource}" />
            </ComboBox>
        </Grid>

        <Grid x:Name="CustomSourceRow" Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Playnite source"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="CustomSourceComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding SourceOptions}"
                      SelectedItem="{Binding CustomSourceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinHeight="30" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Metadata source"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="MetadataSourceComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding MetadataSourceOptions}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding MetadataSourceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinHeight="30" />
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Existing game handling"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      SelectedValue="{Binding ExistingGameBehavior, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Tag"
                      MinHeight="30">
                <ComboBoxItem Content="Overwrite existing game"
                              Tag="{x:Static local:LocalExistingGameImportBehavior.OverwriteExisting}" />
                <ComboBoxItem Content="Skip existing game"
                              Tag="{x:Static local:LocalExistingGameImportBehavior.SkipExisting}" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="5" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Steam appcache user"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding SteamAppCacheUserOptions}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="UserId"
                      SelectedValue="{Binding SteamAppCacheUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinHeight="30" />
        </Grid>

        <Grid Grid.Row="6" Margin="0,2,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Schema-only folders"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <CheckBox Grid.Column="1"
                      IsChecked="{Binding IncludeFoldersWithoutAchievementFiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center"
                      Content="Also import numbered Local folders without achievements.ini or achievements.json" />
        </Grid>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="{DynamicResource LOCPlayAch_Button_Ok}"
                    Click="OkButton_Click"
                    Padding="12,6"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    IsDefault="True" />
            <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                    Click="CancelButton_Click"
                    Padding="12,6"
                    MinWidth="80"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</UserControl>