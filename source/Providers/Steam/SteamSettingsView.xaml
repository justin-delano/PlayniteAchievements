<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Steam.SteamSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="IgnoredFriendsGridRowStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource GameSummariesGridRowBaseStyle}">
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>

            <Style x:Key="IgnoredFriendTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoSteam}" Fill="{StaticResource PlayAch.Brush.ProviderSteam}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Steam}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <!-- Provider Enable Toggle -->
            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <!-- Provider Disabled Message -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <!-- Steam Connection Section -->
            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <!-- Steam Authentication -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="AuthLabel"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   VerticalAlignment="Top"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                        <!-- Auth Card -->
                        <Border Grid.Column="1"
                                Style="{StaticResource AuthStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource AuthStatusIconStyle}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WebAuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Login}"
                                            Click="LoginWeb_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Common_Check}"
                                            Click="SteamAuth_Check_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                            Click="Logout_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Friends Section -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Friends}"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="{StaticResource PlayAch.Thickness.Top.Md}"/>
            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <Expander Header="{DynamicResource LOCPlayAch_Settings_IgnoredFriends}"
                          IsExpanded="False">
                    <DataGrid ItemsSource="{Binding Settings.IgnoredFriends}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                              Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                              MaxHeight="220">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell"
                                   BasedOn="{StaticResource GameSummariesGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource IgnoredFriendsGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="44" MinWidth="32" MaxWidth="96" CanUserResize="True"
                                                    Header="{DynamicResource LOCPlayAch_Column_Avatar}"
                                                    CanUserSort="False"
                                                    CellStyle="{StaticResource GameSummariesImageCellStyle}">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Opacity="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}"
                                                        Padding="0,6">
                                            <Border CornerRadius="{StaticResource PlayAch.Radius.Small}"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource PlayAch.Brush.Control.Background}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="icon,width,12,8,12">
                                                        <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                                <Border.Height>
                                                    <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="icon,height,12,8,12">
                                                        <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Height>
                                                <Image Stretch="UniformToFill"
                                                       ToolTip="{Binding DisplayName}"
                                                       helpers:AsyncImage.Uri="{Binding AvatarUrl}"
                                                       helpers:AsyncImage.DecodePixel="64"/>
                                            </Border>
                                        </ContentControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_Friend}"
                                                Binding="{Binding DisplayName}"
                                                ElementStyle="{StaticResource IgnoredFriendTextStyle}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Settings_SteamId}"
                                                Binding="{Binding SteamId}"
                                                ElementStyle="{StaticResource IgnoredFriendTextStyle}"
                                                Width="180"/>
                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Settings_IgnoredUtc}"
                                                Binding="{Binding IgnoredLocal, StringFormat=g}"
                                                ElementStyle="{StaticResource IgnoredFriendTextStyle}"
                                                Width="150"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource LOCPlayAch_Common_Remove}"
                                                CommandParameter="{Binding SteamId}"
                                                Click="RemoveIgnoredFriend_Click"
                                                Style="{StaticResource AuthActionButtonStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>

