<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Steam.SteamSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Disable auth buttons while busy -->
            <Style x:Key="AuthActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding AuthBusy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Viewbox Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Data="{StaticResource GeoSteam}" Fill="#B0B0B0"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Steam}"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>

            <!-- Provider Enable Toggle -->
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource FontSize}"/>
            </Border>

            <!-- Provider Disabled Message -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}"
                       Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Steam Connection Section -->
            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <!-- Steam Authentication -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="AuthLabel"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,8,0,0"/>

                        <!-- Auth Card -->
                        <Border Grid.Column="1"
                                Style="{StaticResource AuthStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource AuthStatusIconStyle}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WebAuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Login}"
                                            Click="LoginWeb_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Common_Check}"
                                            Click="SteamAuth_Check_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                            Click="Logout_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>

