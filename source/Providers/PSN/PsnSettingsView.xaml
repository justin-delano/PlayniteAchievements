<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.PSN.PsnSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoPSN}" Fill="{StaticResource PlayAch.Brush.ProviderPsn}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_PSN}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold" FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock x:Name="ConnectionLabel"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PlayAch.Brush.Text}" Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}">
                            <Run Text="1. "/><Hyperlink NavigateUri="https://www.playstation.com" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="Underline" FontWeight="SemiBold"><TextBlock Foreground="{StaticResource PlayAch.Brush.ActionLink}" Text="{DynamicResource LOCPlayAch_Settings_Psn_Step1}"/></Hyperlink><Run Text=" "/><Run Text="{DynamicResource LOCPlayAch_Settings_Psn_Step1Note}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PlayAch.Brush.Text}" Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}">
                            <Run Text="2. "/><Hyperlink NavigateUri="https://ca.account.sony.com/api/v1/ssocookie" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="Underline" FontWeight="SemiBold"><TextBlock Foreground="{StaticResource PlayAch.Brush.ActionLink}" Text="{DynamicResource LOCPlayAch_Settings_Psn_Step2}"/></Hyperlink><Run Text=" "/><Run Text="{DynamicResource LOCPlayAch_Settings_Psn_Step2Note}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource PlayAch.Brush.Text}">
                            <Run Text="3. "/><Run Text="{DynamicResource LOCPlayAch_Settings_Psn_Step3}"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="AuthLabel"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Top" Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                        <Border Grid.Column="1"
                                Style="{StaticResource AuthStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource AuthStatusIconStyle}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Login}"
                                            Click="PsnAuth_Login_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Common_Check}"
                                            Click="PsnAuth_Check_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                    <Button Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                            Click="PsnAuth_Clear_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>

                                <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0"
                                        Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PsnNpsso}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                        <TextBox Text="{Binding Settings.Npsso, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 x:Name="PsnNpssoTextBox"
                                                 Padding="8,6"
                                                 VerticalAlignment="Top"
                                                 MaxHeight="60"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="False"
                                                 VerticalScrollBarVisibility="Auto"
                                                 KeyDown="PsnNpsso_KeyDown"/>

                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                                   Text="{DynamicResource LOCPlayAch_Settings_PsnNpssoHint}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>


