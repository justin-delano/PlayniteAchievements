<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.ShadPS4.ShadPS4SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoShadPS4}" Fill="{StaticResource PlayAch.Brush.ProviderShadPS4}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_ShadPS4}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold" FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock x:Name="ConnectionLabel"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_ShadPS4GameDataPath}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   VerticalAlignment="Top"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                        <Border Grid.Column="1" Style="{StaticResource ProviderConfigStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource ProviderConfigStatusIconStyle}">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0"
                                        Margin="0,0,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Settings.GameDataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="4"
                                                     Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                                     KeyDown="ShadPS4GameDataPath_KeyDown"
                                                     LostFocus="ShadPS4GameDataPath_LostFocus"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                                    Click="ShadPS4_Browse_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Compact}"/>
                                        </Grid>

                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ShadPS4GameDataPathHint}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_UseExophaseForMetadata}"
                              IsChecked="{Binding Settings.UseExophaseForRarity, Mode=TwoWay}"
                              FontWeight="SemiBold"
                              FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UseExophaseForMetadata_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="24,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
