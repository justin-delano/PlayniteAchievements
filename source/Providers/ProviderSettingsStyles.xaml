<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderIcons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style x:Key="SettingRowStyle" TargetType="Grid">
        <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <!-- Section container style with shadow -->
    <Style x:Key="SectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Muted text style -->
    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="AuthStatusBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#F72585"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAuthStatusPending, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="True">
                <Setter Property="BorderBrush" Value="#FBBF24"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAuthStatusSuccess, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="True">
                <Setter Property="BorderBrush" Value="#06FFA5"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AuthStatusIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="LineHeight" Value="24"/>
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Text" Value="&#xE783;"/>
        <Setter Property="Foreground" Value="#F72585"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAuthStatusPending, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="True">
                <Setter Property="Text" Value="&#xE9CE;"/>
                <Setter Property="Foreground" Value="#FBBF24"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsAuthStatusSuccess, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Value="True">
                <Setter Property="Text" Value="&#xE930;"/>
                <Setter Property="Foreground" Value="#06FFA5"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
