<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Exophase.ExophaseSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="AuthActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding AuthBusy, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold" FontSize="{DynamicResource FontSize}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Margin="0,0,0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_EnableProvider_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ExophaseConnection}"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap">
                        <Run Text="{DynamicResource LOCPlayAch_Settings_ExophaseAuth_Description}"/>
                        <Run Text=" "/>
                        <Run Text="{DynamicResource LOCPlayAch_Settings_Exophase_Help}"/>
                    </TextBlock>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource LOCPlayAch_Label_ExophaseAuth}"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Top" Margin="0,8,0,0"/>

                        <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}"
                                CornerRadius="8" Padding="16" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#F72585"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="BorderBrush" Value="#06FFA5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FontSize}"
                                               Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform><ScaleTransform ScaleX="1.5" ScaleY="1.5"/></TextBlock.RenderTransform>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE783;"/>
                                                <Setter Property="Foreground" Value="#F72585"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthenticated, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Text" Value="&#xE73E;"/>
                                                        <Setter Property="Foreground" Value="#06FFA5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Login}" Click="LoginWeb_Click"
                                            Style="{StaticResource AuthActionButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Clear}" Click="Logout_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}"
                    Margin="0,16,0,16"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_ManagedPlatforms}"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_ManagedPlatforms_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,12"/>

                    <Border Background="#10000000"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,4,0,0">
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="150"
                                   Margin="0,2,0,0">
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_Steam}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="steam"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_PSN}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="psn"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_Xbox}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="xbox"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_GOG}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="gog"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_Epic}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="epic"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Exophase_Platform_Retro}"
                                      Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="retro"
                                      Margin="0,0,12,10"
                                      FontSize="{DynamicResource FontSize}"/>
                        </WrapPanel>
                    </Border>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_Note}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
