<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Exophase.ExophaseSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ExophaseFriendsGridRowStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource GameSummariesGridRowBaseStyle}">
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>

            <Style x:Key="ExophaseFriendTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Exophase}" Style="{StaticResource ProviderTitleOnlyTextStyle}"/>

            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold" FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_EnableProvider_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="ConnectionLabel"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                               TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="AuthLabel"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Top" Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                        <Border Grid.Column="1"
                                Style="{StaticResource AuthStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource AuthStatusIconStyle}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Login}" Click="LoginWeb_Click"
                                            Style="{StaticResource AuthActionButtonStyle}" Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Common_Check}" Click="Auth_Check_Click"
                                            Style="{StaticResource AuthActionButtonStyle}" Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Button_Clear}" Click="Logout_Click"
                                            Style="{StaticResource AuthActionButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}"
                    Margin="0,16,0,16"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_ManagedPlatforms}"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_ManagedPlatforms_Help}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <Border Background="{StaticResource PlayAch.Brush.Overlay.Shade.10}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Top.Xs}">
                        <StackPanel Margin="0,2,0,0">
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="steam" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoSteam}" Fill="{StaticResource PlayAch.Brush.ProviderSteam}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Steam}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="psn" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoPSN}" Fill="{StaticResource PlayAch.Brush.ProviderPsn}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_PSN}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="xbox" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoXbox}" Fill="{StaticResource PlayAch.Brush.ProviderXbox}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Xbox}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="gog" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoGOG}" Fill="{StaticResource PlayAch.Brush.ProviderGog}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_GOG}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="epic" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoEpic}" Fill="{StaticResource PlayAch.Brush.ProviderEpic}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Epic}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="blizzard" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoBattleNet}" Fill="{StaticResource PlayAch.Brush.ProviderBattleNet}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_BattleNet}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="origin" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoEA}" Fill="{StaticResource PlayAch.Brush.ProviderEA}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_EA}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="android" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoGooglePlay}" Fill="{StaticResource PlayAch.Brush.ProviderGooglePlay}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_GooglePlay}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="apple" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoApple}" Fill="{StaticResource PlayAch.Brush.ProviderApple}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Apple}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="ubisoft" Margin="0,0,0,10"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoUbisoft}" Fill="{StaticResource PlayAch.Brush.ProviderUbisoft}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Ubisoft}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox Loaded="ExophasePlatform_CheckboxLoaded"
                                      Click="ExophasePlatform_CheckChanged"
                                      Tag="retro" Margin="0,0,0,0"
                                      FontSize="{DynamicResource PlayAch.FontSize.Body}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Sm}" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GeoRetroAchievements}" Fill="{StaticResource PlayAch.Brush.ProviderRetroAchievements}"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_RetroAchievements}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Exophase_Note}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}"
                    Margin="0,0,0,16"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Friends}"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewFriendUsernameTextBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_Common_Add}"
                                Click="AddExophaseFriend_Click"
                                Style="{StaticResource AuthActionButtonStyle}"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Friends}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                              MaxHeight="360">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell"
                                   BasedOn="{StaticResource GameSummariesGridCellStyle}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource ExophaseFriendsGridRowStyle}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_Friend}"
                                                Binding="{Binding DisplayName}"
                                                ElementStyle="{StaticResource ExophaseFriendTextStyle}"
                                                Width="*"/>
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_FullLibrary}"
                                                    Width="Auto"
                                                    CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsFullLibrary, Mode=OneWay}"
                                                  Click="FullLibraryToggle_Click"
                                                  ToolTip="{DynamicResource LOCPlayAch_Menu_UseFullLibrary}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}"
                                                    Width="200"
                                                    CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch">
                                            <ToggleButton x:Name="PlatformsPopupToggle"
                                                          Content="{Binding PlatformButtonLabel}"
                                                          HorizontalContentAlignment="Left"
                                                          Margin="4,2"/>
                                            <Popup IsOpen="{Binding IsChecked, ElementName=PlatformsPopupToggle, Mode=TwoWay}"
                                                   PlacementTarget="{Binding ElementName=PlatformsPopupToggle}"
                                                   Placement="Bottom"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade">
                                                <Border Background="{DynamicResource PlayAch.Brush.Panel}"
                                                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                        BorderThickness="1"
                                                        Padding="8">
                                                    <ItemsControl ItemsSource="{Binding Platforms}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          Margin="0,2"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_LastError}"
                                                Binding="{Binding LastError}"
                                                ElementStyle="{StaticResource ExophaseFriendTextStyle}"
                                                Width="1.5*"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="Auto"
                                                    CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource LOCPlayAch_Common_Remove}"
                                                Click="RemoveFriend_Click"
                                                Style="{StaticResource AuthActionButtonStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
