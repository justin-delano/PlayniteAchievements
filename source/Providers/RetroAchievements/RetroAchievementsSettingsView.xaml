<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.RetroAchievements.RetroAchievementsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoRetroAchievements}" Fill="{StaticResource PlayAch.Brush.ProviderRetroAchievements}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_RetroAchievements}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <!-- Provider Enable Toggle -->
            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold"
                          FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <!-- Provider Disabled Message -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <!-- RetroAchievements Settings -->
            <Border Style="{StaticResource SectionBorderStyle}"
                    IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="AuthLabel"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                        <Border Grid.Column="1" Style="{StaticResource ProviderConfigStatusBorderStyle}">

                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource ProviderConfigStatusIconStyle}">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AuthStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <Border BorderBrush="{DynamicResource PopupBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RaUsername}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                                        <TextBox Text="{Binding Settings.RaUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RaUsername_Help}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RaWebApiKey}"
                                                   Margin="0,12,0,8"/>
                                        <TextBox Text="{Binding Settings.RaWebApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RaWebApiKey_Help}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- RetroAchievements Rarity Stats -->
                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_RaRarityStats}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  SelectedValue="{Binding Settings.RaRarityStats, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  VerticalAlignment="Center"
                                  MinWidth="160"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RaRarityStats_Casual}" Tag="casual"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RaRarityStats_Hardcore}" Tag="hardcore"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RaRarityStats_Combined}" Tag="combined"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{DynamicResource LOCPlayAch_Settings_RaRarityStats_Description}"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Compact}"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </Grid>

                    <!-- RetroAchievements Points Display Mode -->
                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_RaPointsMode}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  SelectedValue="{Binding Settings.RaPointsMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  VerticalAlignment="Center"
                                  MinWidth="160"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RaPointsMode_Points}" Tag="points"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RaPointsMode_Scaled}" Tag="scaled"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{DynamicResource LOCPlayAch_Settings_RaPointsMode_Description}"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Compact}"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScanningHashing}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="0,8,0,12"/>

                    <StackPanel>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableArchiveScanning}"
                                  IsChecked="{Binding Settings.EnableArchiveScanning, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableDiscHashing}"
                                  IsChecked="{Binding Settings.EnableDiscHashing, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_RaEnableFuzzyNameMatching}"
                                  IsChecked="{Binding Settings.EnableFuzzyNameMatching, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_RaEnableSubsetScanning}"
                                  IsChecked="{Binding Settings.EnableRaSubsetScanning, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_RaEnableAutomaticCapstoneAssignment}"
                                  IsChecked="{Binding Settings.EnableAutomaticCapstoneAssignment, Mode=TwoWay}"
                                  Margin="0,0,0,10"/>
                    </StackPanel>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_HashIndexMaxAgeDays}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Settings.HashIndexMaxAgeDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60"
                                 TextAlignment="Right"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_ForceHashIndexRebuild}"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_Settings_RebuildNow}"
                                Click="ForceRebuildHashIndex_Click"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                Margin="16,0,0,0"
                                MinWidth="90"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
