<settings:ProviderSettingsViewBase x:Class="PlayniteAchievements.Providers.Manual.ManualSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settings="clr-namespace:PlayniteAchievements.Providers.Settings"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Providers/ProviderSettingsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- Provider Header -->
            <StackPanel Style="{StaticResource ProviderHeaderPanelStyle}">
                <Viewbox Style="{StaticResource ProviderHeaderIconStyle}">
                    <Path Data="{StaticResource GeoManual}" Fill="{StaticResource PlayAch.Brush.ProviderManual}"/>
                </Viewbox>
                <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Manual}" Style="{StaticResource ProviderTitleTextStyle}"/>
            </StackPanel>

            <Border Style="{StaticResource ProviderEnableToggleBorderStyle}">
                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ProviderEnabled}"
                          IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay}"
                          FontWeight="SemiBold" FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
            </Border>

            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderDisabledMessage}" Style="{StaticResource ProviderDisabledMessageStyle}"/>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}" Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                <StackPanel>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Manual_Override_Enable}"
                              IsChecked="{Binding Settings.ManualTrackingOverrideEnabled, Mode=TwoWay}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_Manual_RequireExophaseAuth}"
                              IsChecked="{Binding Settings.RequireExophaseAuthentication, Mode=TwoWay}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_RequireExophaseAuth_Description}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_Override_Description}"
                               Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" IsEnabled="{Binding Settings.IsEnabled}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_Legacy_Header}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_Legacy_Description}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_Legacy_PathLabel}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Manual_Legacy_PathHint}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                    <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding LegacyImportPath, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"
                                 Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>

                        <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                Click="ManualLegacyBrowse_Click"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Compact}"/>
                    </Grid>

                    <Button Content="{DynamicResource LOCPlayAch_Settings_Manual_Legacy_ImportButton}"
                            Click="ManualLegacyImport_Click"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                            MinWidth="180"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding LegacyImportStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</settings:ProviderSettingsViewBase>
