<UserControl x:Class="PlayniteAchievements.Views.ManageAchievementsAchievementOrderTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             Loaded="Control_Loaded"
             d:DesignHeight="600"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ManageAchievementsAchievementOrderViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/ManageAchievementsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ManageAchievementsHeaderCardStyle}"
                Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Order_Header}"
                               Style="{StaticResource ManageAchievementsHeaderTitleStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Order_Hint}"
                               Style="{StaticResource ManageAchievementsHeaderHintStyle}" />
                </StackPanel>
                <Button x:Name="ResetOrderButton"
                        Grid.Column="1"
                        Content="{DynamicResource LOCPlayAch_Button_Reset}"
                        Click="ResetOrderButton_Click"
                        Style="{StaticResource ManageAchievementsHeaderActionButtonStyle}"
                        IsEnabled="{Binding HasCustomOrder}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource LOCPlayAch_Common_NoCachedAchievementsForGame}"
                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                   Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   Margin="0"
                   Visibility="{Binding HasAchievements, Converter={StaticResource InverseBoolToVis}}" />

        <DataGrid x:Name="AchievementOrderDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding AchievementRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowBackground="Transparent"
                  BorderThickness="0"
                  Background="Transparent"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  RowHeight="100"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                  helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
                  helpers:DataGridAlignmentBehavior.IsEnabled="True"
                  Tag="ControllerCellFocus"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="DataGrid_PreviewMouseLeftButtonUp"
                  PreviewMouseMove="DataGrid_PreviewMouseMove"
                  DragOver="DataGrid_DragOver"
                  DragLeave="DataGrid_DragLeave"
                  GiveFeedback="DataGrid_GiveFeedback"
                  QueryContinueDrag="DataGrid_QueryContinueDrag"
                  Drop="DataGrid_Drop">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}" />
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource ManageAchievementsDataGridRowStyle}">
                    <Setter Property="MinHeight" Value="64" />
                    <Setter Property="ClipToBounds" Value="True" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanReveal}" Value="True">
                            <Setter Property="Cursor" Value="Hand" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="44" MinWidth="44" MaxWidth="44" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}">
                            <Setter Property="Cursor" Value="SizeAll" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Tag="DragHandle"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Cursor="SizeAll">
                                <TextBlock Tag="DragHandle"
                                           Text="☰"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="0.65" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="36" MinWidth="36" MaxWidth="36" CanUserResize="False"
                                        CellStyle="{StaticResource ManageAchievementsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementStatusTemplate}" />

                <DataGridTemplateColumn Width="64" MinWidth="64" MaxWidth="64" CanUserResize="False"
                                        CellStyle="{StaticResource ManageAchievementsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementIconTemplate}" />

                <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                        CellTemplate="{StaticResource ManageAchievementInfoTemplate}" />
            </DataGrid.Columns>
        </DataGrid>

        <Border x:Name="DropInsertLine"
                Grid.Row="2"
                Height="2"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource PlayAch.Brush.Accent}"
                Visibility="Collapsed"
                Margin="0,0,0,0"
                IsHitTestVisible="False"
                Panel.ZIndex="10" />

        <Popup x:Name="DragCountPopup"
               Placement="AbsolutePoint"
               AllowsTransparency="True"
               StaysOpen="True"
               IsHitTestVisible="False">
            <Border Background="{StaticResource PlayAch.Brush.DialogBackdrop}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Accent}"
                    BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                    CornerRadius="10"
                    Padding="8,3">
                <TextBlock x:Name="DragCountText"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="{DynamicResource PlayAch.FontSize.Caption}" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
