<UserControl x:Class="PlayniteAchievements.Views.FriendCustomRefreshControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="560"
             d:DesignHeight="420">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CustomRefreshScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource PlayAch.Brush.Window.Background}" Padding="12">
        <Grid TextElement.Foreground="{DynamicResource PlayAch.Brush.Text}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{DynamicResource LOCPlayAch_FriendCustomRefresh_Header}"
                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                              Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding ProviderOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsSelectable}"
                                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                  VerticalAlignment="Center"
                                                  Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProviderName}"
                                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding StatusText}"
                                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                                   VerticalAlignment="Center"
                                                   Opacity="{StaticResource PlayAch.Opacity.Hint}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource LOCPlayAch_CustomRefresh_ScopeHeader}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                              Margin="0,0,0,10">
                        <ComboBox ItemsSource="{Binding ScopeOptions}"
                                  SelectedValuePath="Scope"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding SelectedScope, Mode=TwoWay}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  Background="{DynamicResource PlayAch.Brush.Surface}"
                                  BorderBrush="{DynamicResource PlayAch.Brush.Border}"/>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource LOCPlayAch_FriendsOverview_Friends}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                              Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_FriendCustomRefresh_SelectionHint}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       TextWrapping="Wrap"
                                       Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBox Text="{Binding FriendListSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>
                            <ListBox ItemsSource="{Binding FriendItems}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Background="{DynamicResource PlayAch.Brush.Surface}"
                                     BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                     Height="170">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Content="{Binding DisplayText}"
                                                  Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource LOCPlayAch_FriendsOverview_Games}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                              Margin="0,0,0,10">
                        <StackPanel>
                            <TextBox Text="{Binding GameListSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>
                            <ListBox ItemsSource="{Binding GameItems}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Background="{DynamicResource PlayAch.Brush.Surface}"
                                     BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                     Height="170">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Content="{Binding DisplayName}"
                                                  Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock Text="{Binding SummaryText}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               TextWrapping="Wrap"
                               Opacity="{StaticResource PlayAch.Opacity.Secondary}"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Click="CancelButton_Click"
                        Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                        MinWidth="86"
                        Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                <Button Content="{DynamicResource LOCPlayAch_Button_Run}"
                        Click="RunButton_Click"
                        IsEnabled="{Binding CanRun}"
                        Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                        MinWidth="86"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
