<UserControl x:Class="PlayniteAchievements.Views.GameOptionsManualTrackingTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ManualAchievementsViewModel}"
             FocusManager.FocusedElement="{Binding ElementName=SearchTextBox}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BooleanConverter x:Key="InvertedBooleanConverter" Mode="Inverted"/>

            <!-- Cursor style for hidden achievements -->
            <Style x:Key="HiddenAchievementTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Opacity" Value="0.6"/>
                        <Setter Property="FontStyle" Value="Italic"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Checkbox style for DataGrid -->
            <Style x:Key="DataGridCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0"/>
            </Style>

            <!-- Centered column header style -->
            <Style x:Key="CenteredColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <!-- Clickable cell style for hidden achievements -->
            <Style x:Key="ClickableCellStyle" TargetType="Grid">
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Cell style that stretches content to fill cell for clickable areas -->
            <Style x:Key="StretchCellStyle" TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                        <Setter Property="Background" Value="#40FFFFFF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stage Content -->
        <Grid Grid.Row="0">
            <!-- Stage 1: Search -->
            <Grid Visibility="{Binding DataContext.IsSearchStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Search_Header}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Search bar -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchTextBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 KeyDown="SearchTextBox_KeyDown"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Search_Placeholder}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="9,0,0,0"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.5"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="1"
                            Content="✕"
                            Click="ClearSearchTextButton_Click"
                            Width="24"
                            Height="24"
                            Margin="4,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="2"
                            Content="{DynamicResource LOCPlayAch_Button_Search}"
                            Command="{Binding SearchCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="8,0,0,0"/>
                </Grid>

                <!-- Results grid -->
                <Border Grid.Row="2"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Margin="0,0,0,12">
                    <DataGrid ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="Transparent"
                              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                              MouseDoubleClick="SearchDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding IconUrl}"
                                               Width="32" Height="32"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Search_Column_Name}"
                                                Binding="{Binding Name}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Search_Column_AppId}"
                                                Binding="{Binding SourceGameId}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="3"
                           Text="{Binding SearchStatusMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
            </Grid>

            <!-- Stage 2: Refreshing -->
            <Grid Visibility="{Binding DataContext.IsRefreshingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ProgressMessage}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>

                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             Maximum="100"
                             Width="350" Height="24"
                             HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding ProgressPercent, StringFormat={}{0:F0}%, Mode=OneWay}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                <Button Grid.Row="3"
                        Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Command="{Binding CancelRefreshCommand}"
                        IsEnabled="{Binding CanCancelRefresh}"
                        Padding="12,6"
                        MinWidth="80"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0"/>
            </Grid>

            <!-- Stage 3: Editing -->
            <Grid Visibility="{Binding DataContext.IsEditingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Header}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Progress and action bar -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search filter -->
                    <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox Text="{Binding EditSearchFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     Style="{StaticResource SearchTextBoxStyle}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_SearchPlaceholder}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="9,0,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.5"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EditSearchFilter}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EditSearchFilter}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="1"
                                Content="✕"
                                Click="ClearEditFilterButton_Click"
                                Width="24"
                                Height="24"
                                Margin="4,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EditSearchFilter}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EditSearchFilter}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                        <Button Content="{DynamicResource LOCPlayAch_ManualAchievements_Edit_UnlockAll}"
                                Command="{Binding UnlockAllCommand}"
                                Padding="8,4"
                                Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource LOCPlayAch_ManualAchievements_Edit_LockAll}"
                                Command="{Binding LockAllCommand}"
                                Padding="8,4"/>
                    </StackPanel>
                </Grid>

                <!-- Achievements grid -->
                <Border Grid.Row="2"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Margin="0,0,0,12">
                    <DataGrid ItemsSource="{Binding FilteredAchievements}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowBackground="Transparent"
                              BorderThickness="0"
                              Background="Transparent"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="True"
                              EnableRowVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              VirtualizingStackPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource AchievementCellStyle}"/>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource AchievementRowStyle}">
                                <Setter Property="MinHeight" Value="66"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- Unlocked checkbox -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Unlocked}"
                                                    Width="80"
                                                    SortMemberPath="IsUnlocked"
                                                    HeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUnlocked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource DataGridCheckBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUnlocked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource DataGridCheckBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="78"
                                                    MinWidth="78"
                                                    MaxWidth="78"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource AchievementIconTemplate}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                                    Width="*"
                                                    SortMemberPath="DisplayName"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource StretchCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource AchievementInfoTemplate}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlock date -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Date}"
                                                    Width="120"
                                                    HeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="—" Opacity="0.5"
                                                       Visibility="{Binding IsUnlocked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                            <DatePicker SelectedDate="{Binding UnlockDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Padding="4,2"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlock time -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Time}"
                                                    Width="150"
                                                    HeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="—" Opacity="0.5"
                                                       Visibility="{Binding IsUnlocked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBox Text="{Binding HourText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         Width="32"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Padding="2,0"
                                                         MaxLength="2">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValidHour}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                                <TextBox Text="{Binding MinuteText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         Width="32"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Padding="2,0"
                                                         MaxLength="2">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValidMinute}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <ComboBox ItemsSource="{Binding AvailableTimeModes}"
                                                          SelectedItem="{Binding SelectedTimeModeText, Mode=TwoWay}"
                                                          Width="55"
                                                          VerticalContentAlignment="Center"
                                                          Padding="4,0"
                                                          Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Error state -->
            <StackPanel Visibility="{Binding DataContext.HasError,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{DynamicResource LOCPlayAch_Button_Retry}"
                            Command="{Binding RetryCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="12,6"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Vertical"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsEditingStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Manual_Source}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               VerticalAlignment="Center" />
                    <TextBlock Text=": "
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ManualSourceName}"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="   "
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SourceGameName}"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" ("
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SourceGameId}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                    <TextBlock Text=")"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                    <Button Content="{DynamicResource LOCPlayAch_GameOptions_Manual_Unlink}"
                            Command="{Binding UnlinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Padding="10,5"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding SaveStatusMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.8"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"
                           Visibility="{Binding HasSaveStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <!-- Search stage buttons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsSearchStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="{DynamicResource LOCPlayAch_Button_Next}"
                            Click="NextButton_Click"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="0,0,8,0"
                            IsDefault="True"/>
                    <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Click="CancelButton_Click"
                            Padding="12,6"
                            MinWidth="80"
                            IsCancel="True"/>
                </StackPanel>

                <!-- Editing stage buttons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsEditingStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="{DynamicResource LOCPlayAch_Button_Save}"
                            Command="{Binding SaveCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="0,0,8,0"
                            IsDefault="True"/>
                    <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Click="CancelButton_Click"
                            Padding="12,6"
                            MinWidth="80"
                            IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
