<UserControl x:Class="PlayniteAchievements.Views.GameOptionsOverridesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility" />
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12" />
            </Style>
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_ExclusionHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_ExclusionHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding ExclusionStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0" />
                    <Button Content="{Binding ExclusionActionText}"
                            Command="{Binding ToggleExclusionCommand}"
                            Padding="12,6"
                            MinWidth="190"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_SummaryExclusionHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_SummaryExclusionHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding SummaryExclusionStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0" />
                    <Button Content="{Binding SummaryExclusionActionText}"
                            Command="{Binding ToggleSummaryExclusionCommand}"
                            Padding="12,6"
                            MinWidth="190"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Visibility="{Binding IsRaCapable, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_RaHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_RaHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding RaStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,10,0,0"
                          Visibility="{Binding IsRaCapable, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding RaOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" />
                        <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Apply}"
                                Command="{Binding ApplyRaOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                Command="{Binding ClearRaOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                    </Grid>
                    <!--
                    <Grid Margin="0,10,0,0"
                          Visibility="{Binding IsXeniaCapable, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding XeniaOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" />
                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_Button_Apply}"
                                Command="{Binding ApplyXeniaOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                Command="{Binding ClearXeniaOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                    </Grid>
                    -->
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Visibility="{Binding ShowExophaseToggle, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Provider_Exophase}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_ExophaseHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <CheckBox Content="{DynamicResource LOCPlayAch_GameOptions_UseExophase}"
                              IsChecked="{Binding UseExophaseForGame}"
                              FontWeight="SemiBold"
                              Margin="0,10,0,0" />

                    <!-- Slug Override -->
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_ExophaseSlugLabel}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,12,0,0" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_ExophaseSlugHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="300" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding ExophaseSlugInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 ToolTip="{Binding ExophaseAutoSlug}">
                            <TextBox.Resources>
                                <VisualBrush x:Key="PlaceholderBrush"
                                             AlignmentX="Left"
                                             AlignmentY="Center"
                                             Stretch="None">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="{Binding ExophaseAutoSlug}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.4"
                                                   Padding="8,0,0,0" />
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </TextBox.Resources>
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExophaseSlugInput}" Value="">
                                            <Setter Property="Background" Value="{StaticResource PlaceholderBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_Button_Apply}"
                                Command="{Binding ApplyExophaseSlugOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                Command="{Binding ClearExophaseSlugOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock Text="{Binding ExophaseSlugOverrideValue, StringFormat='Current override: {0}'}"
                               Visibility="{Binding HasExophaseSlugOverride, Converter={StaticResource BoolToVis}}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
