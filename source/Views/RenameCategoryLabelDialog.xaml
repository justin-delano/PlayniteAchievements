<UserControl x:Class="PlayniteAchievements.Views.RenameCategoryLabelDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="220"
             d:DesignWidth="500"
             FocusManager.FocusedElement="{Binding ElementName=TargetLabelTextBox}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource LOCPlayAch_GameOptions_Category_RenameDialog_Hint}"
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{DynamicResource LOCPlayAch_GameOptions_Category_RenameDialog_SourceLabel}"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding LabelOptions}"
                      SelectedItem="{Binding SelectedSourceLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      MinHeight="30" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{DynamicResource LOCPlayAch_GameOptions_Category_RenameDialog_TargetLabel}"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="TargetLabelTextBox"
                     Grid.Column="1"
                     Text="{Binding TargetLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     MinHeight="30"
                     KeyDown="TargetLabelTextBox_KeyDown" />
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="{DynamicResource LOCPlayAch_Button_Ok}"
                    Click="OkButton_Click"
                    Padding="12,6"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    IsDefault="True" />
            <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                    Click="CancelButton_Click"
                    Padding="12,6"
                    MinWidth="80"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</UserControl>
