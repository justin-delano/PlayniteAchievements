<UserControl x:Class="PlayniteAchievements.Views.FriendsSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="720">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Themed like the achievement grids, but with a compact settings-row height and no
                 achievement-style hand cursor. -->
            <Style x:Key="FriendsSettingsGridRowStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource AchievementRowStyle}">
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsSettings_AutoDiscover}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsSettings_AutoDiscoverHint}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding AutoDiscoverProviders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsAvailable}"
                                          Margin="0,0,0,6"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="{DynamicResource LOCPlayAch_Settings_RefreshFriendsList}"
                            Command="{Binding RefreshAutoDiscoverCommand}"
                            HorizontalAlignment="Left"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsSettings_ManualAdd}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Provider_Exophase}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,12,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ManualExophaseUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 MinWidth="220"
                                 Margin="0,0,12,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Add}"
                                Command="{Binding AddManualFriendCommand}"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Friends}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_FriendsTableHint}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <DockPanel Margin="0,0,0,8">
                        <Button Content="{DynamicResource LOCPlayAch_FriendsSettings_MergeSelected}"
                                Command="{Binding MergeSelectedCommand}"
                                HorizontalAlignment="Left"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"/>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding Friends}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="False"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                              CellStyle="{StaticResource AchievementCellStyle}"
                              RowStyle="{StaticResource FriendsSettingsGridRowStyle}"
                              MinHeight="220"
                              MaxHeight="520"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header=""
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="Auto"
                                                    MinWidth="36"/>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Name}"
                                                    Width="Auto"
                                                    MinWidth="220"
                                                    MaxWidth="320">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="28"
                                                    Height="28"
                                                    CornerRadius="3"
                                                    Background="{DynamicResource PlayAch.Brush.ControlSurface}"
                                                    BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <Image helpers:AsyncImage.Uri="{Binding AvatarSource}"
                                                       helpers:AsyncImage.DecodePixel="48"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBox Text="{Binding Nickname, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         MinWidth="120"
                                                         Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Accounts}"
                                                    Width="Auto"
                                                    MinWidth="170"
                                                    MaxWidth="300">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Accounts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="20"
                                                                Height="20"
                                                                CornerRadius="3"
                                                                Background="{DynamicResource PlayAch.Brush.ControlSurface}"
                                                                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center">
                                                            <Image helpers:AsyncImage.Uri="{Binding AvatarSource}"
                                                                   helpers:AsyncImage.DecodePixel="32"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="4,0,0,0">
                                                            <TextBlock Text="{Binding ProviderDisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource MutedTextStyle}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Platform}"
                                                    Width="Auto"
                                                    MinWidth="130"
                                                    MaxWidth="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Accounts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2,0,4">
                                                        <Grid>
                                                            <ToggleButton x:Name="PlatformSelectorButton"
                                                                          Content="{Binding PlatformText}"
                                                                          IsEnabled="{Binding SupportsPlatformSelection}"
                                                                          HorizontalAlignment="Stretch"
                                                                          Padding="8,3"/>
                                                            <Popup PlacementTarget="{Binding ElementName=PlatformSelectorButton}"
                                                                   Placement="Bottom"
                                                                   StaysOpen="False"
                                                                   AllowsTransparency="True"
                                                                   IsOpen="{Binding IsChecked, ElementName=PlatformSelectorButton}">
                                                                <Border Background="{DynamicResource PlayAch.Brush.PopupSurface}"
                                                                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                                        BorderThickness="1"
                                                                        Padding="10"
                                                                        MinWidth="180">
                                                                    <ItemsControl ItemsSource="{Binding Platforms}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <CheckBox Content="{Binding Label}"
                                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                          IsEnabled="{Binding IsEnabled}"
                                                                                          Margin="0,0,0,6"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_FullLibrary}"
                                                    Width="Auto"
                                                    MinWidth="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Accounts}"
                                                      HorizontalAlignment="Center">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding UseFullLibrary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ToolTip="{Binding ProviderDisplayName}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="0,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Ignore}"
                                                    Width="Auto"
                                                    MinWidth="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Accounts}"
                                                      HorizontalAlignment="Center">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsIgnored, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ToolTip="{Binding ProviderDisplayName}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="0,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_FriendsSettings_AvatarSource}"
                                                    Width="Auto"
                                                    MinWidth="110"
                                                    MaxWidth="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding AvatarOptions}"
                                                  IsEnabled="{Binding CanChooseAvatar}"
                                                  SelectedValuePath="AccountKey"
                                                  SelectedValue="{Binding SelectedAvatarAccountKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Label"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Actions}"
                                                    Width="Auto"
                                                    MinWidth="84">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Button Content="{DynamicResource LOCPlayAch_FriendsSettings_Unmerge}"
                                                    Command="{Binding DataContext.UnmergeFriendCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding CanUnmerge}"
                                                    Padding="8,3"
                                                    Margin="0,0,0,4"/>

                                            <ItemsControl ItemsSource="{Binding Accounts}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{DynamicResource LOCPlayAch_Button_Remove}"
                                                                Command="{Binding DataContext.RemoveFriendCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                                CommandParameter="{Binding}"
                                                                IsEnabled="{Binding CanRemove}"
                                                                Padding="8,3"
                                                                Margin="0,0,0,4"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
