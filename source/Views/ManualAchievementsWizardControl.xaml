<UserControl x:Class="PlayniteAchievements.Views.ManualAchievementsWizardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ManualAchievementsWizardViewModel}"
             FocusManager.FocusedElement="{Binding ElementName=SearchTextBox}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BooleanConverter x:Key="InvertedBooleanConverter" Mode="Inverted"/>

            <!-- Cursor style for hidden achievements -->
            <Style x:Key="HiddenAchievementTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Opacity" Value="0.6"/>
                        <Setter Property="FontStyle" Value="Italic"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Checkbox style for DataGrid -->
            <Style x:Key="DataGridCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0"/>
            </Style>

            <!-- Centered column header style -->
            <Style x:Key="CenteredColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <!-- Clickable cell style for hidden achievements -->
            <Style x:Key="ClickableCellStyle" TargetType="Grid">
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Cell style that stretches content to fill cell for clickable areas -->
            <Style x:Key="StretchCellStyle" TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                        <Setter Property="Background" Value="#40FFFFFF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stage Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Foreground="{DynamicResource TextBrush}" Opacity="0.75">
                <Run Text="{DynamicResource LOCPlayAch_ManualAchievements_Wizard_GameLabel}"/>
                <Run Text="{Binding PlayniteGameName, Mode=OneTime}" FontWeight="Bold"/>
            </TextBlock>
        </StackPanel>

        <!-- Stage Content -->
        <Grid Grid.Row="1">
            <!-- Stage 1: Search -->
            <Grid Visibility="{Binding DataContext.IsSearchStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource LOCPlayAch_ManualAchievements_Search_Header}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Game name hint -->
                <TextBlock Grid.Row="1"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12">
                    <Run Text="{DynamicResource LOCPlayAch_ManualAchievements_Search_GameLabel}"/>
                    <Run Text="{Binding PlayniteGameName, Mode=OneTime}" FontWeight="Bold"/>
                </TextBlock>

                <!-- Search bar -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             KeyDown="SearchTextBox_KeyDown"/>

                    <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Search}"
                            Command="{Binding SearchCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="8,0,0,0"/>
                </Grid>

                <!-- Results grid -->
                <Border Grid.Row="3"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              MouseDoubleClick="SearchDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding IconUrl}"
                                               Width="32" Height="32"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Search_Column_Name}"
                                                Binding="{Binding Name}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Search_Column_AppId}"
                                                Binding="{Binding SourceGameId}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="4"
                           Text="{Binding SearchStatusMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
            </Grid>

            <!-- Stage 2: Refreshing -->
            <Grid Visibility="{Binding DataContext.IsRefreshingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ProgressMessage}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>

                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             Maximum="100"
                             Width="350" Height="24"
                             HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding ProgressPercent, StringFormat={}{0:F0}%, Mode=OneWay}"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                <Button Grid.Row="3"
                        Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Command="{Binding CancelRefreshCommand}"
                        IsEnabled="{Binding CanCancelRefresh}"
                        Padding="12,6"
                        MinWidth="80"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0"/>
            </Grid>

            <!-- Stage 3: Editing -->
            <Grid Visibility="{Binding DataContext.IsEditingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Header}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Game info -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Foreground="{DynamicResource TextBrush}" Opacity="0.75">
                        <Run Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_LinkedInfo}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding SourceGameName, Mode=OneWay}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="4,0,0,0"/>
                    <TextBlock Text="("
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"
                               Margin="4,0,0,0"/>
                    <TextBlock Text="{Binding SourceGameId, Mode=OneWay}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"/>
                    <TextBlock Text=")"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- Progress and action bar -->
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Progress stats -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource TextBrush}" Opacity="0.75">
                            <Run Text="{Binding UnlockedCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                            <Run Text="("/>
                            <Run Text="{Binding CompletionPercent, StringFormat={}{0:F1}, Mode=OneWay}"/>
                            <Run Text="%)"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Search filter -->
                    <TextBox Grid.Column="1"
                             Text="{Binding EditSearchFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             Padding="8,4"
                             VerticalContentAlignment="Center"
                             Width="200"
                             HorizontalAlignment="Center"
                             MinWidth="120">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Resources>
                                    <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_SearchPlaceholder}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Opacity="0.4"
                                                       IsHitTestVisible="False"
                                                       Padding="8,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditSearchFilter}" Value="">
                                        <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EditSearchFilter}" Value="{x:Null}">
                                        <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource LOCPlayAch_ManualAchievements_Edit_UnlockAll}"
                                Command="{Binding UnlockAllCommand}"
                                Padding="8,4"
                                Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource LOCPlayAch_ManualAchievements_Edit_LockAll}"
                                Command="{Binding LockAllCommand}"
                                Padding="8,4"/>
                    </StackPanel>
                </Grid>

                <!-- Achievements grid -->
                <Border Grid.Row="3"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,12">
                    <DataGrid ItemsSource="{Binding FilteredAchievements}"
                              RowStyle="{StaticResource AchievementRowStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <!-- Icon -->
                            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True" SortMemberPath="IsUnlocked"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource StretchCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <Border Width="32" Height="32" CornerRadius="4"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    RenderOptions.BitmapScalingMode="LowQuality">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Background>
                                                    <ImageBrush Stretch="UniformToFill"
                                                                helpers:AsyncImage.Uri="{Binding DisplayIconUrl}"
                                                                helpers:AsyncImage.DecodePixel="64"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Name -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Name}"
                                                    Width="*"
                                                    IsReadOnly="True"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource StretchCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <TextBlock Text="{Binding DisplayNameResolved, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Style="{StaticResource HiddenAchievementTextStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Description -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Description}"
                                                    Width="2*"
                                                    IsReadOnly="True"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource StretchCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <TextBlock Text="{Binding DescriptionResolved, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource HiddenAchievementTextStyle}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlocked checkbox -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Unlocked}"
                                                    Width="70"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUnlocked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource DataGridCheckBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUnlocked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource DataGridCheckBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlock date -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Date}"
                                                    Width="120"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="—" Opacity="0.5"
                                                       Visibility="{Binding IsUnlocked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                            <DatePicker SelectedDate="{Binding UnlockDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                        Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Padding="4,2"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlock time -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Column_Time}"
                                                    Width="140"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="—" Opacity="0.5"
                                                       Visibility="{Binding IsUnlocked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding IsUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBox Text="{Binding HourText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         Width="32"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Padding="2,0"
                                                         MaxLength="2">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValidHour}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                                                <TextBox Text="{Binding MinuteText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         Width="32"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Padding="2,0"
                                                         MaxLength="2">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValidMinute}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <ComboBox ItemsSource="{Binding AvailableTimeModes}"
                                                          SelectedItem="{Binding SelectedTimeMode, Mode=TwoWay}"
                                                          Width="50"
                                                          VerticalContentAlignment="Center"
                                                          Padding="4,0"
                                                          Margin="2,0,0,0">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Rarity -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Rarity}"
                                                    Width="70"
                                                    IsReadOnly="True"
                                                    SortMemberPath="GlobalPercentUnlocked"
                                                    HeaderStyle="{StaticResource CenteredColumnHeaderStyle}"
                                                    CellStyle="{StaticResource AchievementCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding GlobalPercentUnlocked, StringFormat={}{0:F1}%}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRarity}" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                            <Setter Property="Text" Value="--"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Error state -->
            <StackPanel Visibility="{Binding DataContext.HasError,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{DynamicResource LOCPlayAch_Button_Retry}"
                            Command="{Binding RetryCommand}"
                            Padding="12,6"
                            MinWidth="80"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="12,6"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <!-- Search stage buttons -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding DataContext.IsSearchStage,
                            RelativeSource={RelativeSource AncestorType=UserControl},
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="{DynamicResource LOCPlayAch_Button_Next}"
                        Click="NextButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Click="CancelButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        IsCancel="True"/>
            </StackPanel>

            <!-- Editing stage buttons -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding DataContext.IsEditingStage,
                            RelativeSource={RelativeSource AncestorType=UserControl},
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Content="{DynamicResource LOCPlayAch_Button_Save}"
                        Click="SaveButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        IsDefault="True"/>
                <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Click="CancelButton_Click"
                        Padding="12,6"
                        MinWidth="80"
                        IsCancel="True"/>
            </StackPanel>
        </StackPanel>
