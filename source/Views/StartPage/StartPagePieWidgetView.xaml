<UserControl x:Class="PlayniteAchievements.Views.StartPage.StartPagePieWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="4,0,4,4"
                   Opacity="0.78"/>

        <controls:PieChartWithRadialIcons Grid.Row="1"
                                          PieSeries="{Binding Chart.PieSeries}"
                                          LegendItems="{Binding Chart.LegendItems}"
                                          HighlightedLabels="{Binding Chart.HighlightedLabels}"
                                          ExactUnlockedCount="{Binding Chart.ExactUnlockedCount}"
                                          ExactTotalCount="{Binding Chart.ExactTotalCount}"
                                          ShowCenterPercentage="{Binding ShowCenterPercentage}"
                                          IconOffset="12"/>
    </Grid>
</UserControl>
