<UserControl x:Class="PlayniteAchievements.Views.StartPage.StartPageGamesOverviewGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility"/>
            <converters:BooleanConverter x:Key="InverseBoolToVis" Mode="InvertedToVisibility"/>
            <converters:IntToVisibilityConverter x:Key="IntToVis"/>
            <converters:ProviderIconConverter x:Key="ProviderIconConverter"/>

            <Style x:Key="StartPageGameImageBorderStyle" TargetType="Border">
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="48"/>
                <Setter Property="Margin" Value="6,5"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="ClipToBounds" Value="True"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <ImageBrush Stretch="Uniform"
                                    helpers:AsyncImage.Uri="{Binding GameLogo, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"
                                    helpers:AsyncImage.DecodePixel="96"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.UseCoverImages, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Width" Value="40"/>
                        <Setter Property="Height" Value="60"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <ImageBrush Stretch="UniformToFill"
                                            helpers:AsyncImage.Uri="{Binding GameCoverPath, Converter={StaticResource DefaultGameImage}, ConverterParameter=cover}"
                                            helpers:AsyncImage.DecodePixel="128"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StartPageOverviewProgressContainerStyle" TargetType="Grid">
                <Setter Property="Margin" Value="8,5"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="StartPageOverviewProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource GameProgressBar}">
                <Setter Property="Height" Value="20"/>
            </Style>

            <Style x:Key="StartPageOverviewProgressPercentTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
            </Style>

            <Style x:Key="StartPageOverviewProgressFooterStyle" TargetType="Grid">
                <Setter Property="VerticalAlignment" Value="Bottom"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="StartPageOverviewProgressMetaRowStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="StartPageOverviewMiniBadgeItemStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="3,0"/>
            </Style>

            <Style x:Key="StartPageOverviewMiniBadgeImageStyle" TargetType="Image" BasedOn="{StaticResource RarityIcon}">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Effect" Value="{StaticResource BadgeShadow}"/>
            </Style>

            <Style x:Key="StartPageOverviewMiniBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Margin" Value="2,0,0,0"/>
            </Style>

            <Style x:Key="StartPageOverviewCompletedFooterIconStyle" TargetType="Image" BasedOn="{StaticResource StartPageOverviewMiniBadgeImageStyle}">
                <Setter Property="Margin" Value="0,0,5,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="4">
        <DataGrid x:Name="GamesOverviewDataGrid"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="None"
                  RowBackground="Transparent"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource NormalBorderBrush}"
                  Background="Transparent"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="True"
                  EnableRowVirtualization="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ColumnHeaderStyle="{StaticResource AchievementColumnHeaderWithMenuStyle}"
                  PreviewMouseRightButtonUp="DataGridColumnMenu_PreviewMouseRightButtonUp">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="GridRow_PreviewMouseRightButtonDown"/>
                    <EventSetter Event="PreviewMouseRightButtonUp" Handler="GridRow_PreviewMouseRightButtonUp"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header=""
                                        Width="58"
                                        MinWidth="58"
                                        MaxWidth="58"
                                        CanUserResize="False"
                                        CanUserSort="False"
                                        helpers:ColumnVisibilityHelper.ColumnKey="Cover">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Border Style="{StaticResource StartPageGameImageBorderStyle}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Game}"
                                        Width="2*"
                                        MinWidth="180"
                                        SortMemberPath="SortingName"
                                        helpers:ColumnVisibilityHelper.ColumnKey="OverviewGameName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,4">
                                <TextBlock Text="{Binding GameName}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SecondaryMetadataText}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextBrush}"
                                           Opacity="0.62"
                                           FontSize="{DynamicResource FontSizeSmall}"
                                           Visibility="{Binding DataContext.ShowGameMetadata, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Progress}"
                                        Width="180"
                                        MinWidth="150"
                                        SortMemberPath="Progression"
                                        helpers:ColumnVisibilityHelper.ColumnKey="OverviewProgression">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Style="{StaticResource StartPageOverviewProgressContainerStyle}">
                                <Grid VerticalAlignment="Center">
                                    <ProgressBar Value="{Binding Progression, Mode=OneWay}"
                                                 Style="{StaticResource StartPageOverviewProgressBarStyle}"/>
                                    <TextBlock Text="{Binding ProgressionText}"
                                               Style="{StaticResource StartPageOverviewProgressPercentTextStyle}"/>
                                </Grid>

                                <Grid Style="{StaticResource StartPageOverviewProgressFooterStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0"
                                           Source="{StaticResource BadgeCompletedGame}"
                                           Style="{StaticResource StartPageOverviewCompletedFooterIconStyle}"
                                           ToolTip="{DynamicResource LOCPlayAch_Completed}"
                                           Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>

                                    <StackPanel Grid.Column="1"
                                                Style="{StaticResource StartPageOverviewProgressMetaRowStyle}"
                                                Visibility="{Binding HasTrophyTypes, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding UltraRareCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Ultra Rare">
                                            <Image Source="{DynamicResource BadgeRarityUltraRare}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding UltraRareCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding RareCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Rare">
                                            <Image Source="{DynamicResource BadgeRarityRare}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding RareCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding UncommonCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Uncommon">
                                            <Image Source="{DynamicResource BadgeRarityUncommon}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding UncommonCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding CommonCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Common">
                                            <Image Source="{DynamicResource BadgeRarityCommon}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding CommonCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Style="{StaticResource StartPageOverviewProgressMetaRowStyle}"
                                                Visibility="{Binding HasTrophyTypes, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding TrophyPlatinumCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Platinum">
                                            <Image Source="{StaticResource TrophyPlatinum}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding TrophyPlatinumCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding TrophyGoldCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Gold">
                                            <Image Source="{StaticResource TrophyGold}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding TrophyGoldCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding TrophySilverCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Silver">
                                            <Image Source="{StaticResource TrophySilver}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding TrophySilverCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                        <StackPanel Style="{StaticResource StartPageOverviewMiniBadgeItemStyle}"
                                                    Visibility="{Binding TrophyBronzeCount, Converter={StaticResource IntToVis}}"
                                                    ToolTip="Bronze">
                                            <Image Source="{StaticResource TrophyBronze}"
                                                   Style="{StaticResource StartPageOverviewMiniBadgeImageStyle}"/>
                                            <TextBlock Text="{Binding TrophyBronzeCount}"
                                                       Style="{StaticResource StartPageOverviewMiniBadgeTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Common_Unlocked}"
                                    Binding="{Binding UnlockedAchievements}"
                                    Width="92"
                                    MinWidth="80"
                                    SortMemberPath="UnlockedAchievements"
                                    helpers:ColumnVisibilityHelper.ColumnKey="UnlockedAchievements"/>
                <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_Total}"
                                    Binding="{Binding TotalAchievements}"
                                    Width="72"
                                    MinWidth="62"
                                    SortMemberPath="TotalAchievements"
                                    helpers:ColumnVisibilityHelper.ColumnKey="TotalAchievements"/>
                <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Common_LastUnlock}"
                                    Binding="{Binding LastUnlockUtc, StringFormat={}{0:g}}"
                                    Width="145"
                                    MinWidth="120"
                                    SortMemberPath="LastUnlockUtc"
                                    helpers:ColumnVisibilityHelper.ColumnKey="LastUnlock"/>
                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_GameOptions_Overview_Provider}"
                                        Width="72"
                                        MinWidth="60"
                                        SortMemberPath="Provider"
                                        helpers:ColumnVisibilityHelper.ColumnKey="OverviewProvider">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Image Width="18"
                                       Height="18"
                                       Margin="0,0,5,0"
                                       ToolTip="{Binding Provider}"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                            <Binding Path="ProviderIconKey"/>
                                            <Binding Path="ProviderColorHex"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{Binding Provider}"
                                           Foreground="{DynamicResource TextBrush}"
                                           Opacity="0.72"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="96"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_CollectionScore}"
                                    Binding="{Binding CollectionScore}"
                                    Width="116"
                                    MinWidth="96"
                                    SortMemberPath="CollectionScore"
                                    helpers:ColumnVisibilityHelper.ColumnKey="OverviewCollectionScore"/>
                <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_PrestigeScore}"
                                    Binding="{Binding PrestigeScore}"
                                    Width="110"
                                    MinWidth="92"
                                    SortMemberPath="PrestigeScore"
                                    helpers:ColumnVisibilityHelper.ColumnKey="OverviewPrestigeScore"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
