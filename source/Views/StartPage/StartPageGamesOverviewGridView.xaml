<UserControl x:Class="PlayniteAchievements.Views.StartPage.StartPageGamesOverviewGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Unloaded="OnUnloaded">
    <Grid Margin="4">
        <controls:GamesOverviewDataGridControl x:Name="GamesOverviewGrid"
                                               ItemsSource="{Binding Items}"
                                               UseCoverImages="{Binding UseCoverImages}"
                                               EnableCompactGridMode="{Binding EnableCompactGridMode}"
                                               ShowGameMetadata="{Binding ShowGameMetadata}"
                                               ShowCompletionBorder="{Binding ShowCompletionBorder}"
                                               ShowColumnHeaders="{Binding ShowColumnHeaders}"
                                               ColumnSettingsKey="StartPageOverview"
                                               RowPreviewMouseRightButtonDown="GridRow_PreviewMouseRightButtonDown"
                                               RowPreviewMouseRightButtonUp="GridRow_PreviewMouseRightButtonUp"/>
    </Grid>
</UserControl>
