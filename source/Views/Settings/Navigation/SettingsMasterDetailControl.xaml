<UserControl x:Class="PlayniteAchievements.Views.Settings.Navigation.SettingsMasterDetailControl"
             x:Name="MasterDetailRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PlayAch.Brush.Panel}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="190" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                BorderThickness="0,0,1,0"
                Background="{DynamicResource PlayAch.Brush.Surface}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="10,10,10,8"
                        Visibility="{Binding ShowSearch, ElementName=MasterDetailRoot, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Opacity="{StaticResource PlayAch.Opacity.Disabled}"
                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 Height="24"
                                 Padding="6,2"
                                 Text="{Binding SearchText, ElementName=MasterDetailRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 ToolTip="{DynamicResource LOCPlayAch_Button_Search}"/>
                    </Grid>
                </Border>

                <ListBox ItemsSource="{Binding ItemsSource, ElementName=MasterDetailRoot}"
                         SelectedItem="{Binding SelectedItem, ElementName=MasterDetailRoot, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource ProviderNavigationItemContainerStyle}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="{StaticResource PlayAch.Thickness.None}">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Opacity="0.58"
                                               Margin="10,10,8,3"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Name}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,3"
                                  MinHeight="{StaticResource PlayAch.Size.Control.Height}">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.55"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Width="18"
                                       Height="18"
                                       Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasProviderIcon, Converter={StaticResource BoolToVis}}">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                            <Binding Path="ProviderIconKey"/>
                                            <Binding Path="ProviderColorHex"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>

                                <TextBlock Text="{Binding IconGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasIconGlyph, Converter={StaticResource BoolToVis}}"/>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding Subtitle}">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                               Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasSubtitle, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding SelectedItem.View, ElementName=MasterDetailRoot}"/>
    </Grid>
</UserControl>
