<UserControl x:Class="PlayniteAchievements.Views.Settings.General.HotkeySettingsSection"
             x:Name="HotkeySettingsSectionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- ================== HOTKEYS ================== -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_Title}"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_Description}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"/>

                    <CheckBox Content="{DynamicResource LOCPlayAch_Hotkeys_Enable}"
                              IsChecked="{Binding Persisted.EnableAchievementHotkeys}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                    <CheckBox Content="{DynamicResource LOCPlayAch_Hotkeys_EnableGlobal}"
                              IsChecked="{Binding Persisted.EnableGlobalAchievementHotkeys}"
                              IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                              Margin="18,0,0,8"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_GlobalHelp}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="18,0,0,14"
                               TextWrapping="Wrap"/>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Menu_ViewAchievements}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="ViewAchievementsHotkeyCaptureButton"
                                Grid.Column="1"
                                Content="{Binding ViewAchievementsHotkeyButtonText, ElementName=HotkeySettingsSectionRoot}"
                                Click="HotkeyCapture_Click"
                                CommandParameter="ViewAchievements"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                Margin="12,0,8,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                Click="ResetHotkey_Click"
                                CommandParameter="ViewAchievements"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Menu_ManageAchievements}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="ManageAchievementsHotkeyCaptureButton"
                                Grid.Column="1"
                                Content="{Binding ManageAchievementsHotkeyButtonText, ElementName=HotkeySettingsSectionRoot}"
                                Click="HotkeyCapture_Click"
                                CommandParameter="ManageAchievements"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                Margin="12,0,8,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                Click="ResetHotkey_Click"
                                CommandParameter="ManageAchievements"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Menu_OpenOverview}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="OverviewHotkeyCaptureButton"
                                Grid.Column="1"
                                Content="{Binding OverviewHotkeyButtonText, ElementName=HotkeySettingsSectionRoot}"
                                Click="HotkeyCapture_Click"
                                CommandParameter="Overview"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                Margin="12,0,8,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                Click="ResetHotkey_Click"
                                CommandParameter="Overview"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_OpenSettings}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="OpenSettingsHotkeyCaptureButton"
                                Grid.Column="1"
                                Content="{Binding OpenSettingsHotkeyButtonText, ElementName=HotkeySettingsSectionRoot}"
                                Click="HotkeyCapture_Click"
                                CommandParameter="OpenSettings"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                Margin="12,0,8,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                Click="ResetHotkey_Click"
                                CommandParameter="OpenSettings"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LOCPlayAch_CategorySummaries_ToggleToolTip}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button x:Name="CategoryModeHotkeyCaptureButton"
                                Grid.Column="1"
                                Content="{Binding CategoryModeHotkeyButtonText, ElementName=HotkeySettingsSectionRoot}"
                                Click="HotkeyCapture_Click"
                                CommandParameter="CategoryMode"
                                PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                Margin="12,0,8,0"/>

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                Click="ResetHotkey_Click"
                                CommandParameter="CategoryMode"
                                IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_CategoryModeHelp}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding HotkeyCaptureStatusText, ElementName=HotkeySettingsSectionRoot}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
