<UserControl x:Class="PlayniteAchievements.Views.Settings.General.NotificationsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:PlayniteAchievements.Models.Settings"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Captures this section's DataContext (the settings view model) so DataGrid columns
                 inside the provider-overrides grid (a DataContext island, and columns are not in
                 the visual tree) can bind back to persisted settings. -->
            <helpers:BindingProxy x:Key="NotificationsSectionContext" Data="{Binding}"/>

            <!-- Themed like the achievement grids, but with a compact settings-row height and no
                 achievement-style hand cursor (mirrors FriendsSettingsGridRowStyle). -->
            <Style x:Key="ProviderOverridesGridRowStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource AchievementRowStyle}">
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource PlayAch.Brush.Panel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">
                <!-- General notifications -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Section_Notifications}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableNotifications}"
                                  IsChecked="{Binding Persisted.EnableNotifications}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_NotifyPeriodicUpdates}"
                                  IsChecked="{Binding Persisted.NotifyPeriodicUpdates}"
                                  Margin="18,0,0,10"
                                  IsEnabled="{Binding Persisted.EnableNotifications}"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_NotifyOnRebuild}"
                                  IsChecked="{Binding Persisted.NotifyOnRebuild}"
                                  Margin="18,0,0,10"
                                  IsEnabled="{Binding Persisted.EnableNotifications}"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableUnlockToasts}"
                                  IsChecked="{Binding Persisted.EnableUnlockToasts}"
                                  Margin="18,0,0,10"
                                  IsEnabled="{Binding Persisted.EnableNotifications}"/>
                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableFriendUnlockToasts}"
                                  IsChecked="{Binding Persisted.EnableFriendUnlockToasts}"
                                  Margin="18,0,0,0"
                                  IsEnabled="{Binding Persisted.EnableNotifications}"
                                  Visibility="{Binding Persisted.EnableFriendsFeatures, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- Behavior -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel IsEnabled="{Binding Persisted.EnableNotifications}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ToastBehavior}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{DynamicResource LOCPlayAch_Settings_ToastDurationSeconds}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding Persisted.ToastDurationSeconds, UpdateSourceTrigger=LostFocus}"
                                     Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                     TextAlignment="Right"
                                     Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{DynamicResource LOCPlayAch_Settings_MaxConcurrentToasts}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding Persisted.MaxConcurrentToasts, UpdateSourceTrigger=LostFocus}"
                                     Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                     TextAlignment="Right"
                                     Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{DynamicResource LOCPlayAch_Settings_ToastPosition}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      SelectedValue="{Binding Persisted.ToastPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag"
                                      MinWidth="140">
                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_BottomRight}" Tag="{x:Static settings:ToastScreenCorner.BottomRight}"/>
                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_BottomLeft}" Tag="{x:Static settings:ToastScreenCorner.BottomLeft}"/>
                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_TopRight}" Tag="{x:Static settings:ToastScreenCorner.TopRight}"/>
                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_TopLeft}" Tag="{x:Static settings:ToastScreenCorner.TopLeft}"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Screenshots -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotsHeader}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableUnlockScreenshots}"
                                  IsChecked="{Binding Persisted.EnableUnlockScreenshots}"
                                  Margin="0,0,0,10"/>

                        <StackPanel Margin="18,0,0,0"
                                    IsEnabled="{Binding Persisted.EnableUnlockScreenshots}">
                            <WrapPanel Margin="0,0,0,6">
                                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantClean}"
                                          IsChecked="{Binding Persisted.UnlockScreenshotClean}"
                                          Margin="0,0,14,8"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantWithToast}"
                                          IsChecked="{Binding Persisted.UnlockScreenshotWithToast}"
                                          Margin="0,0,14,8"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantFramed}"
                                          IsChecked="{Binding Persisted.UnlockScreenshotFramed}"
                                          Margin="0,0,14,8"/>
                            </WrapPanel>

                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotDirectory}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Persisted.UnlockScreenshotDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                        Click="ScreenshotDirectory_Browse_Click"
                                        Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotDirectoryHint}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Unlock recordings: rolling ffmpeg screen capture + per-unlock clip export.
                     ffmpeg is user-supplied (path + Test button); the plugin never downloads it. -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingsHeader}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableUnlockRecordings}"
                                  IsChecked="{Binding Persisted.EnableUnlockRecordings}"
                                  Margin="0,0,0,10"/>

                        <StackPanel Margin="18,0,0,0"
                                    IsEnabled="{Binding Persisted.EnableUnlockRecordings}">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingFfmpegPath}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Persisted.FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                        Click="FfmpegPath_Browse_Click"
                                        Margin="8,0,0,0"/>
                                <Button x:Name="FfmpegTestButton"
                                        Grid.Column="2"
                                        Content="{DynamicResource LOCPlayAch_Button_Test}"
                                        Click="FfmpegTest_Click"
                                        Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock x:Name="FfmpegStatusText"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       Margin="0,6,0,0"/>

                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingDirectory}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="0,10,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Persisted.UnlockRecordingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                        Click="RecordingDirectory_Browse_Click"
                                        Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingDirectoryHint}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{DynamicResource LOCPlayAch_Settings_RecordingClipSeconds}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding Persisted.RecordingClipSeconds, UpdateSourceTrigger=LostFocus}"
                                         Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                         TextAlignment="Right"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{DynamicResource LOCPlayAch_Settings_RecordingFps}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding Persisted.RecordingFps, UpdateSourceTrigger=LostFocus}"
                                         Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                         TextAlignment="Right"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{DynamicResource LOCPlayAch_Settings_RecordingResolution}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          SelectedValue="{Binding Persisted.RecordingResolution, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RecordingResolutionNative}" Tag="{x:Static settings:RecordingResolution.Native}"/>
                                    <ComboBoxItem Content="1080p" Tag="{x:Static settings:RecordingResolution.P1080}"/>
                                    <ComboBoxItem Content="720p" Tag="{x:Static settings:RecordingResolution.P720}"/>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="{DynamicResource LOCPlayAch_Settings_RecordingEncoder}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          SelectedValue="{Binding Persisted.RecordingEncoder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RecordingAuto}" Tag="{x:Static settings:RecordingEncoder.Auto}"/>
                                    <ComboBoxItem Content="x264 (CPU)" Tag="{x:Static settings:RecordingEncoder.X264}"/>
                                    <ComboBoxItem Content="NVENC (NVIDIA)" Tag="{x:Static settings:RecordingEncoder.Nvenc}"/>
                                    <ComboBoxItem Content="Quick Sync (Intel)" Tag="{x:Static settings:RecordingEncoder.Qsv}"/>
                                    <ComboBoxItem Content="AMF (AMD)" Tag="{x:Static settings:RecordingEncoder.Amf}"/>
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="{DynamicResource LOCPlayAch_Settings_RecordingCaptureBackend}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox Grid.Row="4" Grid.Column="1"
                                          SelectedValue="{Binding Persisted.RecordingCaptureBackend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_RecordingAuto}" Tag="{x:Static settings:RecordingCaptureBackend.Auto}"/>
                                    <ComboBoxItem Content="GDI (gdigrab)" Tag="{x:Static settings:RecordingCaptureBackend.Gdigrab}"/>
                                    <ComboBoxItem Content="DirectX (ddagrab)" Tag="{x:Static settings:RecordingCaptureBackend.Ddagrab}"/>
                                </ComboBox>
                            </Grid>

                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_RecordingIncludeAudio}"
                                      IsChecked="{Binding Persisted.RecordingIncludeAudio}"
                                      Margin="0,10,0,0"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingIncludeAudioHint}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecordingHint}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Live mockup + appearance toggles (adjacent so the mockup reflects each toggle
                     without scrolling) + example toast buttons -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_NotesDialog_Preview}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10">
                            <ContentControl x:Name="ToastMockupHost"
                                            ContentTemplate="{DynamicResource PlayAch.Template.AchievementToast}"/>
                        </Border>

                        <WrapPanel Margin="0,0,0,4">
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowHeader}"
                                      IsChecked="{Binding Persisted.ToastShowHeader}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowName}"
                                      IsChecked="{Binding Persisted.ToastShowName}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowDescription}"
                                      IsChecked="{Binding Persisted.ToastShowDescription}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowGameName}"
                                      IsChecked="{Binding Persisted.ToastShowGameName}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Category}"
                                      IsChecked="{Binding Persisted.ToastShowCategory}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityBadge}"
                                      IsChecked="{Binding Persisted.ToastShowRarityBadge}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityPercent}"
                                      IsChecked="{Binding Persisted.ToastShowRarityPercent}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityGlow}"
                                      IsChecked="{Binding Persisted.ToastShowRarityGlow}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastRarityColoredName}"
                                      IsChecked="{Binding Persisted.ToastRarityColoredName}"
                                      Margin="0,0,14,8"/>
                        </WrapPanel>

                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ToastPreviewHint}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Button x:Name="ToastPreviewCommonButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="common"
                                    Content="{DynamicResource LOCPlayAch_Rarity_Common}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="ToastPreviewUncommonButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="uncommon"
                                    Content="{DynamicResource LOCPlayAch_Rarity_Uncommon}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="ToastPreviewRareButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="rare"
                                    Content="{DynamicResource LOCPlayAch_Rarity_Rare}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="ToastPreviewUltraRareButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="ultrarare"
                                    Content="{DynamicResource LOCPlayAch_Rarity_UltraRare}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="ToastPreviewCapstoneButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="capstone"
                                    Content="{DynamicResource LOCPlayAch_Completed}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="ToastPreviewFriendButton"
                                    Click="ToastPreviewButton_Click"
                                    CommandParameter="friend"
                                    Content="{DynamicResource LOCPlayAch_Settings_ToastPreviewFriend}"
                                    Margin="0,0,8,8"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Screenshot frame preview + appearance: the 16:9 grid stands in for the
                     screenshot; the frame template lays out on the same 1080-DIP virtual canvas
                     the compositor uses, scaled down uniformly. -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_FrameHeader}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8">
                            <Viewbox Stretch="Uniform"
                                     MaxWidth="480">
                                <Grid Width="1920"
                                      Height="1080"
                                      Background="#FF17222D">
                                    <ContentControl x:Name="FrameMockupHost"/>
                                </Grid>
                            </Viewbox>
                        </Border>

                        <!-- Frame appearance: independent of the toast's ToastShow*
                             toggles; drives the FrameShow* bindings in the frame template.
                             Labels reuse the generic toast-toggle keys. -->
                        <WrapPanel Margin="0,0,0,4">
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowHeader}"
                                      IsChecked="{Binding Persisted.FrameShowHeader}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowName}"
                                      IsChecked="{Binding Persisted.FrameShowName}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowDescription}"
                                      IsChecked="{Binding Persisted.FrameShowDescription}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowGameName}"
                                      IsChecked="{Binding Persisted.FrameShowGameName}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Category}"
                                      IsChecked="{Binding Persisted.FrameShowCategory}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityBadge}"
                                      IsChecked="{Binding Persisted.FrameShowRarityBadge}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityPercent}"
                                      IsChecked="{Binding Persisted.FrameShowRarityPercent}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityGlow}"
                                      IsChecked="{Binding Persisted.FrameShowRarityGlow}"
                                      Margin="0,0,14,8"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastRarityColoredName}"
                                      IsChecked="{Binding Persisted.FrameRarityColoredName}"
                                      Margin="0,0,14,8"/>
                        </WrapPanel>

                        <WrapPanel>
                            <Button x:Name="FramePreviewButton"
                                    Click="FramePreviewButton_Click"
                                    Content="{DynamicResource LOCPlayAch_Settings_FramePreviewButton}"
                                    Margin="0,0,8,0"/>
                        </WrapPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_FramePreviewHint}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Per-platform overrides: tri-state cells (Default / On / Off) modulating the
                     global toggles above per provider. The grid stays enabled when notifications
                     are off because it edits defaults for when they are on; the master switches
                     always win. DataContext is the provider-overrides view model (set in
                     code-behind), independent of this section's settings DataContext. -->
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderNotificationOverrides}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                        <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ProviderNotificationOverridesHint}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <DataGrid x:Name="ProviderOverridesGrid"
                                  ItemsSource="{Binding Rows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="False"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                                  RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                                  CellStyle="{StaticResource AchievementCellStyle}"
                                  RowStyle="{StaticResource ProviderOverridesGridRowStyle}"
                                  MaxHeight="420"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                                        Width="*"
                                                        MinWidth="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="4,2">
                                                <Image Width="16"
                                                       Height="16"
                                                       Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding HasProviderIcon, Converter={StaticResource BoolToVis}}">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                                            <Binding Path="ProviderIconKey"/>
                                                            <Binding Path="ProviderColorHex"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_UnlockToasts}"
                                                        Width="Auto"
                                                        MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedValue="{Binding UnlockToasts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Tag"
                                                      MinWidth="86"
                                                      VerticalAlignment="Center"
                                                      Margin="4,2">
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_FriendToasts}"
                                                        Width="Auto"
                                                        MinWidth="100"
                                                        Visibility="{Binding Data.Persisted.EnableFriendsFeatures, Source={StaticResource NotificationsSectionContext}, Converter={StaticResource BoolToVis}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedValue="{Binding FriendUnlockToasts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Tag"
                                                      MinWidth="86"
                                                      VerticalAlignment="Center"
                                                      Margin="4,2">
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Screenshots}"
                                                        Width="Auto"
                                                        MinWidth="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center"
                                                  Margin="4,2">
                                                <ToggleButton x:Name="ScreenshotOverridesButton"
                                                              Content="{Binding ScreenshotsSummaryText}"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center"
                                                              MinWidth="86"
                                                              Padding="8,3"/>
                                                <Popup PlacementTarget="{Binding ElementName=ScreenshotOverridesButton}"
                                                       Placement="Bottom"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True"
                                                       IsOpen="{Binding IsChecked, ElementName=ScreenshotOverridesButton}">
                                                    <Border Background="{DynamicResource PlayAch.Brush.PopupSurface}"
                                                            BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                            BorderThickness="1"
                                                            Padding="10"
                                                            MinWidth="220">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                       Text="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantClean}"
                                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,10,6"/>
                                                            <ComboBox Grid.Row="0" Grid.Column="1"
                                                                      SelectedValue="{Binding ScreenshotClean, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectedValuePath="Tag"
                                                                      MinWidth="86"
                                                                      Margin="0,0,0,6">
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                                            </ComboBox>

                                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                                       Text="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantWithToast}"
                                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,10,6"/>
                                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                                      SelectedValue="{Binding ScreenshotWithToast, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectedValuePath="Tag"
                                                                      MinWidth="86"
                                                                      Margin="0,0,0,6">
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                                            </ComboBox>

                                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                                       Text="{DynamicResource LOCPlayAch_Settings_ScreenshotVariantFramed}"
                                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,10,0"/>
                                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                                      SelectedValue="{Binding ScreenshotFramed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectedValuePath="Tag"
                                                                      MinWidth="86">
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                                            </ComboBox>
                                                        </Grid>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Recordings}"
                                                        Width="Auto"
                                                        MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedValue="{Binding Recordings, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Tag"
                                                      MinWidth="86"
                                                      VerticalAlignment="Center"
                                                      Margin="4,2">
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static vm:OverrideState.Inherit}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_On}" Tag="{x:Static vm:OverrideState.On}"/>
                                                <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_Override_Off}" Tag="{x:Static vm:OverrideState.Off}"/>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
