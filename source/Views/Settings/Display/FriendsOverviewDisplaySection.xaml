<UserControl x:Class="PlayniteAchievements.Views.Settings.Display.FriendsOverviewDisplaySection"
             x:Name="FriendsOverviewDisplaySectionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:PlayniteAchievements.Models.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}"
                    Background="{DynamicResource PlayAch.Brush.Panel}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Display_FriendsOverviewSection}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_FriendSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGameSummariesGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewFriendSummariesGridColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewFriendSummariesGridControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_DateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.FriendsOverviewFriendSummariesLastUnlockDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewFriendSummariesGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewFriendSummariesGridMaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_GameSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_UseCoverImages}"
                                      IsChecked="{Binding Persisted.FriendsOverviewGameSummariesUseCoverImages}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GameMetadataHeader}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Margin="16,0,0,0">
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                          IsChecked="{Binding Persisted.FriendsOverviewGameSummariesShowMetadataPlatform}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Playtime}"
                                          IsChecked="{Binding Persisted.FriendsOverviewGameSummariesShowMetadataPlaytime}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Region}"
                                          IsChecked="{Binding Persisted.FriendsOverviewGameSummariesShowMetadataRegion}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            </StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGameSummariesGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewGameSummariesGridColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewGameSummariesGridControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_DateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.FriendsOverviewGameSummariesLastPlayedDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewGameSummariesGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewGameSummariesGridMaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_Title}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_UseCoverImages}"
                                      IsChecked="{Binding Persisted.FriendsOverviewAchievementsUseCoverImages}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowRarityGlow}"
                                      IsChecked="{Binding Persisted.FriendsOverviewAchievementsShowRarityGlow}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ColorNamesByRarity}"
                                      IsChecked="{Binding Persisted.FriendsOverviewAchievementsColorNamesByRarity}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowAchievementGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewAchievementsGridColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.ShowFriendsOverviewAchievementsGridControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_StartInCategoryMode}"
                                      IsChecked="{Binding Persisted.FriendsOverviewAchievementsStartInCategoryMode}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_StartInCategoryMode_ViewFriends}"
                                      IsChecked="{Binding Persisted.ViewFriendsAchievementsStartInCategoryMode}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                      ToolTip="{DynamicResource LOCPlayAch_Menu_ViewFriendsAchievements}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UnlockDateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.FriendsOverviewAchievementsUnlockDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewAchievementsGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.FriendsOverviewAchievementsGridMaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80"
                                         Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                           Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
