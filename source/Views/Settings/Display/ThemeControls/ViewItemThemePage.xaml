<UserControl x:Class="PlayniteAchievements.Views.Settings.Display.ThemeControls.ViewItemThemePage"
             x:Name="ViewItemThemePageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
             xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PreviewThemeControlStyle"
                   TargetType="{x:Type base:ThemeControlBase}">
                <Setter Property="SettingsOverride"
                        Value="{Binding DataContext, ElementName=ViewItemThemePageRoot}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ViewItemPreview}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0"/>
                        <CheckBox Grid.Column="1"
                                  Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                                  IsChecked="{Binding Persisted.EnableAchievementViewItemControl}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}"
                            Visibility="{Binding Persisted.EnableAchievementViewItemControl, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="PREVIEW"
                                       Style="{StaticResource ContextLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <modern:AchievementViewItemControl Width="60" ShowProgressBar="False" Margin="0,0,16,0"
                                    Style="{StaticResource PreviewThemeControlStyle}"
                                    ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                <modern:AchievementViewItemControl Width="100" ShowProgressBar="True"
                                    Style="{StaticResource PreviewThemeControlStyle}"
                                    ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
