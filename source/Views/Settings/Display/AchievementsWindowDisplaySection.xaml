<UserControl x:Class="PlayniteAchievements.Views.Settings.Display.AchievementsWindowDisplaySection"
             x:Name="AchievementsWindowDisplaySectionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
             xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
             xmlns:settings="clr-namespace:PlayniteAchievements.Models.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PreviewThemeControlStyle"
                   TargetType="{x:Type base:ThemeControlBase}">
                <Setter Property="SettingsOverride"
                        Value="{Binding DataContext, ElementName=AchievementsWindowDisplaySectionRoot}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}"
                    Background="{DynamicResource PlayAch.Brush.Panel}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Display_LibrarySection}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ViewAchievementsWindow}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Overview_GameSummaries}"
                               Style="{StaticResource SubSectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_UseCoverImages}"
                                      IsChecked="{Binding Persisted.ViewAchievementsGameSummariesUseCoverImages}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GameMetadataHeader}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Margin="16,0,0,0">
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                          IsChecked="{Binding Persisted.ViewAchievementsGameSummariesShowMetadataPlatform}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Playtime}"
                                          IsChecked="{Binding Persisted.ViewAchievementsGameSummariesShowMetadataPlaytime}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Region}"
                                          IsChecked="{Binding Persisted.ViewAchievementsGameSummariesShowMetadataRegion}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            </StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowCompletionBorder}"
                                      IsChecked="{Binding Persisted.ViewAchievementsGameSummariesShowCompletionBorder}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGameSummariesGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.ShowViewAchievementsGameSummariesGridColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_LastPlayedDateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.ViewAchievementsGameSummariesLastPlayedDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.ViewAchievementsGameSummariesGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Achievements}"
                               Style="{StaticResource SubSectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Top.Md}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.ShowViewAchievementsAchievementGridControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_StartInCategoryMode}"
                                      IsChecked="{Binding Persisted.ViewAchievementsAchievementGridStartInCategoryMode}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.SingleGameGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.SingleGameGridMaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UnlockDateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.ViewAchievementsAchievementsUnlockDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox SelectedValue="{Binding Persisted.SingleGameGridSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="180">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                                </ComboBox>
                                <Button ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                        VerticalAlignment="Center"
                                        Click="ToggleSingleGameGridSortDescending">
                                    <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xea65;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Persisted.SingleGameGridSortDescending}" Value="True">
                                                        <Setter Property="Text" Value="&#xea66;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortResetHint}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}"
                    Background="{DynamicResource PlayAch.Brush.Panel}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Display_ThemeIntegration}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
            </Border>

    <!-- ================== DATA GRID PREVIEW SECTION ================== -->
    <Border Style="{StaticResource SectionBorderStyle}">
        <StackPanel>
            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_AchievementDataGridPreview}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
                <CheckBox Grid.Column="1"
                          Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                          IsChecked="{Binding Persisted.EnableAchievementDataGridControl}"
                          VerticalAlignment="Center"/>
            </Grid>
            <Border Style="{StaticResource SectionAccentRuleStyle}"/>
            <Border Style="{StaticResource SettingGroupCardStyle}"
                    Visibility="{Binding Persisted.EnableAchievementDataGridControl, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PREVIEW"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <modern:AchievementDataGridControl
                        Style="{StaticResource PreviewThemeControlStyle}"
                        ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        PreviewMinimumMaxHeight="220"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <TextBlock Text="SETTINGS"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowDesktopThemeAchievementGridColumnHeaders}"
                              IsChecked="{Binding Persisted.ShowDesktopThemeAchievementGridColumnHeaders}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                              IsChecked="{Binding Persisted.ShowDesktopThemeAchievementGridControlBar}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_StartInCategoryMode}"
                              IsChecked="{Binding Persisted.DesktopThemeAchievementGridStartInCategoryMode}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UnlockDateDisplay}"
                                   VerticalAlignment="Center"/>
                        <ComboBox SelectedValue="{Binding Persisted.DesktopThemeAchievementsUnlockDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  MinWidth="140"
                                  Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowRarityGlow}"
                              IsChecked="{Binding Persisted.ModernDataGridShowRarityGlow}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ColorNamesByRarity}"
                              IsChecked="{Binding Persisted.ModernDataGridColorNamesByRarity}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_AchievementDataGridMaxHeight}"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Persisted.AchievementDataGridMaxHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=88}"
                                 Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsUnit}"
                                   VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Top.Sm}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Persisted.DesktopThemeAchievementGridRowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                 Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                   VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Top.Sm}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Persisted.DesktopThemeAchievementGridMaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                 Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                   VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                               Style="{StaticResource SubSectionHeaderStyle}"
                               Margin="0,12,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox SelectedValue="{Binding Persisted.AchievementDataGridSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  MinWidth="180">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                        </ComboBox>
                        <Button ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                VerticalAlignment="Center"
                                Click="ToggleAchievementDataGridSortDescending">
                            <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xea65;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Persisted.AchievementDataGridSortDescending}" Value="True">
                                                <Setter Property="Text" Value="&#xea66;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortResetHint}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>

    <!-- ================== COMPACT LIST PREVIEW SECTION ================== -->
    <Border Style="{StaticResource SectionBorderStyle}">
        <StackPanel>
            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CompactListPreview}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
                <CheckBox Grid.Column="1"
                          Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                          IsChecked="{Binding Persisted.EnableAchievementCompactListControl}"
                          VerticalAlignment="Center"/>
            </Grid>
            <Border Style="{StaticResource SectionAccentRuleStyle}"/>
            <Border Style="{StaticResource SettingGroupCardStyle}"
                    Visibility="{Binding Persisted.EnableAchievementCompactListControl, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PREVIEW"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <modern:AchievementCompactListControl
                        Style="{StaticResource PreviewThemeControlStyle}"
                        ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        SettingsOverride="{Binding}"
                        IconSize="48"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <TextBlock Text="SETTINGS"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowCompactListRarityBar}"
                              IsChecked="{Binding Persisted.ShowCompactListRarityBar}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowRarityGlow}"
                              IsChecked="{Binding Persisted.ModernCompactListShowRarityGlow}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding Persisted.CompactListSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                        </ComboBox>
                        <Button Grid.Column="2"
                                ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                VerticalAlignment="Center"
                                Click="ToggleCompactListSortDescending">
                            <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xea65;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Persisted.CompactListSortDescending}" Value="True">
                                                <Setter Property="Text" Value="&#xea66;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>

    <!-- ================== COMPACT UNLOCKED LIST PREVIEW SECTION ================== -->
    <Border Style="{StaticResource SectionBorderStyle}">
        <StackPanel>
            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CompactUnlockedListPreview}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
                <CheckBox Grid.Column="1"
                          Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                          IsChecked="{Binding Persisted.EnableAchievementCompactUnlockedListControl}"
                          VerticalAlignment="Center"/>
            </Grid>
            <Border Style="{StaticResource SectionAccentRuleStyle}"/>
            <Border Style="{StaticResource SettingGroupCardStyle}"
                    Visibility="{Binding Persisted.EnableAchievementCompactUnlockedListControl, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PREVIEW"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <modern:AchievementCompactUnlockedListControl
                        Style="{StaticResource PreviewThemeControlStyle}"
                        ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        SettingsOverride="{Binding}"
                        IconSize="48"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <TextBlock Text="SETTINGS"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowRarityGlow}"
                              IsChecked="{Binding Persisted.ModernUnlockedListShowRarityGlow}"
                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding Persisted.CompactUnlockedListSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                        </ComboBox>
                        <Button Grid.Column="2"
                                ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                VerticalAlignment="Center"
                                Click="ToggleCompactUnlockedListSortDescending">
                            <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xea65;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Persisted.CompactUnlockedListSortDescending}" Value="True">
                                                <Setter Property="Text" Value="&#xea66;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>

    <!-- ================== COMPACT LOCKED LIST PREVIEW SECTION ================== -->
    <Border Style="{StaticResource SectionBorderStyle}">
        <StackPanel>
            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CompactLockedListPreview}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
                <CheckBox Grid.Column="1"
                          Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                          IsChecked="{Binding Persisted.EnableAchievementCompactLockedListControl}"
                          VerticalAlignment="Center"/>
            </Grid>
            <Border Style="{StaticResource SectionAccentRuleStyle}"/>
            <Border Style="{StaticResource SettingGroupCardStyle}"
                    Visibility="{Binding Persisted.EnableAchievementCompactLockedListControl, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PREVIEW"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <modern:AchievementCompactLockedListControl
                        Style="{StaticResource PreviewThemeControlStyle}"
                        ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        SettingsOverride="{Binding}"
                        IconSize="48"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <TextBlock Text="SETTINGS"
                               Style="{StaticResource ContextLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding Persisted.CompactLockedListSortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                        </ComboBox>
                        <Button Grid.Column="2"
                                ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                VerticalAlignment="Center"
                                Click="ToggleCompactLockedListSortDescending">
                            <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xea65;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Persisted.CompactLockedListSortDescending}" Value="True">
                                                <Setter Property="Text" Value="&#xea66;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>

