<UserControl x:Class="PlayniteAchievements.Views.Settings.Display.FriendsAchievementsWindowDisplaySection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Settings.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}"
                    Background="{DynamicResource PlayAch.Brush.Panel}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                <TextBlock Text="{DynamicResource LOCPlayAch_ViewFriendsAchievements_TitleFallback}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_FriendSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <controls:GridOptionsEditor Options="{Binding Persisted.GridOptions.FriendSummaries[ViewFriendsAchievements]}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Overview_GameSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <controls:GridOptionsEditor Options="{Binding Persisted.GridOptions.GameSummaries[ViewFriendsAchievements]}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Overview_GameSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <controls:GridOptionsEditor Options="{Binding Persisted.GridOptions.GameSummaries[ViewFriendsAchievementsSelectedFriend]}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Achievements}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <controls:GridOptionsEditor Options="{Binding Persisted.GridOptions.Achievement[ViewFriendsAchievements]}"
                                                    ShowCategoryModeRow="True"/>
                    </Border>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CategoryGrid}"
                               Style="{StaticResource SubSectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Top.Md}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <controls:GridOptionsEditor Options="{Binding Persisted.GridOptions.CategorySummaries[ViewFriendsAchievements]}"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
