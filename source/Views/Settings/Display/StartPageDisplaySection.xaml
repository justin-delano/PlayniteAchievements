<UserControl x:Class="PlayniteAchievements.Views.Settings.Display.StartPageDisplaySection"
             x:Name="StartPageDisplaySectionRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:PlayniteAchievements.Models.Settings"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource SectionBorderStyle}"
                    Background="{DynamicResource PlayAch.Brush.Panel}"
                    BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Display_StartPageSection}"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0"/>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_CustomRefresh_ScopeHeader}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{DynamicResource LOCPlayAch_Filter_ActivitySelectorPlaceholder}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,8"/>
                            <Button x:Name="StartPageActivityScopeSelectionButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource AchievementSelectorButtonStyle}"
                                    Content="{Binding StartPageActivityScopeText, ElementName=StartPageDisplaySectionRoot}"
                                    Click="StartPageActivityScopeSelectionButton_Click"
                                    MinWidth="220"
                                    Height="{StaticResource PlayAch.Size.Control.Height}"
                                    Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"
                                    HorizontalAlignment="Left">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="StartPageActivityScopeSelectionContextMenu"
                                                 Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                                 ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                                </Button.ContextMenu>
                            </Button>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="{DynamicResource LOCPlayAch_Progress}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Button x:Name="StartPageProgressScopeSelectionButton"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource AchievementSelectorButtonStyle}"
                                    Content="{Binding StartPageProgressScopeText, ElementName=StartPageDisplaySectionRoot}"
                                    Click="StartPageProgressScopeSelectionButton_Click"
                                    MinWidth="220"
                                    Height="{StaticResource PlayAch.Size.Control.Height}"
                                    HorizontalAlignment="Left">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="StartPageProgressScopeSelectionContextMenu"
                                                 Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                                 ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Overview_GameSummaries}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_UseCoverImages}"
                                      IsChecked="{Binding Persisted.StartPageGameSummariesGrid.UseCoverImages}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GameMetadataHeader}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <StackPanel Margin="16,0,0,0">
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                          IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowMetadataPlatform}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Playtime}"
                                          IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowMetadataPlaytime}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Label_Region}"
                                          IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowMetadataRegion}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            </StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowCompletionBorder}"
                                      IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowCompletionBorder}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGameSummariesGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.StartPageGameSummariesGrid.ShowControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_LastPlayedDateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.StartPageGameSummariesLastPlayedDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.StartPageGameSummariesGrid.RowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.StartPageGameSummariesGrid.MaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox SelectedValue="{Binding Persisted.StartPageGameSummariesGrid.SortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="180">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_LastUnlock}" Tag="{x:Static settings:GameSummariesSortMode.RecentUnlock}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_LastPlayed}" Tag="{x:Static settings:GameSummariesSortMode.LastPlayed}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Total}" Tag="{x:Static settings:GameSummariesSortMode.TotalAchievements}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Progress}" Tag="{x:Static settings:GameSummariesSortMode.Progress}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Name}" Tag="{x:Static settings:GameSummariesSortMode.Alphabetical}"/>
                                </ComboBox>
                                <Button ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                        VerticalAlignment="Center"
                                        Click="ToggleStartPageGameSummariesGridSortDescending">
                                    <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xea65;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Persisted.StartPageGameSummariesGrid.SortDescending}" Value="True">
                                                        <Setter Property="Text" Value="&#xea66;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_RecentAchievements}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_UseCoverImages}"
                                      IsChecked="{Binding Persisted.StartPageRecentUnlocksGrid.UseCoverImages}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowRarityGlow}"
                                      IsChecked="{Binding Persisted.StartPageRecentUnlocksGrid.ShowRarityGlow}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ColorNamesByRarity}"
                                      IsChecked="{Binding Persisted.StartPageRecentUnlocksGrid.ColorNamesByRarity}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowAchievementGridColumnHeaders}"
                                      IsChecked="{Binding Persisted.StartPageRecentUnlocksGrid.ShowColumnHeaders}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowGridControlBar}"
                                      IsChecked="{Binding Persisted.StartPageRecentUnlocksGrid.ShowControlBar}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_UnlockDateDisplay}"
                                           VerticalAlignment="Center"/>
                                <ComboBox SelectedValue="{Binding Persisted.StartPageAchievementsUnlockDateMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="140"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateAndTime}" Tag="{x:Static settings:DateDisplayMode.DateAndTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_DateOnly}" Tag="{x:Static settings:DateDisplayMode.DateOnly}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_DateDisplayMode_Relative}" Tag="{x:Static settings:DateDisplayMode.Relative}"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridRowHeight}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.StartPageRecentUnlocksGrid.RowHeight, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableDoubleTextConverter}, ConverterParameter=32}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PixelsAutomaticUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_GridMaxRows}"
                                           VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Persisted.StartPageRecentUnlocksGrid.MaxRows, UpdateSourceTrigger=LostFocus, Converter={StaticResource NullableIntTextConverter}, ConverterParameter=1}"
                                         Width="80" Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RowsUnlimitedUnit}"
                                           VerticalAlignment="Center" Margin="{StaticResource PlayAch.Thickness.Left.Xs}" Opacity="{StaticResource PlayAch.Opacity.Muted}"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_SortBy}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox SelectedValue="{Binding Persisted.StartPageRecentUnlocksGrid.SortMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          MinWidth="180">
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_Default}" Tag="{x:Static settings:CompactListSortMode.None}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Common_UnlockTime}" Tag="{x:Static settings:CompactListSortMode.UnlockTime}"/>
                                    <ComboBoxItem Content="{DynamicResource LOCPlayAch_Column_Rarity}" Tag="{x:Static settings:CompactListSortMode.Rarity}"/>
                                </ComboBox>
                                <Button ToolTip="{DynamicResource LOCPlayAch_Settings_SortDirection_Tooltip}"
                                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                                        VerticalAlignment="Center"
                                        Click="ToggleStartPageRecentUnlocksGridSortDescending">
                                    <TextBlock FontFamily="{DynamicResource CommonFont}" FontSize="18">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xea65;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Persisted.StartPageRecentUnlocksGrid.SortDescending}" Value="True">
                                                        <Setter Property="Text" Value="&#xea66;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PieChartPreview}"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                    <Border Style="{StaticResource SettingGroupCardStyle}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ShowOverviewPiePercentages}"
                                      IsChecked="{Binding Persisted.StartPagePieCharts.ShowCenterPercentage}"
                                      Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_OverviewPieSmallSliceMode}"
                                       Style="{StaticResource SubSectionHeaderStyle}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{DynamicResource LOCPlayAch_Settings_OverviewPieSmallSliceMode_Exact}"
                                             GroupName="StartPagePieSmallSliceMode"
                                             Style="{StaticResource OverviewPieModeRadioButtonStyle}"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding Persisted.StartPagePieCharts.SmallSliceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource EnumToBool}, ConverterParameter=Exact}"/>
                                <RadioButton Content="{DynamicResource LOCPlayAch_Common_Hide}"
                                             GroupName="StartPagePieSmallSliceMode"
                                             Style="{StaticResource OverviewPieModeRadioButtonStyle}"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding Persisted.StartPagePieCharts.SmallSliceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource EnumToBool}, ConverterParameter=Hide}"/>
                                <RadioButton Content="{DynamicResource LOCPlayAch_Settings_OverviewPieSmallSliceMode_Round}"
                                             GroupName="StartPagePieSmallSliceMode"
                                             Style="{StaticResource OverviewPieModeRadioButtonStyle}"
                                             IsChecked="{Binding Persisted.StartPagePieCharts.SmallSliceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource EnumToBool}, ConverterParameter=Round}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
