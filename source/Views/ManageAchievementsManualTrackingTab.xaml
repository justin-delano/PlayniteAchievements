<UserControl x:Class="PlayniteAchievements.Views.ManageAchievementsManualTrackingTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ManualAchievementsViewModel}"
             FocusManager.FocusedElement="{Binding ElementName=SearchTextBox}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/ManageAchievementsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stage Content -->
        <Grid Grid.Row="0">
            <!-- Stage 1: Search -->
            <Grid Visibility="{Binding DataContext.IsSearchStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ManageAchievementsHeaderCardStyle}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Search_Header}"
                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Source Selection -->
                <Grid Grid.Row="1" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource LOCPlayAch_ManageAchievements_Manual_Source}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                    <ComboBox x:Name="SourceComboBox"
                              Grid.Column="1"
                              ItemsSource="{Binding AvailableSources}"
                              SelectedValue="{Binding SelectedSourceKey, Mode=TwoWay}"
                              SelectedValuePath="SourceKey"
                              DisplayMemberPath="SourceName"
                              MinWidth="150"
                              HorizontalAlignment="Left"/>
                </Grid>

                <!-- Search bar -->
                <Grid Grid.Row="2" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchTextBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Style="{StaticResource ManageAchievementsSearchTextBoxStyle}"
                                 KeyDown="SearchTextBox_KeyDown"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Games}"
                                   Style="{StaticResource ManageAchievementsSearchPlaceholderTextStyle}"/>
                        <Button x:Name="ClearSearchTextButton"
                                Tag="{Binding SearchText}"
                                Click="ClearSearchTextButton_Click"
                                Style="{StaticResource ClearSearchButtonStyle}"/>
                    </Grid>

                    <Button x:Name="SearchButton"
                            Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Search}"
                            Command="{Binding SearchCommand}"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                            MinWidth="80"
                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                </Grid>

                <!-- Results grid -->
                <Border Grid.Row="3"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                    <DataGrid x:Name="SearchResultsDataGrid"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              KeyboardNavigation.DirectionalNavigation="Continue"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              RowHeight="68"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              VirtualizingStackPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                              ColumnHeaderStyle="{StaticResource ManageAchievementsColumnHeaderStyle}"
                              helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
                              helpers:DataGridAlignmentBehavior.IsEnabled="True"
                              PreviewMouseLeftButtonDown="SearchDataGrid_PreviewMouseLeftButtonDown"
                              Tag="ControllerCellFocus"
                              MouseDoubleClick="SearchDataGrid_MouseDoubleClick">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}"/>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ManageAchievementsDataGridRowStyle}">
                                <Setter Property="MinHeight" Value="64"/>
                                <Setter Property="ClipToBounds" Value="True"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Icon}" Width="80" IsReadOnly="True"
                                                    CellStyle="{StaticResource ManageAchievementsIconCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Width="72"
                                              Height="44">
                                            <Image Source="{Binding IconUrl}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_Name}"
                                                Binding="{Binding Name}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedDataGridTextStyle}">
                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                                Binding="{Binding Platforms}"
                                                Width="120"
                                                Visibility="{Binding DataContext.ShowPlatformColumn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedDataGridTextStyle}">
                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{DynamicResource LOCPlayAch_Column_AppId}"
                                                Binding="{Binding SourceGameId}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedDataGridTextStyle}">
                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="4"
                           Text="{Binding SearchStatusMessage}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Hint}"
                           TextWrapping="Wrap"
                           Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
            </Grid>

            <!-- Stage 2: Refreshing -->
            <Grid Visibility="{Binding DataContext.IsRefreshingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ProgressMessage}"
                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>

                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             Maximum="100"
                             Width="350" Height="24"
                             HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="{Binding ProgressPercent, StringFormat={}{0:F0}%, Mode=OneWay}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource PlayAch.Thickness.Top.Sm}"/>

                <Button x:Name="RefreshCancelButton"
                        Grid.Row="3"
                        Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                        Command="{Binding CancelRefreshCommand}"
                        IsEnabled="{Binding CanCancelRefresh}"
                        Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                        MinWidth="80"
                        HorizontalAlignment="Center"
                        Margin="0,24,0,0"/>
            </Grid>

            <!-- Stage 3: Editing -->
            <Grid Visibility="{Binding DataContext.IsEditingStage,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ManageAchievementsHeaderCardStyle}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManualAchievements_Edit_Header}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Progress and action bar -->
                <Grid Grid.Row="1" Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search filter -->
                    <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                        <Grid>
                            <TextBox x:Name="EditSearchTextBox"
                                     Text="{Binding EditSearchFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     Style="{StaticResource ManageAchievementsSearchTextBoxStyle}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Common_FilterAchievementsPlaceholder}"
                                       Style="{StaticResource ManageAchievementsEditSearchPlaceholderTextStyle}"/>
                            <Button x:Name="ClearEditFilterButton"
                                    Tag="{Binding EditSearchFilter}"
                                    Click="ClearEditFilterButton_Click"
                                    Style="{StaticResource ClearSearchButtonStyle}"/>
                        </Grid>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                        <Button x:Name="UnlockAllButton"
                                Content="{DynamicResource LOCPlayAch_Common_SelectAll}"
                                Command="{Binding UnlockAllCommand}"
                                Padding="8,4"
                                Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                        <Button x:Name="LockAllButton"
                                Content="{DynamicResource LOCPlayAch_Common_DeselectAll}"
                                Command="{Binding LockAllCommand}"
                                Padding="8,4"/>
                    </StackPanel>
                </Grid>

                <!-- Achievements grid -->
                <Border Grid.Row="2"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                    <DataGrid x:Name="ManualAchievementsDataGrid"
                              ItemsSource="{Binding FilteredAchievements}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              KeyboardNavigation.DirectionalNavigation="Continue"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                              BorderThickness="0"
                              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="True"
                              RowHeight="100"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              VirtualizingStackPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ColumnHeaderStyle="{StaticResource ManageAchievementsColumnHeaderStyle}"
                              helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
                              helpers:DataGridAlignmentBehavior.IsEnabled="True"
                              Tag="ControllerCellFocus">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}"/>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ManageAchievementsDataGridRowStyle}">
                                <Setter Property="MinHeight" Value="64"/>
                                <Setter Property="ClipToBounds" Value="True"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <!-- Unlocked / locked -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Common_Unlocked}"
                                                    Width="80"
                                                    SortMemberPath="IsUnlocked"
                                                    HeaderStyle="{StaticResource ManageAchievementsColumnHeaderStyle}"
                                                    CellStyle="{StaticResource ManageAchievementsCheckBoxCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUnlocked, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="72"
                                                    MinWidth="44"
                                                    MaxWidth="160"
                                                    CanUserResize="True"
                                                    CellStyle="{StaticResource ManageAchievementsIconCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Background="Transparent"
                                              Style="{StaticResource ClickableCellStyle}"
                                              PreviewMouseDown="HiddenText_PreviewMouseDown">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource AchievementIconTemplate}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                                    Width="*"
                                                    SortMemberPath="DisplayName"
                                                    IsReadOnly="True"
                                                    CellStyle="{StaticResource StretchCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Background="Transparent"
                                            Style="{StaticResource ClickableCellStyle}"
                                            PreviewMouseDown="HiddenText_PreviewMouseDown"
                                            helpers:DataGridAlignmentBehavior.CellHorizontalAlignment="Left"
                                            helpers:DataGridAlignmentBehavior.CellVerticalAlignment="Center"
                                            helpers:DataGridAlignmentBehavior.CellTextAlignment="Left">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource AchievementInfoTemplate}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unlock time set/null + date/time editor -->
                            <DataGridTemplateColumn Header="{DynamicResource LOCPlayAch_Common_UnlockTime}"
                                                    Width="300"
                                                    SortMemberPath="UnlockTime"
                                                    HeaderStyle="{StaticResource ManageAchievementsColumnHeaderStyle}"
                                                    CellStyle="{StaticResource ManageAchievementsControllerCellStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center"
                                              Margin="4,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding HasUnlockTime, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsUnlocked}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Focusable="False"
                                                      IsTabStop="False"/>
                                            <Grid Grid.Column="1"
                                                  Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                                  VerticalAlignment="Center">
                                                <TextBlock Text="—"
                                                           Style="{StaticResource PlayAch.TextBlock.BaseStyle}"
                                                           Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding CanEditUnlockTime, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding CanEditUnlockTime, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <DatePicker SelectedDate="{Binding UnlockDate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Padding="4,2"
                                                            Margin="{StaticResource PlayAch.Thickness.Right.Compact}"/>
                                                <TextBox Text="{Binding TimeText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         Width="62"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         Padding="4,0"
                                                         MaxLength="5">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource PlayAch.TextBox.BaseStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValidTime}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <ComboBox ItemsSource="{Binding AvailableTimeModes}"
                                                          SelectedItem="{Binding SelectedTimeModeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectionChanged="TimeModeComboBox_SelectionChanged"
                                                          Width="74"
                                                          VerticalContentAlignment="Center"
                                                          Padding="4,0"
                                                          Margin="2,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Error state -->
            <StackPanel Visibility="{Binding DataContext.HasError,
                    RelativeSource={RelativeSource AncestorType=UserControl},
                    Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>
            </StackPanel>
        </Grid>

        <!-- Footer Buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsEditingStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Manual_Source}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Hint}"
                               VerticalAlignment="Center" />
                    <TextBlock Text=": "
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Hint}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ManualSourceName}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="   "
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SourceGameName}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" ("
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SourceGameId}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                               VerticalAlignment="Center" />
                    <TextBlock Text=")"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                               VerticalAlignment="Center" />
                    <Button x:Name="UnlinkButton"
                            Content="{DynamicResource LOCPlayAch_ManageAchievements_Manual_Unlink}"
                            Command="{Binding UnlinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Padding="10,5"
                            Margin="{StaticResource PlayAch.Thickness.Left.Md}"
                            VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding SaveStatusMessage}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                           VerticalAlignment="Center"
                           Margin="{StaticResource PlayAch.Thickness.Top.Compact}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSaveStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <!-- Search stage buttons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsSearchStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button x:Name="NextButton"
                            Content="{DynamicResource LOCPlayAch_Button_Next}"
                            Click="NextButton_Click"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                            MinWidth="80"
                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                            IsDefault="True"/>
                    <Button x:Name="SearchCancelButton"
                            Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Click="CancelButton_Click"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                            MinWidth="80"
                            IsCancel="True"/>
                </StackPanel>

                <!-- Editing stage buttons -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding DataContext.IsEditingStage,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button x:Name="SaveButton"
                            Content="{DynamicResource LOCPlayAch_Button_Save}"
                            Command="{Binding SaveCommand}"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                            MinWidth="80"
                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                            IsDefault="True"/>
                    <Button x:Name="EditCancelButton"
                            Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                            Click="CancelButton_Click"
                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                            MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

