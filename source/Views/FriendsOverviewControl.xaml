<UserControl x:Class="PlayniteAchievements.Views.FriendsOverviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Loaded="OnLoaded"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FriendsOverviewGridRowStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource GameSummariesGridRowBaseStyle}">
                <Setter Property="MinHeight" Value="52"/>
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SummaryRow_PreviewMouseLeftButtonDown"/>
            </Style>

            <Style x:Key="FriendsOverviewTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource WrappedDataGridTextStyle}">
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>

            <Style x:Key="FriendsOverviewNumberTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource FriendsOverviewTextStyle}">
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="FriendsOverviewRefreshButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
                <Setter Property="Padding" Value="10,3"/>
                <Setter Property="MinWidth" Value="88"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0"/>
            </Style>

            <Style x:Key="FriendsOverviewNavigationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="17"
                                    Width="34"
                                    Height="34">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource PlayAch.Brush.Overlay.Tint.20}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FriendsOverviewClearSelectionButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background}"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.72"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource PlayAch.Radius.Small}"
                                    SnapsToDevicePixels="True">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PlayAch.Brush.Panel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header / Refresh -->
        <Border Grid.Row="0"
                Background="{DynamicResource Transparent}"
                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,0,16,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,18,0">
                    <Button x:Name="CloseViewButton"
                            Content="&#xE72B;"
                            Click="CloseViewButton_Click"
                            Style="{StaticResource FriendsOverviewNavigationButtonStyle}"
                            ToolTip="{DynamicResource LOCPlayAch_CloseView}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_Title}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               FontWeight="Bold"
                               FontSize="20"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               MaxWidth="230"
                               TextTrimming="CharacterEllipsis"
                               Margin="{StaticResource PlayAch.Thickness.Left.Md}"/>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="24,0,0,0">
                        <Button x:Name="RefreshModeSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Content="{Binding RefreshModeSelectionText}"
                                Click="RefreshModeSelectionButton_Click"
                                HorizontalContentAlignment="Center"
                                MinWidth="94"
                                MinHeight="24"
                                Margin="{StaticResource PlayAch.Thickness.Right.Compact}"
                                VerticalAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="RefreshModeSelectionContextMenu"
                                             Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                            </Button.ContextMenu>
                        </Button>

                        <Button Content="{Binding RefreshOrCancelButtonText}"
                                Command="{Binding RefreshOrCancelCommand}"
                                Style="{StaticResource FriendsOverviewRefreshButtonStyle}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                        ToolTip="{DynamicResource LOCPlayAch_FriendsOverview_ClearSelection}"
                        Click="ClearSelection_Click"
                        Style="{StaticResource FriendsOverviewClearSelectionButtonStyle}"
                        Visibility="{Binding HasAnySelection, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- ROW 1: Progress -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,8"
                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding ProgressMessage}"
                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                           TextTrimming="CharacterEllipsis"
                           Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>
                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                             Height="6"
                             Minimum="0"
                             Maximum="100"/>
            </StackPanel>
        </Border>

        <!-- ROW 2: Three connected grids -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" MinWidth="260"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="1.35*" MinWidth="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="2.1*" MinWidth="440"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Friend header/filter -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="Transparent"
                    Height="{StaticResource PlayAch.Size.Header.Height}"
                    Padding="16,0"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_FriendSummaries}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                            ToolTip="{DynamicResource LOCPlayAch_FriendsOverview_ClearSelection}"
                            Click="ClearFriendSelection_Click"
                            Style="{StaticResource FriendsOverviewClearSelectionButtonStyle}"
                            Visibility="{Binding HasFriendSelection, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    Background="Transparent"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid>
                        <TextBox x:Name="FriendSearchTextBox"
                                 Text="{Binding FriendSearchText, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_SearchFriends}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                   FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                                   Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=FriendSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=FriendSearchTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Tag="{Binding Text, ElementName=FriendSearchTextBox}"
                                Click="ClearFriendSearch_Click"
                                Style="{StaticResource ClearSearchButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Game header/filter -->
            <Border Grid.Row="0" Grid.Column="2"
                    Background="Transparent"
                    Height="{StaticResource PlayAch.Size.Header.Height}"
                    Padding="16,0"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource LOCPlayAch_FriendsOverview_GameSummaries}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                            ToolTip="{DynamicResource LOCPlayAch_FriendsOverview_ClearSelection}"
                            Click="ClearGameSelection_Click"
                            Style="{StaticResource FriendsOverviewClearSelectionButtonStyle}"
                            Visibility="{Binding HasGameSelection, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="2"
                    Background="Transparent"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <TextBox x:Name="GameSearchTextBox"
                             Text="{Binding GameSearchText, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                             Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Games}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                               FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                               Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=GameSearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=GameSearchTextBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Tag="{Binding Text, ElementName=GameSearchTextBox}"
                            Click="ClearGameSearch_Click"
                            Style="{StaticResource ClearSearchButtonStyle}"/>
                </Grid>
            </Border>

            <!-- Achievement header/filter -->
            <Border Grid.Row="0" Grid.Column="4"
                    Background="Transparent"
                    Height="{StaticResource PlayAch.Size.Header.Height}"
                    Padding="16,0"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding AchievementSectionTitle}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                        <TextBlock Text="{Binding AchievementCountText}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                   VerticalAlignment="Center"/>
                        <Button Content="&#xE711;"
                                FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                                ToolTip="{DynamicResource LOCPlayAch_FriendsOverview_ClearSelection}"
                                Click="ClearSelection_Click"
                                Style="{StaticResource FriendsOverviewClearSelectionButtonStyle}"
                                Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                Visibility="{Binding HasAnySelection, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="4"
                    Background="Transparent"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="AchievementSearchTextBox"
                                 Text="{Binding AchievementSearchText, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Achievements}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                   FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                                   Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=AchievementSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=AchievementSearchTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Tag="{Binding Text, ElementName=AchievementSearchTextBox}"
                                Click="ClearAchievementSearch_Click"
                                Style="{StaticResource ClearSearchButtonStyle}"/>
                    </Grid>

                    <Button x:Name="TypeFilterSelectionButton"
                            Grid.Column="1"
                            Style="{StaticResource AchievementSelectorButtonStyle}"
                            Content="{Binding SelectedTypeFilterText}"
                            Click="TypeFilterSelectionButton_Click"
                            Width="118"
                            Height="{StaticResource PlayAch.Size.Control.Height}"
                            Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                            VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="TypeFilterSelectionContextMenu"
                                         Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                         ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                        </Button.ContextMenu>
                    </Button>

                    <Button x:Name="CategoryFilterSelectionButton"
                            Grid.Column="2"
                            Style="{StaticResource AchievementSelectorButtonStyle}"
                            Content="{Binding SelectedCategoryFilterText}"
                            Click="CategoryFilterSelectionButton_Click"
                            Width="132"
                            Height="{StaticResource PlayAch.Size.Control.Height}"
                            Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                            VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="CategoryFilterSelectionContextMenu"
                                         Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                         ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="1,0,0,0"
                    IsHitTestVisible="False"/>
            <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Focusable="False"
                          IsTabStop="False"/>

            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                    BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                    BorderThickness="1,0,0,0"
                    IsHitTestVisible="False"/>
            <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Focusable="False"
                          IsTabStop="False"/>

            <!-- Friend summaries -->
            <controls:FriendSummariesGridControl x:Name="FriendSummariesGridControl"
                                                 Grid.Row="2"
                                                 Grid.Column="0"
                                                 Margin="16,0,16,0"
                                                 ItemsSource="{Binding FilteredFriends}"
                                                 SelectedItem="{Binding SelectedFriend, Mode=TwoWay}"
                                                 ShowColumnHeaders="{Binding Settings.Persisted.ShowFriendsOverviewFriendSummariesGridColumnHeaders}"
                                                 FixedRowHeight="{Binding Settings.Persisted.FriendsOverviewFriendSummariesGridRowHeight}"
                                                 DelayInitialRenderUntilNormalized="True"
                                                 RowPreviewMouseLeftButtonDown="SummaryRow_PreviewMouseLeftButtonDown"/>

            <!-- Game summaries -->
            <controls:GameSummariesGridControl x:Name="FriendGameSummariesGridControl"
                                               Grid.Row="2"
                                               Grid.Column="2"
                                               Margin="16,0,16,0"
                                               ItemsSource="{Binding FilteredGames}"
                                               SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                                               ColumnSettingsKey="FriendsOverviewGameSummaries"
                                               UseCoverImages="{Binding Settings.Persisted.FriendsOverviewGameSummariesUseCoverImages}"
                                               ShowMetadataPlatform="{Binding Settings.Persisted.FriendsOverviewGameSummariesShowMetadataPlatform}"
                                               ShowMetadataPlaytime="{Binding Settings.Persisted.FriendsOverviewGameSummariesShowMetadataPlaytime}"
                                               ShowMetadataRegion="{Binding Settings.Persisted.FriendsOverviewGameSummariesShowMetadataRegion}"
                                               ShowCompletionBorder="False"
                                               ShowColumnHeaders="{Binding Settings.Persisted.ShowFriendsOverviewGameSummariesGridColumnHeaders}"
                                               FixedRowHeight="{Binding Settings.Persisted.FriendsOverviewGameSummariesGridRowHeight}"
                                               DelayInitialRenderUntilNormalized="True"
                                               RowPreviewMouseLeftButtonDown="SummaryRow_PreviewMouseLeftButtonDown"/>

            <!-- Achievements -->
            <Grid Grid.Row="2" Grid.Column="4">
                <controls:AchievementDataGridControl x:Name="FriendsAchievementsGrid"
                                                     Margin="16,0,16,0"
                                                     ItemsSource="{Binding DisplayedAchievements}"
                                                     ColumnSettingsKey="FriendsOverviewRecentAchievements"
                                                     ShowGameColumn="True"
                                                     ShowFriendColumn="True"
                                                     HideStatusColumn="True"
                                                     UseCoverImages="{Binding Settings.Persisted.FriendsOverviewAchievementsUseCoverImages}"
                                                     ShowRarityGlow="{Binding Settings.Persisted.FriendsOverviewAchievementsShowRarityGlow}"
                                                     ColorNamesByRarity="{Binding Settings.Persisted.FriendsOverviewAchievementsColorNamesByRarity}"
                                                     ShowColumnHeaders="{Binding Settings.Persisted.ShowFriendsOverviewAchievementsGridColumnHeaders}"
                                                     FixedRowHeight="{Binding Settings.Persisted.FriendsOverviewAchievementsGridRowHeight}"
                                                     DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                                     DelayInitialRenderUntilNormalized="True"
                                                     RowPreviewMouseLeftButtonDown="AchievementRow_PreviewMouseLeftButtonDown"/>

                <Border Background="{DynamicResource PlayAch.Brush.Panel}"
                        Visibility="{Binding HasStatusText, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding StatusText}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               Foreground="{DynamicResource PlayAch.Brush.Text.Secondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="24"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
