<UserControl x:Class="PlayniteAchievements.Views.FirstTimeLandingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="360">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="ScrollBar" BasedOn="{StaticResource PlayAch.ScrollBar.BaseStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,24">

            <!-- Plugin Icon -->
            <Image x:Name="PluginIcon"
                   Source="pack://application:,,,/icon.png"
                   Width="56"
                   Height="56"
                   HorizontalAlignment="Center"
                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Main Title -->
            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_Title}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

            <!-- Rarity Icons Decoration -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,20">
                <Image Source="{DynamicResource BadgeRarityCommon}"
                       Width="28"
                       Height="28"
                       Margin="3"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Image Source="{DynamicResource BadgeRarityUncommon}"
                       Width="28"
                       Height="28"
                       Margin="3"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Image Source="{DynamicResource BadgeRarityRare}"
                       Width="28"
                       Height="28"
                       Margin="3"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Image Source="{DynamicResource BadgeRarityUltraRare}"
                       Width="28"
                       Height="28"
                       Margin="3"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <Image Source="{DynamicResource BadgeCompletedGame}"
                       Width="28"
                       Height="28"
                       Margin="3"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </StackPanel>

            <StackPanel MinWidth="800" HorizontalAlignment="Center">

            <!-- Language Selector -->
            <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                    CornerRadius="{StaticResource PlayAch.Radius.Card}"
                    Padding="12,10"
                    Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource LOCPlayAch_Landing_Language}"
                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                               FontWeight="Medium"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>

                    <TextBlock Grid.Column="1"
                               Text="{DynamicResource LOCPlayAch_Settings_LanguageHint}"
                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               Opacity="{StaticResource PlayAch.Opacity.Muted}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <ComboBox Grid.Column="2"
                              Width="180"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding GlobalLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="English" Tag="english"/>
                        <ComboBoxItem Content="German (Deutsch)" Tag="german"/>
                        <ComboBoxItem Content="French (Français)" Tag="french"/>
                        <ComboBoxItem Content="Spanish (Español)" Tag="spanish"/>
                        <ComboBoxItem Content="Italian (Italiano)" Tag="italian"/>
                        <ComboBoxItem Content="Portuguese" Tag="portuguese"/>
                        <ComboBoxItem Content="Brazilian Portuguese" Tag="brazilian"/>
                        <ComboBoxItem Content="Russian (Русский)" Tag="russian"/>
                        <ComboBoxItem Content="Polish (Polski)" Tag="polish"/>
                        <ComboBoxItem Content="Dutch (Nederlands)" Tag="dutch"/>
                        <ComboBoxItem Content="Swedish (Svenska)" Tag="swedish"/>
                        <ComboBoxItem Content="Finnish (Suomi)" Tag="finnish"/>
                        <ComboBoxItem Content="Danish (Dansk)" Tag="danish"/>
                        <ComboBoxItem Content="Norwegian (Norsk)" Tag="norwegian"/>
                        <ComboBoxItem Content="Hungarian (Magyar)" Tag="hungarian"/>
                        <ComboBoxItem Content="Czech (Čeština)" Tag="czech"/>
                        <ComboBoxItem Content="Romanian (Română)" Tag="romanian"/>
                        <ComboBoxItem Content="Turkish (Türkçe)" Tag="turkish"/>
                        <ComboBoxItem Content="Greek (Ελληνικά)" Tag="greek"/>
                        <ComboBoxItem Content="Bulgarian (Български)" Tag="bulgarian"/>
                        <ComboBoxItem Content="Ukrainian (Українська)" Tag="ukrainian"/>
                        <ComboBoxItem Content="Thai (ไทย)" Tag="thai"/>
                        <ComboBoxItem Content="Vietnamese (Tiếng Việt)" Tag="vietnamese"/>
                        <ComboBoxItem Content="Japanese (日本語)" Tag="japanese"/>
                        <ComboBoxItem Content="Korean (한국어)" Tag="koreana"/>
                        <ComboBoxItem Content="Simplified Chinese (简体中文)" Tag="schinese"/>
                        <ComboBoxItem Content="Traditional Chinese (繁體中文)" Tag="tchinese"/>
                        <ComboBoxItem Content="Arabic (العربية)" Tag="arabic"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Provider Status List - Always Visible -->
            <StackPanel Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                <!-- Section Header -->
                <TextBlock Text="{DynamicResource LOCPlayAch_Landing_ProviderStatus}"
                           FontSize="{DynamicResource PlayAch.FontSize.Body}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                           Margin="0,0,0,10"/>

                <!-- Provider Cards -->
                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"
                                    Background="{DynamicResource PlayAch.Brush.Surface}"
                                    CornerRadius="{StaticResource PlayAch.Radius.Card}"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Glyph}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Icon -->
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Glyph}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource NegativeRatingBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Provider Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"/>
                                        <TextBlock Text="{Binding StatusSubtitle}"
                                                   FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Enable Toggle -->
                                    <CheckBox Grid.Column="2"
                                              Content="{DynamicResource LOCPlayAch_Landing_EnableProvider}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="12,0"
                                              FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                              Command="{Binding DataContext.ToggleProviderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding ProviderKey}"/>

                                    <!-- Status Badge -->
                                    <TextBlock Grid.Column="3" Text="{Binding StatusBadgeText}"
                                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                               FontWeight="SemiBold"
                                               Padding="6,2"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                                <Setter Property="Opacity" Value="0.5"/>
                                                <Setter Property="Background" Value="{DynamicResource ControlBackgroundDarkBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Surface}"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Glyph}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Setter Property="Background" Value="{DynamicResource ControlBackgroundDarkBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Content states switched via visibility bindings -->
            <Grid>

                <!-- State 1: No Auth Configured -->
                <StackPanel x:Name="NoAuthPanel"
                            Visibility="{Binding ShowNoAuthPanel, Converter={StaticResource BoolToVis}}">

                    <!-- Config Card -->
                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="4"
                            Padding="16"
                            Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_NoAuthTitle}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_NoAuthMessage}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextWrapping="Wrap"
                                       Opacity="0.85"/>
                        </StackPanel>
                    </Border>

                    <!-- Open Settings Button -->
                    <Button Content="{DynamicResource LOCPlayAch_Landing_OpenSettings}"
                            Command="{Binding OpenPluginSettingsCommand}"
                            HorizontalAlignment="Center"
                            Padding="16,6"
                            MinWidth="150"
                            Margin="0,10,0,12"/>

                </StackPanel>

                <!-- State 2: Has Auth, No Cache (Needs Refresh) -->
                <StackPanel x:Name="NeedsRefreshPanel"
                            Visibility="{Binding ShowNeedsRefreshPanel, Converter={StaticResource BoolToVis}}">

                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="4"
                            Padding="16"
                            Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_Status_ReadyToRefresh}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_NeedsRefreshMessage}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextWrapping="Wrap"
                                       Opacity="0.85"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <ComboBox x:Name="RefreshModeComboBox"
                                          ItemsSource="{Binding RefreshModes}"
                                          DisplayMemberPath="ShortDisplayName"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding SelectedRefreshMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="110"
                                          Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                          VerticalContentAlignment="Center"/>
                                <Button Content="{Binding RefreshActionButtonText}"
                                        Command="{Binding BeginRefreshCommand}"
                                        Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                        MinWidth="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Ready indicator -->
                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="4"
                            Padding="16"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="&#xE8FB;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       Foreground="{DynamicResource PlayAch.Brush.Glyph}"
                                       HorizontalAlignment="Center"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_Status_ReadyToRefresh}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextWrapping="Wrap"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- State 3: Has Auth + Cache (Existing User) -->
                <StackPanel x:Name="HasDataPanel"
                            Visibility="{Binding ShowHasDataPanel, Converter={StaticResource BoolToVis}}">

                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="4"
                            Padding="16"
                            Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_HasDataTitle}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_HasDataMessage}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextWrapping="Wrap"
                                       Opacity="0.85"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                            <Button Content="{DynamicResource LOCPlayAch_Common_Continue}"
                                    Command="{Binding ContinueCommand}"
                                    HorizontalAlignment="Center"
                                    Padding="16,6"
                                    MinWidth="110"/>
                        </StackPanel>
                    </Border>

                    <!-- Existing data indicator -->
                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="4"
                            Padding="16"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}">
                                <Image Source="{DynamicResource BadgeCompletedGame}"
                                       Width="20"
                                       Height="20"
                                       Margin="1"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="{DynamicResource BadgeRarityUltraRare}"
                                       Width="20"
                                       Height="20"
                                       Margin="1"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Image Source="{DynamicResource BadgeRarityRare}"
                                       Width="20"
                                       Height="20"
                                       Margin="1"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Landing_HasDataFound}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextWrapping="Wrap"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>

            <!-- Theme Migration Section - Always Visible -->
            <StackPanel Margin="0,16,0,0">
                <!-- Section Header -->
                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Title}"
                           FontSize="{DynamicResource PlayAch.FontSize.Body}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                           Margin="0,0,0,10"/>

                <!-- Migrate Theme Card -->
                <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                        CornerRadius="4"
                        Padding="16"
                        Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        BorderThickness="{StaticResource PlayAch.Thickness.Border}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_MigrateLabel}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   TextWrapping="Wrap"
                                   Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                        <!-- Theme Dropdown -->
                        <ComboBox x:Name="MigrationThemeComboBox"
                                  ItemsSource="{Binding AvailableThemes}"
                                  DisplayMemberPath="BestDisplayName"
                                  SelectedValuePath="Path"
                                  SelectedValue="{Binding SelectedThemePath}"
                                  Width="300"
                                  HorizontalAlignment="Center"
                                  Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                  VerticalContentAlignment="Center"
                                  IsEnabled="{Binding HasThemesToMigrate}"/>

                        <!-- Migration Buttons -->
                        <StackPanel x:Name="ThemeMigrationPresetButtons"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationLimited}"
                                    Command="{Binding MigrateThemeLimitedCommand}"
                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                    MinWidth="100"
                                    Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                    IsEnabled="{Binding HasThemesToMigrate}"
                                    ToolTipService.ShowOnDisabled="True">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="250"/>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationFull}"
                                    x:Name="ThemeMigrationFullButton"
                                    Command="{Binding MigrateThemeFullCommand}"
                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                    MinWidth="100"
                                    IsEnabled="{Binding HasThemesToMigrate}"
                                    ToolTipService.ShowOnDisabled="True">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="250"/>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <!-- Custom Migration Expander -->
                        <Border Background="{StaticResource PlayAch.Brush.Overlay.Shade.12}"
                                x:Name="ThemeMigrationCustomContainer"
                                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                CornerRadius="{StaticResource PlayAch.Radius.Card}"
                                Margin="0,16,0,0"
                                Padding="{StaticResource PlayAch.Thickness.None}"
                                IsEnabled="{Binding HasThemesToMigrate}">
                            <Expander x:Name="ThemeMigrationCustomExpander"
                                      IsExpanded="False"
                                      Expanded="ThemeMigrationCustomExpander_Expanded"
                                      Collapsed="ThemeMigrationCustomExpander_Collapsed"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <Expander.Header>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Custom}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               FontWeight="SemiBold"
                                               Margin="-4,8,0,8"/>
                                </Expander.Header>

                                <StackPanel Margin="12,0,12,12">
                                    <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Left"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                               MaxWidth="520"/>

                                    <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                          HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="176"/>
                                            <ColumnDefinition Width="108"/>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="108"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="1"
                                                Content="{DynamicResource LOCPlayAch_ThemeMigration_AllLegacy}"
                                                Command="{Binding SetAllMigrationLegacyCommand}"
                                                Style="{StaticResource MigrationChoiceButtonBaseStyle}"
                                                Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <Button Grid.Column="3"
                                                Content="{DynamicResource LOCPlayAch_ThemeMigration_AllModern}"
                                                Command="{Binding SetAllMigrationModernCommand}"
                                                Style="{StaticResource MigrationChoiceButtonBaseStyle}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding ThemeMigrationCustomOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10"
                                                      HorizontalAlignment="Left">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="176"/>
                                                        <ColumnDefinition Width="108"/>
                                                        <ColumnDefinition Width="54"/>
                                                        <ColumnDefinition Width="108"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                               VerticalAlignment="Center"
                                                               Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>

                                                    <Button Grid.Column="1"
                                                            Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeLegacy}"
                                                            Style="{StaticResource MigrationChoiceLegacyButtonStyle}"
                                                            Command="{Binding DataContext.SetMigrationRowLegacyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>

                                                    <ToggleButton Grid.Column="2"
                                                                  Style="{StaticResource MigrationSwitchToggleStyle}"
                                                                  IsChecked="{Binding IsModern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <Button Grid.Column="3"
                                                            Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeModern}"
                                                            Style="{StaticResource MigrationChoiceModernButtonStyle}"
                                                            Command="{Binding DataContext.SetMigrationRowModernCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationCustom}"
                                            Command="{Binding MigrateThemeCustomCommand}"
                                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                            Margin="{StaticResource PlayAch.Thickness.Top.Compact}"
                                            MinWidth="100"
                                            HorizontalAlignment="Right"
                                            IsEnabled="{Binding HasThemesToMigrate}"/>
                                </StackPanel>
                            </Expander>
                        </Border>

                        <!-- No themes message -->
                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoThemesMessage}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                   Visibility="{Binding ShowNoThemesMessage, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- Revert Theme Card -->
                <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                        CornerRadius="4"
                        Padding="16"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        BorderThickness="{StaticResource PlayAch.Thickness.Border}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Revert}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                        <!-- Revertable Theme Dropdown and Revert Button -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <ComboBox x:Name="RevertThemeComboBox"
                                      ItemsSource="{Binding RevertableThemes}"
                                      DisplayMemberPath="BestDisplayName"
                                      SelectedValuePath="Path"
                                      SelectedValue="{Binding SelectedRevertThemePath}"
                                      Width="200"
                                      Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                      VerticalContentAlignment="Center"
                                      IsEnabled="{Binding HasRevertableThemes}"/>
                            <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_RevertButton}"
                                    Command="{Binding RevertThemeCommand}"
                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                    MinWidth="100"
                                    IsEnabled="{Binding HasRevertableThemes}"/>
                        </StackPanel>

                        <!-- No revertable themes message -->
                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoRevertableThemes}"
                                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                   Visibility="{Binding ShowNoRevertableThemesMessage, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- End constrained content container -->
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>


