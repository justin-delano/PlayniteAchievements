<UserControl x:Class="PlayniteAchievements.Views.ManageAchievementsOverridesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility" />
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12" />
            </Style>
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_ExclusionHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_ExclusionHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding ExclusionStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0" />
                    <Button Content="{Binding ExclusionActionText}"
                            Command="{Binding ToggleExclusionCommand}"
                            Padding="12,6"
                            MinWidth="190"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_SummaryExclusionHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_SummaryExclusionHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding SummaryExclusionStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0" />
                    <Button Content="{Binding SummaryExclusionActionText}"
                            Command="{Binding ToggleSummaryExclusionCommand}"
                            Padding="12,6"
                            MinWidth="190"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_LockedIconsHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_LockedIconsHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding SeparateLockedIconsStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <CheckBox Content="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_LockedIconsCheckbox}"
                              IsChecked="{Binding UseSeparateLockedIconsOverride}"
                              FontWeight="SemiBold"
                              Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_ProviderHeader}"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Overrides_ProviderHint}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding ProviderOverrideStatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ProviderOverrideOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="ProviderKey"
                                  SelectedValue="{Binding SelectedProviderOverrideKey, Mode=TwoWay}"
                                  Padding="8,4" />
                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_Button_Apply}"
                                Command="{Binding ApplyProviderOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                Command="{Binding ClearProviderOverrideCommand}"
                                Padding="12,6"
                                Margin="8,0,0,0" />
                    </Grid>

                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding IsProviderOverrideProviderSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ProviderOverrideInputLabel}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold" />
                        <TextBox Text="{Binding ProviderOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 Width="300"
                                 HorizontalAlignment="Left"
                                 Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
