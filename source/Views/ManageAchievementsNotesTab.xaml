<UserControl x:Class="PlayniteAchievements.Views.ManageAchievementsNotesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:ManageAchievementsNotesViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/ManageAchievementsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ManageAchievementsHeaderCardStyle}">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Notes_Header}"
                           Style="{StaticResource ManageAchievementsHeaderTitleStyle}" />
                <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_Notes_Hint}"
                           Style="{StaticResource ManageAchievementsHeaderHintStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Style="{StaticResource ManageAchievementsToolbarRowStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="170" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchTextBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ManageAchievementsSearchTextBoxStyle}" />
                <TextBlock Text="{DynamicResource LOCPlayAch_Common_FilterAchievementsPlaceholder}"
                           Style="{StaticResource ManageAchievementsSearchPlaceholderTextStyle}"/>
                <Button x:Name="ClearSearchButton"
                        Tag="{Binding SearchText}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource ClearSearchButtonStyle}" />
            </Grid>

            <ComboBox x:Name="StateFilterComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding NoteOptions}"
                      SelectedItem="{Binding SelectedNoteOption, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      Height="{StaticResource PlayAch.Size.Control.Height}"
                      Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                      VerticalAlignment="Center" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource LOCPlayAch_Common_NoCachedAchievementsForGame}"
                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                   Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   Margin="0"
                   Visibility="{Binding HasAchievements, Converter={StaticResource InverseBoolToVis}}" />

        <DataGrid x:Name="NotesDataGrid"
                  Grid.Row="2"
                  Margin="0,2,0,0"
                  ItemsSource="{Binding AchievementRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
                  BorderThickness="0"
                  Background="{DynamicResource PlayAch.Brush.Grid.Background}"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  RowHeight="104"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ColumnHeaderStyle="{StaticResource ManageAchievementsColumnHeaderStyle}"
                  helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
                  helpers:DataGridAlignmentBehavior.IsEnabled="True"
                  Tag="ControllerCellFocus"
                  PreviewMouseLeftButtonDown="NotesDataGrid_PreviewMouseLeftButtonDown">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource ManageAchievementsControllerCellStyle}" />
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource ManageAchievementsDataGridRowStyle}">
                    <Setter Property="MinHeight" Value="68" />
                    <Setter Property="ClipToBounds" Value="True" />
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="36" MinWidth="36" MaxWidth="36" CanUserResize="False"
                                        CellStyle="{StaticResource ManageAchievementsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementStatusTemplate}" />

                <DataGridTemplateColumn Width="72" MinWidth="44" MaxWidth="160" CanUserResize="True"
                                        CellStyle="{StaticResource ManageAchievementsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementIconTemplate}" />

                <DataGridTemplateColumn Width="2*" Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                        CellTemplate="{StaticResource ManageAchievementInfoTemplate}" />

                <DataGridTemplateColumn Width="2*" Header="{DynamicResource LOCPlayAch_ManageAchievements_Notes_Note}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Margin="8,8">

                                <!-- No note: centered in the cell -->
                                <TextBlock Text="{Binding NoteStatusText}"
                                        Foreground="{DynamicResource PlayAch.Brush.Text}"
                                        FontWeight="SemiBold"
                                        Opacity="0.85"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        TextAlignment="Center"
                                        Visibility="{Binding HasAchievementNote, Converter={StaticResource InverseBoolToVis}}" />

                                <!-- Has note: top-left aligned -->
                                <StackPanel HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding HasAchievementNote, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding NoteStatusText}"
                                            Foreground="{DynamicResource PlayAch.Brush.Text}"
                                            FontWeight="SemiBold"
                                            Opacity="0.85"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            TextAlignment="Left" />

                                    <Border Background="{StaticResource PlayAch.Brush.Overlay.Shade.08}"
                                            BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                            BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                            CornerRadius="4"
                                            Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                            Padding="6"
                                            MaxHeight="70"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Stretch">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                    HorizontalScrollBarVisibility="Disabled"
                                                    PanningMode="VerticalOnly">
                                            <TextBlock helpers:AchievementNoteInlineFormatter.FormattedText="{Binding AchievementNote}"
                                                    Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                    Opacity="0.68"
                                                    TextWrapping="Wrap"
                                                    TextAlignment="Left"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Top"
                                                    Padding="0,0,8,0" />
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="142"
                                        MinWidth="132"
                                        Header="{DynamicResource LOCPlayAch_Common_Actions}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="{DynamicResource LOCPlayAch_Common_View}"
                                        Click="ViewButton_Click"
                                        IsEnabled="{Binding HasAchievementNote}"
                                        Padding="9,4"
                                        Margin="{StaticResource PlayAch.Thickness.Right.Compact}" />
                                <Button Content="{DynamicResource LOCPlayAch_Common_Edit}"
                                        Click="EditButton_Click"
                                        Padding="9,4" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
