<UserControl x:Class="PlayniteAchievements.Views.GameOptionsCapstonesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="760">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Checkbox style for marker selection -->
            <Style x:Key="MarkerCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent">
                                <Ellipse x:Name="OuterEllipse"
                                         Width="20" Height="20"
                                         Stroke="{DynamicResource TextBrush}"
                                         StrokeThickness="2"
                                         Fill="Transparent"/>
                                <Ellipse x:Name="InnerCheck"
                                         Width="12" Height="12"
                                         Fill="{DynamicResource GlyphBrush}"
                                         Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="InnerCheck" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="OuterEllipse" Property="Stroke" Value="{DynamicResource GlyphBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterEllipse" Property="StrokeThickness" Value="3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_Capstone_Subtitle}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding CurrentMarkerText}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,8,0,0"
                           FontStyle="Italic"
                           Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1"
                Padding="0"
                Margin="0,0,0,12">
            <Grid>
                <Grid>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Capstone_SearchPlaceholder}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.5"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Tag="{Binding SearchText}"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource ClearSearchButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>

        <DataGrid x:Name="AchievementsDataGrid"
                  Grid.Row="2"
                  Margin="0"
                  ItemsSource="{Binding AchievementOptions}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowBackground="Transparent"
                  BorderThickness="0"
                  Background="Transparent"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="True"
                  EnableRowVirtualization="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  Sorting="DataGrid_Sorting">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource AchievementCellStyle}"/>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource AchievementRowStyle}">
                    <Setter Property="MinHeight" Value="76"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Marker Selection Checkbox -->
                <DataGridTemplateColumn Width="44" MinWidth="44" MaxWidth="44" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Style="{StaticResource MarkerCheckBoxStyle}"
                                      IsChecked="{Binding IsCurrentMarker, Mode=OneWay}"
                                      Click="MarkerCheckBox_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Current capstone badge -->
                <DataGridTemplateColumn Width="34" MinWidth="34" MaxWidth="34" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{StaticResource BadgeCompletedGame}"
                                   Style="{StaticResource RarityIcon}"
                                   Effect="{StaticResource BadgeShadow}"
                                   Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsCurrentMarker, Converter={StaticResource BoolToVis}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status: Checkmark (unlocked) or Padlock (locked) -->
                <DataGridTemplateColumn Width="36" MinWidth="36" MaxWidth="36" CanUserSort="False" CanUserResize="False"
                                        CellTemplate="{StaticResource AchievementStatusTemplate}"/>

                <DataGridTemplateColumn Width="78" MinWidth="78" MaxWidth="78" CanUserSort="False" CanUserResize="False"
                                        CellTemplate="{StaticResource AchievementIconTemplate}"/>

                <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                        CanUserSort="False"
                                        CellTemplate="{StaticResource AchievementInfoTemplate}"/>

                <!-- Rarity -->
                <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Rarity}" SortMemberPath="RaritySortValue" SortDirection="Ascending"
                                        CellTemplate="{StaticResource AchievementRarityTemplate}"/>

                <!-- Points -->
                <DataGridTemplateColumn Width="72" Header="{DynamicResource LOCPlayAch_Column_Points}" SortMemberPath="Points"
                                        CellTemplate="{StaticResource AchievementPointsTemplate}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
