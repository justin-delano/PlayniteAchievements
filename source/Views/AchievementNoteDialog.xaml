<UserControl x:Class="PlayniteAchievements.Views.AchievementNoteDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="620"
             FocusManager.FocusedElement="{Binding ElementName=NoteTextBox}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="AchievementIconBorder"
                    Grid.Column="0"
                    Width="48"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource NormalBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    ClipToBounds="True">
                <Image x:Name="AchievementIconImage"
                       Width="46"
                       Height="46"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       helpers:AsyncImage.DecodePixel="96" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock x:Name="AchievementTitleTextBlock"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="AchievementApiNameTextBlock"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.6"
                           FontSize="{DynamicResource FontSizeSmall}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <ScrollViewer x:Name="ViewScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <TextBlock x:Name="ViewTextBlock"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"
                       Padding="0,0,8,0" />
        </ScrollViewer>

        <Grid x:Name="EditorPanel"
              Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" MinHeight="150" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="110" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <Button x:Name="BoldButton"
                        Content="B"
                        FontWeight="Bold"
                        Width="34"
                        Height="30"
                        Padding="0"
                        Margin="0,0,6,0"
                        ToolTip="{DynamicResource LOCPlayAch_NotesDialog_Bold}"
                        Click="BoldButton_Click" />
                <Button x:Name="ItalicButton"
                        Content="I"
                        FontStyle="Italic"
                        Width="34"
                        Height="30"
                        Padding="0"
                        Margin="0,0,6,0"
                        ToolTip="{DynamicResource LOCPlayAch_NotesDialog_Italic}"
                        Click="ItalicButton_Click" />
                <Button x:Name="UnderlineButton"
                        Width="34"
                        Height="30"
                        Padding="0"
                        ToolTip="{DynamicResource LOCPlayAch_NotesDialog_Underline}"
                        Click="UnderlineButton_Click">
                    <TextBlock Text="U" TextDecorations="Underline" />
                </Button>
            </StackPanel>

            <TextBox x:Name="NoteTextBox"
                     Grid.Row="1"
                     Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     Padding="8"
                     KeyDown="NoteTextBox_KeyDown" />

            <TextBlock x:Name="CharacterCountTextBlock"
                       Grid.Row="2"
                       Foreground="{DynamicResource TextBrush}"
                       Opacity="0.65"
                       FontSize="{DynamicResource FontSizeSmall}"
                       HorizontalAlignment="Right"
                       Margin="0,6,0,10" />

            <TextBlock Grid.Row="3"
                       Text="{DynamicResource LOCPlayAch_NotesDialog_Preview}"
                       Foreground="{DynamicResource TextBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />

            <Border Grid.Row="4"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource NormalBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10"
                    MinHeight="86"
                    ClipToBounds="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly">
                    <TextBlock x:Name="PreviewTextBlock"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               Padding="0,0,8,0" />
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="SaveButton"
                    Content="{DynamicResource LOCPlayAch_Button_Save}"
                    Click="SaveButton_Click"
                    Padding="12,6"
                    MinWidth="82"
                    Margin="0,0,8,0"
                    IsDefault="True" />
            <Button x:Name="ClearButton"
                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                    Click="ClearButton_Click"
                    Padding="12,6"
                    MinWidth="82"
                    Margin="0,0,8,0" />
            <Button x:Name="CancelButton"
                    Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                    Click="CancelButton_Click"
                    Padding="12,6"
                    MinWidth="82"
                    IsCancel="True" />
            <Button x:Name="CloseButton"
                    Content="{DynamicResource LOCPlayAch_Button_Ok}"
                    Click="CancelButton_Click"
                    Padding="12,6"
                    MinWidth="82"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</UserControl>
