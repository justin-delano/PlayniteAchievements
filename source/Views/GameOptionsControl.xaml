<UserControl x:Class="PlayniteAchievements.Views.GameOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:PlayniteAchievements.Views"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1050">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:EnumToBoolConverter x:Key="EnumToBool" />
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility" />
            <converters:BooleanConverter x:Key="InverseBoolToVis" Mode="InvertedToVisibility" />
            <converters:DefaultGameImageConverter x:Key="DefaultGameImage" />

            <Style x:Key="NavTabRadioStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="BorderRoot"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="BorderRoot" Property="Background" Value="#1FFFFFFF" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BorderRoot" Property="Background" Value="#14FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="245" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{DynamicResource LOCPlayAch_Menu_GameOptions}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="{DynamicResource FontSizeLarge}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding GameName}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.75"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="2"
                        Height="150"
                        CornerRadius="6"
                        ClipToBounds="True"
                        Background="Transparent">
                    <Image Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           helpers:AsyncImage.Uri="{Binding GameImagePath, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"
                           helpers:AsyncImage.DecodePixel="320" />
                </Border>

                <TextBlock Grid.Row="4"
                           Text="{DynamicResource LOCPlayAch_GameOptions_Tabs}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.65"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <StackPanel Grid.Row="5">
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_Overview}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Overview}" />
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_Overrides}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Overrides}" />
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_Capstones}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Capstones}" />
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_ManualTracking}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=ManualTracking}" />
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_AchievementOrder}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=AchievementOrder}" />
                    <RadioButton Content="{DynamicResource LOCPlayAch_GameOptions_Tab_Category}"
                                 Style="{StaticResource NavTabRadioStyle}"
                                 IsChecked="{Binding SelectedTab, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Category}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <views:GameOptionsOverviewTab>
                    <views:GameOptionsOverviewTab.Style>
                        <Style TargetType="{x:Type views:GameOptionsOverviewTab}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Overview">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:GameOptionsOverviewTab.Style>
                </views:GameOptionsOverviewTab>

                <views:GameOptionsOverridesTab>
                    <views:GameOptionsOverridesTab.Style>
                        <Style TargetType="{x:Type views:GameOptionsOverridesTab}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Overrides">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:GameOptionsOverridesTab.Style>
                </views:GameOptionsOverridesTab>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Capstones">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <TextBlock Text="{Binding CapstoneEmptyMessage}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.78"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top"
                               Margin="4"
                               Visibility="{Binding HasCapstoneData, Converter={StaticResource InverseBoolToVis}}" />

                    <ContentControl x:Name="CapstoneHost"
                                    Visibility="{Binding HasCapstoneData, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="ManualTracking">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ContentControl x:Name="ManualHost" />
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="AchievementOrder">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ContentControl x:Name="AchievementOrderHost" />
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="Category">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ContentControl x:Name="CategoryHost" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
