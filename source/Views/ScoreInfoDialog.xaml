<UserControl x:Class="PlayniteAchievements.Views.ScoreInfoDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             MinWidth="640"
             MinHeight="650"
             d:DesignHeight="700"
             d:DesignWidth="680"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ScoreInfoTierIconStyle" TargetType="Image" BasedOn="{StaticResource RarityIcon}">
                <Setter Property="Width" Value="34"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Effect" Value="{StaticResource BadgeShadow}"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ScoreInfoTierArrowStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
                <Setter Property="Text" Value="&#xE76C;"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Opacity" Value="0.58"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Margin" Value="0,22,0,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource LOCPlayAch_Score_Info_Title}"
                   Style="{DynamicResource BaseTextBlockStyle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_CollectionTitle}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_CollectionBody}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.82"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="6"
                        Padding="14"
                        Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_PrestigeTitle}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_PrestigeBody}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.82"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="6"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_LevelsTitle}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,4,0,18"
                              MinHeight="116">
                            <Border Height="2"
                                    Margin="48,28,48,0"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource NormalBorderBrush}"
                                    Opacity="0.55"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center"
                                            MinWidth="88"
                                            Margin="0,0,0,4">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="28"
                                                Background="#12FFFFFF"
                                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                                BorderThickness="1"/>
                                        <Image Source="{StaticResource BadgeBronzeTriangle}"
                                               Style="{StaticResource ScoreInfoTierIconStyle}"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Trophy_Bronze}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="V-I"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextAlignment="Center"
                                               LineHeight="14"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource ScoreInfoTierArrowStyle}"/>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center"
                                            MinWidth="88"
                                            Margin="0,0,0,4">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="28"
                                                Background="#12FFFFFF"
                                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                                BorderThickness="1"/>
                                        <Image Source="{StaticResource BadgeSilverSquare}"
                                               Style="{StaticResource ScoreInfoTierIconStyle}"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Trophy_Silver}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="V-I"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextAlignment="Center"
                                               LineHeight="14"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3"
                                           Style="{StaticResource ScoreInfoTierArrowStyle}"/>

                                <StackPanel Grid.Column="4"
                                            HorizontalAlignment="Center"
                                            MinWidth="88"
                                            Margin="0,0,0,4">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="28"
                                                Background="#12FFFFFF"
                                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                                BorderThickness="1"/>
                                        <Image Source="{StaticResource BadgeGoldPentagon}"
                                               Style="{StaticResource ScoreInfoTierIconStyle}"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Trophy_Gold}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="V-I"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextAlignment="Center"
                                               LineHeight="14"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="5"
                                           Style="{StaticResource ScoreInfoTierArrowStyle}"/>

                                <StackPanel Grid.Column="6"
                                            HorizontalAlignment="Center"
                                            MinWidth="88"
                                            Margin="0,0,0,4">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="28"
                                                Background="#12FFFFFF"
                                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                                BorderThickness="1"/>
                                        <Image Source="{StaticResource BadgePlatinumHexagon}"
                                               Style="{StaticResource ScoreInfoTierIconStyle}"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Trophy_Platinum}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="V-I"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextAlignment="Center"
                                               LineHeight="14"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="7"
                                           Style="{StaticResource ScoreInfoTierArrowStyle}"/>

                                <StackPanel Grid.Column="8"
                                            HorizontalAlignment="Center"
                                            MinWidth="88"
                                            Margin="0,0,0,4">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="28"
                                                Background="#12FFFFFF"
                                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                                BorderThickness="1"/>
                                        <Image Source="{StaticResource BadgeCompletedGame}"
                                               Style="{StaticResource ScoreInfoTierIconStyle}"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Score_Tier_Master}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="V-I"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextAlignment="Center"
                                               LineHeight="14"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Score_Info_LevelsBody}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.82"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{DynamicResource LOCPlayAch_Button_Ok}"
                    Click="CloseButton_Click"
                    Padding="14,6"
                    MinWidth="84"
                    IsDefault="True"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</UserControl>
