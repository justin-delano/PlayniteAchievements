<Window x:Class="PlayniteAchievements.Views.AlphaColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick color"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,12,12"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFFFFFFF">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,12,12"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFE5E5E5">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,6,6"/>
                                <RectangleGeometry Rect="6,6,6,6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Border Padding="16"
            Background="{DynamicResource PlayAch.Brush.Dialog.Background}"
            BorderBrush="{DynamicResource PlayAch.Brush.Dialog.Border}"
            BorderThickness="1">
        <StackPanel>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="ColorSpace"
                        Grid.Column="0"
                        Height="150"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        Cursor="Cross"
                        MouseLeftButtonDown="ColorSpace_MouseLeftButtonDown"
                        MouseLeftButtonUp="ColorSpace_MouseLeftButtonUp"
                        MouseMove="ColorSpace_MouseMove"
                        SizeChanged="ColorSpace_SizeChanged">
                    <Grid>
                        <Border x:Name="HueSurface"/>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#FF000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Canvas>
                            <Ellipse x:Name="ColorSpaceMarker"
                                     Width="12"
                                     Height="12"
                                     Stroke="White"
                                     StrokeThickness="2"
                                     Fill="Transparent"
                                     IsHitTestVisible="False">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.8" BlurRadius="2" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>
                </Border>

                <Slider x:Name="HueSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="360"
                        Orientation="Vertical"
                        Margin="12,0,0,0"
                        ValueChanged="HueSlider_ValueChanged"/>
            </Grid>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="72"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        BorderThickness="1"
                        Background="{StaticResource CheckerBrush}">
                    <Border x:Name="PreviewSwatch"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Hex"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="HexTextBox"
                             MinWidth="180"
                             TextChanged="HexTextBox_TextChanged"
                             KeyDown="HexTextBox_KeyDown"/>
                    <TextBlock x:Name="ValidationText"
                               Foreground="{DynamicResource PlayAch.Brush.Text.Secondary}"
                               FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="58"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="A" Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Center"/>
                <Slider x:Name="AlphaSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ChannelSlider_ValueChanged"/>
                <TextBox x:Name="AlphaTextBox" Grid.Row="0" Grid.Column="2" Margin="8,0,0,6" TextAlignment="Right" LostFocus="ChannelTextBox_LostFocus" KeyDown="ChannelTextBox_KeyDown"/>

                <TextBlock Grid.Row="1" Text="R" Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Center"/>
                <Slider x:Name="RedSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ChannelSlider_ValueChanged"/>
                <TextBox x:Name="RedTextBox" Grid.Row="1" Grid.Column="2" Margin="8,0,0,6" TextAlignment="Right" LostFocus="ChannelTextBox_LostFocus" KeyDown="ChannelTextBox_KeyDown"/>

                <TextBlock Grid.Row="2" Text="G" Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Center"/>
                <Slider x:Name="GreenSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ChannelSlider_ValueChanged"/>
                <TextBox x:Name="GreenTextBox" Grid.Row="2" Grid.Column="2" Margin="8,0,0,6" TextAlignment="Right" LostFocus="ChannelTextBox_LostFocus" KeyDown="ChannelTextBox_KeyDown"/>

                <TextBlock Grid.Row="3" Text="B" Foreground="{DynamicResource PlayAch.Brush.Text}" VerticalAlignment="Center"/>
                <Slider x:Name="BlueSlider" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="ChannelSlider_ValueChanged"/>
                <TextBox x:Name="BlueTextBox" Grid.Row="3" Grid.Column="2" Margin="8,0,0,0" TextAlignment="Right" LostFocus="ChannelTextBox_LostFocus" KeyDown="ChannelTextBox_KeyDown"/>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        MinWidth="76"
                        Margin="0,0,8,0"
                        IsCancel="True"/>
                <Button Content="OK"
                        MinWidth="76"
                        IsDefault="True"
                        Click="OkButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
