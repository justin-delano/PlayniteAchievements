<UserControl x:Class="PlayniteAchievements.Views.GameOptionsLocalOverridesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility" />
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12" />
            </Style>
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,12,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalSteamAppIdHeader}"
                           Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalSteamAppIdHint}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding LocalSteamAppIdStatusText}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding LocalSteamAppIdOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" />
                    <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Apply}"
                            Command="{Binding ApplyLocalSteamAppIdOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                    <Button Grid.Column="2"
                            Content="{DynamicResource LOCPlayAch_Button_Clear}"
                            Command="{Binding ClearLocalSteamAppIdOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalSteamUserHeader}"
                           Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalSteamUserHint}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding LocalSteamAppCacheUserStatusText}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailableLocalSteamAppCacheUsers}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="UserId"
                              SelectedValue="{Binding LocalSteamAppCacheUserOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              MinHeight="30" />
                    <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Apply}"
                            Command="{Binding ApplyLocalSteamAppCacheUserOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                    <Button Grid.Column="2"
                            Content="{DynamicResource LOCPlayAch_Button_Clear}"
                            Command="{Binding ClearLocalSteamAppCacheUserOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalFolderHeader}"
                           Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Overrides_LocalFolderHint}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock Text="{Binding LocalFolderStatusText}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding LocalFolderCandidatesSummary}"
                           Visibility="{Binding HasAmbiguousLocalFolders, Converter={StaticResource BoolToVis}}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.65"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="420" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding LocalFolderOverrideInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" />
                    <Button Grid.Column="1"
                            Content="{DynamicResource LOCPlayAch_Button_Browse}"
                            Command="{Binding BrowseLocalFolderOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                    <Button Grid.Column="2"
                            Content="{DynamicResource LOCPlayAch_Button_Apply}"
                            Command="{Binding ApplyLocalFolderOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                    <Button Grid.Column="3"
                            Content="{DynamicResource LOCPlayAch_Button_Clear}"
                            Command="{Binding ClearLocalFolderOverrideCommand}"
                            Padding="12,6"
                            Margin="8,0,0,0" />
                </Grid>

            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>