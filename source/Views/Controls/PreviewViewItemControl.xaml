<UserControl x:Class="PlayniteAchievements.Views.Controls.PreviewViewItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignHeight="24" d:DesignWidth="200">

    <Grid x:Name="PART_GridContainer">
        <!-- Simple label format (when ShowProgressBar=False) -->
        <TextBlock x:Name="LabelMode"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextBrush}"
                   FontSize="{DynamicResource FontSize}"
                   Visibility="{Binding ShowProgressBar, ElementName=Root, Converter={StaticResource InvertedBooleanToVisibility}}">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0}/{1}">
                    <Binding Path="UnlockedCount" ElementName="Root" FallbackValue="0" />
                    <Binding Path="AchievementCount" ElementName="Root" FallbackValue="0" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Progress bar mode (when ShowProgressBar=True) -->
        <Grid x:Name="ProgressBarMode">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowProgressBar, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Value="{Binding UnlockedCount, ElementName=Root, Mode=OneWay, FallbackValue=0}"
                         Maximum="{Binding AchievementCount, ElementName=Root, Mode=OneWay, FallbackValue=100}"
                         MinWidth="40"
                         Height="16"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource HighlightGlyphBrush}"
                         Background="{DynamicResource ControlBackgroundBrush}"
                         BorderBrush="{DynamicResource NormalBorderBrush}"/>

            <TextBlock Grid.Column="0"
                       Grid.ColumnSpan="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="{DynamicResource FontSizeSmall}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}/{1}">
                        <Binding Path="UnlockedCount" ElementName="Root" FallbackValue="0" />
                        <Binding Path="AchievementCount" ElementName="Root" FallbackValue="0" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
