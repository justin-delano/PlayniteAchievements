<UserControl x:Class="PlayniteAchievements.Views.Controls.AchievementCompactItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels.Items"
             xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="48"
             d:DataContext="{d:DesignInstance vm:AchievementDisplayItem}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Cursor="Hand">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:RarityPercentToTextConverter x:Key="RarityPercentToTextConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
          Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
          ClipToBounds="False"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">
        <Grid.ToolTip>
            <ToolTip x:Name="ItemToolTip"
                     MaxWidth="300"
                     Closed="ItemToolTip_OnClosed">
                <ToolTip.Content>
                    <StackPanel>
                        <!-- Title with hidden indicator -->
                        <TextBlock FontWeight="SemiBold"
                                   TextWrapping="Wrap">
                            <Run Text="{Binding DisplayNameResolved, Mode=OneWay}"/>
                            <Run Text="{Binding HiddenTitleSuffix, Mode=OneWay}"
                                 FontStyle="Italic"
                                 FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                 Foreground="{DynamicResource PlayAch.Brush.Text.Secondary}"/>
                        </TextBlock>

                        <!-- Description -->
                        <TextBlock Text="{Binding DescriptionResolved, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                   Opacity="{StaticResource PlayAch.Opacity.Secondary}"/>

                        <!-- Game name (if available) -->
                        <TextBlock Text="{Binding GameName, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                   FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                   Opacity="{StaticResource PlayAch.Opacity.Muted}"/>

                        <!-- Unlock date -->
                        <TextBlock Text="{Binding UnlockTimeText, Mode=OneWay}"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                   FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                   Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                   Visibility="{Binding Unlocked, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Rarity info (only when percentage data is available) -->
                        <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                    Visibility="{Binding HasRarityPercent, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding RarityDetailText, Mode=OneWay}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="{StaticResource PlayAch.Opacity.Subtle}"/>
                        </StackPanel>

                        <!-- Progress info (for partial progress achievements) -->
                        <StackPanel Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                    Visibility="{Binding HasProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ProgressText, Mode=OneWay}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="{StaticResource PlayAch.Opacity.Subtle}"/>
                            <TextBlock Text=" ("
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="{StaticResource PlayAch.Opacity.Placeholder}"/>
                            <TextBlock Text="{Binding ProgressPercent, Mode=OneWay, StringFormat={}{0:F0}%}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="{StaticResource PlayAch.Opacity.Subtle}"/>
                            <TextBlock Text=")"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="{StaticResource PlayAch.Opacity.Placeholder}"/>
                        </StackPanel>

                        <!-- Click to reveal hint for hidden achievements -->
                        <TextBlock Text="{DynamicResource LOCPlayAch_Achievements_ClickToReveal}"
                                   Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                                   FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                   FontStyle="Italic"
                                   Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                                   Visibility="{Binding CanReveal, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </ToolTip.Content>
            </ToolTip>
        </Grid.ToolTip>

        <!-- Achievement icon with glow effect - keep glow on a backing layer so the front icon stays sharp -->
        <Grid Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
              ClipToBounds="False"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Image Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   IsHitTestVisible="False"
                   helpers:AsyncImage.Uri="{Binding DisplayIcon, Mode=OneWay}"
                   helpers:AsyncImage.DecodePixel="256">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Effect" Value="{x:Null}"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Unlocked}" Value="True"/>
                                    <Condition Binding="{Binding ShowRarityGlow, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Effect" Value="{Binding Rarity, Converter={StaticResource CompactPercentToRarityGlow}}"/>
                            </MultiDataTrigger>
                            <!-- Hardcore achievements use a solid border instead of the soft glow. -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Unlocked}" Value="True"/>
                                    <Condition Binding="{Binding ShowRarityGlow, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}" Value="True"/>
                                    <Condition Binding="{Binding IsHardcore}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Effect" Value="{x:Null}"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <Image Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   helpers:AsyncImage.Uri="{Binding DisplayIcon, Mode=OneWay}"
                   helpers:AsyncImage.DecodePixel="256"/>

            <!-- Solid rarity border for Hardcore achievements (replaces the glow).
                 Negative margin draws the border just OUTSIDE the icon so it never shrinks it. -->
            <Border Margin="-3"
                    BorderThickness="3"
                    Background="Transparent"
                    IsHitTestVisible="False"
                    SnapsToDevicePixels="True"
                    BorderBrush="{Binding Rarity, Converter={StaticResource RarityToShineBrush}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Unlocked}" Value="True"/>
                                    <Condition Binding="{Binding ShowRarityGlow, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}" Value="True"/>
                                    <Condition Binding="{Binding IsHardcore}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </Grid>

        <!-- Rarity bar overlay at bottom - shows global unlock percentage -->
        <Grid VerticalAlignment="Bottom">
            <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasRarityPercent}" Value="True"/>
                                    <Condition Binding="{Binding ShowRarityBar}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                </Style>
            </Grid.Style>
            <ProgressBar Height="10"
                         Maximum="100"
                         Value="{Binding RarityPercentValue, Mode=OneWay}"
                         Background="{StaticResource PlayAch.Brush.Overlay.Shade.80}"
                         Foreground="{DynamicResource PlayAch.Brush.Accent}"
                         BorderThickness="0"/>
            <TextBlock Text="{Binding RarityPercentValue, Mode=OneWay, Converter={StaticResource RarityPercentToTextConverter}}"
                       Style="{StaticResource PlayAch.TextBlock.BaseStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="8"
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Grid>
    </Grid>
</UserControl>
