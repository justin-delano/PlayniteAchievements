<UserControl x:Class="PlayniteAchievements.Views.Controls.PreviewBarChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="280">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Mock time range buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Border Background="{DynamicResource HighlightGlyphBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,0">
                <TextBlock Text="7D" FontSize="{DynamicResource FontSizeTiny}" Foreground="White"/>
            </Border>
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,0" BorderBrush="{DynamicResource NormalBorderBrush}" BorderThickness="1">
                <TextBlock Text="14D" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}"/>
            </Border>
            <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,0" BorderBrush="{DynamicResource NormalBorderBrush}" BorderThickness="1">
                <TextBlock Text="1M" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}"/>
            </Border>
        </StackPanel>

        <!-- Mock bar chart -->
        <Grid Grid.Row="1" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Bars -->
            <Border Grid.Column="0" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="40" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="1" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="60" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="2" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="25" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="3" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="80" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="4" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="45" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="5" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="70" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>
            <Border Grid.Column="6" Grid.Row="0"
                    Background="{DynamicResource HighlightGlyphBrush}"
                    Height="35" VerticalAlignment="Bottom" CornerRadius="2,2,0,0" Margin="2,0"/>

            <!-- Labels -->
            <TextBlock Grid.Column="0" Grid.Row="1" Text="Mon" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="1" Grid.Row="1" Text="Tue" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="2" Grid.Row="1" Text="Wed" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="3" Grid.Row="1" Text="Thu" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="4" Grid.Row="1" Text="Fri" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="5" Grid.Row="1" Text="Sat" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
            <TextBlock Grid.Column="6" Grid.Row="1" Text="Sun" FontSize="{DynamicResource FontSizeTiny}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
        </Grid>
    </Grid>
</UserControl>
