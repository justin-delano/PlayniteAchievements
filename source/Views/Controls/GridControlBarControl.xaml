<UserControl x:Class="PlayniteAchievements.Views.Controls.GridControlBarControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementGridStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="GridControlBarBoolToVis"/>

            <!-- Toolbar mode toggle (category-summaries mode), rendered as a sliding switch with a
                 trailing label. The thumb slides right and the track fills with the accent when on. -->
            <Style x:Key="GridModeToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Background="Transparent">
                                <Border x:Name="Track"
                                        Width="34" Height="18"
                                        CornerRadius="9"
                                        Background="{DynamicResource PlayAch.Brush.Button.Background}"
                                        BorderBrush="{DynamicResource PlayAch.Brush.Button.Border}"
                                        BorderThickness="1">
                                    <Border x:Name="Thumb"
                                            Width="12" Height="12"
                                            CornerRadius="6"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="3,0,0,0"
                                            Background="{DynamicResource PlayAch.Brush.Text}"/>
                                </Border>
                                <TextBlock Text="{TemplateBinding Content}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                    <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ProviderFilterRowToggleStyle" TargetType="ToggleButton">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
                <Setter Property="FontFamily" Value="{DynamicResource PlayAch.FontFamily.Body}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="RowBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <Grid Margin="4,5,10,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="16" Height="16" SnapsToDevicePixels="True">
                                        <Border x:Name="CheckBorder"
                                                Background="{DynamicResource PlayAch.Brush.Control.Background}"
                                                BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="3"/>
                                        <Path x:Name="CheckMark"
                                              Data="M 3.5 8 L 6.5 11 L 12.5 5"
                                              Stroke="{DynamicResource PlayAch.Brush.Accent}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="Collapsed"/>
                                        <Path x:Name="DashMark"
                                              Data="M 3.5 8 L 12.5 8"
                                              Stroke="{DynamicResource PlayAch.Brush.Accent}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="Collapsed"/>
                                    </Grid>
                                    <ContentPresenter Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource PlayAch.Brush.Control.Background.Hover}"/>
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="{x:Null}">
                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource PlayAch.Brush.Control.Background.Hover}"/>
                                    <Setter TargetName="DashMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                                    <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ProviderFilterChevronToggleStyle" TargetType="ToggleButton">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="30"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ChevronBorder"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="Arrow"
                                      Width="8" Height="5"
                                      Data="M 0,0 L 8,0 L 4,5 Z"
                                      Fill="{DynamicResource PlayAch.Brush.Text}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChevronBorder" Property="Background" Value="{DynamicResource PlayAch.Brush.Grid.RowHoverBackground}"/>
                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="PlatformFilterOptionTemplate" DataType="{x:Type vm:PlatformFilterOption}">
                <ToggleButton Style="{StaticResource ProviderFilterRowToggleStyle}"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Content="{Binding PlatformName}"/>
            </DataTemplate>

            <DataTemplate x:Key="ProviderFilterGroupTemplate" DataType="{x:Type vm:ProviderFilterGroup}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton Grid.Column="0"
                                      Style="{StaticResource ProviderFilterRowToggleStyle}"
                                      IsThreeState="True"
                                      IsChecked="{Binding SelectionState, Mode=OneWay}"
                                      Command="{Binding ToggleAllCommand}"
                                      Content="{Binding DisplayName}"/>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                      Style="{StaticResource ProviderFilterChevronToggleStyle}"
                                      Visibility="{Binding HasMultiplePlatforms, Converter={StaticResource GridControlBarBoolToVis}}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Platforms}"
                                  ItemTemplate="{StaticResource PlatformFilterOptionTemplate}"
                                  Margin="18,0,0,0"
                                  Visibility="{Binding IsExpanded, Converter={StaticResource GridControlBarBoolToVis}}"/>
                </StackPanel>
            </DataTemplate>

            <Style x:Key="ProviderFilterContextMenuStyle" TargetType="ContextMenu">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.PopupSurface}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.PopupBorder}"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="MinWidth" Value="180"/>
                <Setter Property="MaxWidth" Value="280"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="4"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                    <ItemsControl ItemsSource="{TemplateBinding ItemsSource}"
                                                  ItemTemplate="{StaticResource ProviderFilterGroupTemplate}"/>
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate DataType="{x:Type vm:GridSearchControl}">
                <Grid MinWidth="{Binding MinWidth}">
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                             Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                    <TextBlock Text="{Binding Placeholder}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontSize="{DynamicResource PlayAch.FontSize.Body}"
                               FontFamily="{DynamicResource PlayAch.FontFamily.Body}"
                               Opacity="{StaticResource PlayAch.Opacity.Placeholder}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Tag="{Binding Text}"
                            Click="ClearSearch_Click"
                            Style="{StaticResource ClearSearchButtonStyle}"/>
                </Grid>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:GridMultiSelectFilter}">
                <Button Style="{StaticResource AchievementSelectorButtonStyle}"
                        Content="{Binding DisplayText}"
                        Click="MultiSelectFilter_Click"
                        Width="{Binding Width}"
                        MinWidth="{Binding MinWidth}"
                        Height="{StaticResource PlayAch.Size.Control.Height}"
                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                        VerticalAlignment="Center"
                        ToolTip="{Binding ToolTip}"
                        Visibility="{Binding IsVisible, Converter={StaticResource GridControlBarBoolToVis}}">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                     ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                    </Button.ContextMenu>
                </Button>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:GridProviderPlatformFilter}">
                <Button Style="{StaticResource AchievementSelectorButtonStyle}"
                        Content="{Binding DisplayText}"
                        Click="ProviderFilter_Click"
                        Width="{Binding Width}"
                        MinWidth="{Binding MinWidth}"
                        Height="{StaticResource PlayAch.Size.Control.Height}"
                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                        VerticalAlignment="Center"
                        ToolTip="{Binding ToolTip}"
                        Visibility="{Binding IsVisible, Converter={StaticResource GridControlBarBoolToVis}}">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ProviderFilterContextMenuStyle}"
                                     Closed="ProviderFilterContextMenu_Closed"/>
                    </Button.ContextMenu>
                </Button>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:GridToggleFilter}">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                          ToolTip="{Binding Content}"
                          Visibility="{Binding IsVisible, Converter={StaticResource GridControlBarBoolToVis}}">
                    <!-- Content is one of: text label (Icon=None), or a Status-column glyph
                         (checkmark / padlock) or the IcoFont hidden glyph. The localized name
                         is surfaced via the CheckBox ToolTip. -->
                    <Grid VerticalAlignment="Center">
                        <TextBlock x:Name="TextGlyph"
                                   Text="{Binding Content}"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                        <Viewbox x:Name="CheckGlyph"
                                 Width="15" Height="15"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed">
                            <Path Data="{StaticResource GeoCheck}"
                                  Stroke="{DynamicResource PlayAch.Brush.Glyph}"
                                  StrokeThickness="2.3"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Viewbox>
                        <Viewbox x:Name="LockGlyph"
                                 Width="15" Height="15"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed">
                            <Path Data="{StaticResource GeoLock}"
                                  Fill="{DynamicResource PlayAch.Brush.Glyph}"/>
                        </Viewbox>
                        <TextBlock x:Name="HiddenGlyph"
                                   Text="&#xEF22;"
                                   FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                                   Foreground="{DynamicResource PlayAch.Brush.Glyph}"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </CheckBox>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Icon}" Value="None">
                        <Setter TargetName="TextGlyph" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Icon}" Value="Unlocked">
                        <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Icon}" Value="Locked">
                        <Setter TargetName="LockGlyph" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Icon}" Value="Hidden">
                        <Setter TargetName="HiddenGlyph" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <Style x:Key="GridActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Button.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate DataType="{x:Type vm:GridActionButton}">
                <Button Style="{StaticResource GridActionButtonStyle}"
                        Content="{Binding Content}"
                        Click="ActionButton_Click"
                        MinWidth="{Binding MinWidth}"
                        Height="{StaticResource PlayAch.Size.Control.Height}"
                        Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                        VerticalAlignment="Center"
                        ToolTip="{Binding ToolTip}"
                        Visibility="{Binding IsVisible, Converter={StaticResource GridControlBarBoolToVis}}"/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:GridModeToggle}">
                <ToggleButton Style="{StaticResource GridModeToggleButtonStyle}"
                              Content="{Binding Content}"
                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              Height="{StaticResource PlayAch.Size.Control.Height}"
                              Margin="{StaticResource PlayAch.Thickness.Left.Xs}"
                              VerticalAlignment="Center"
                              ToolTip="{Binding ToolTip}"
                              Visibility="{Binding IsVisible, Converter={StaticResource GridControlBarBoolToVis}}"/>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid KeyboardNavigation.DirectionalNavigation="Continue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="100"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding ControlBar.Search, ElementName=Root}"/>

        <ItemsControl Grid.Column="1"
                      ItemsSource="{Binding ControlBar.Items, ElementName=Root}"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</UserControl>
