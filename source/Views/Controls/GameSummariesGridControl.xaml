<UserControl x:Class="PlayniteAchievements.Views.Controls.GameSummariesGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <Style x:Key="GameImageBorderStyle" TargetType="Border" BasedOn="{StaticResource GameImageBorderBaseStyle}">
                <Setter Property="Margin" Value="2"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseCoverImages, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <ImageBrush Stretch="Uniform"
                                            helpers:AsyncImage.Uri="{Binding GameCoverPath, Converter={StaticResource DefaultGameImage}, ConverterParameter=cover}"
                                            helpers:AsyncImage.DecodePixel="128"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GameSummariesGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource GameSummariesGridRowBaseStyle}">
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_PreviewMouseLeftButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonUp" Handler="DataGridRow_PreviewMouseRightButtonUp"/>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <DataGrid x:Name="GameSummariesGrid"
              KeyboardNavigation.DirectionalNavigation="Contained"
              ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}"
              SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}, Mode=TwoWay}"
              SelectionChanged="DataGrid_SelectionChanged"
              Sorting="DataGrid_Sorting"
              LoadingRow="GameSummariesGrid_LoadingRow"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              GridLinesVisibility="None"
              HeadersVisibility="Column"
              BorderThickness="0"
              CanUserResizeColumns="True"
              CanUserResizeRows="False"
              CanUserReorderColumns="True"
              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
              CanUserSortColumns="True"
              EnableRowVirtualization="True"
              VirtualizingStackPanel.IsVirtualizing="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderWithMenuStyle}"
              VirtualizingStackPanel.ScrollUnit="Pixel"
              ScrollViewer.CanContentScroll="True"
              ScrollViewer.VerticalScrollBarVisibility="Visible"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              ScrollViewer.IsDeferredScrollingEnabled="False"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True"
              Tag="ControllerCellFocus"
              helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
              helpers:DataGridAlignmentBehavior.IsEnabled="True"
              PreviewMouseRightButtonUp="DataGridColumnMenu_PreviewMouseRightButtonUp">
        <DataGrid.CellStyle>
            <Style TargetType="DataGridCell"
                   BasedOn="{StaticResource GameSummariesGridCellStyle}"/>
        </DataGrid.CellStyle>
        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow"
                   BasedOn="{StaticResource GameSummariesGridRowStyle}"/>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
            <DataGridTemplateColumn Width="96" MinWidth="56" MaxWidth="240" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Cover}"
                                    CellStyle="{StaticResource GameSummariesImageCellStyle}"
                                    helpers:ColumnVisibilityHelper.ColumnKey="Cover">
                <DataGridTemplateColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Opacity="0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.HeaderTemplate>
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}"
                                        Padding="4,6">
                            <Grid>
                                <Border CornerRadius="{StaticResource PlayAch.Radius.Card}"
                                        HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                        VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                        Style="{StaticResource GameImageBorderStyle}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="auto,width,12,8,12">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}" Path="UseCoverImages"/>
                                        </MultiBinding>
                                    </Border.Width>
                                    <Border.Height>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="auto,height,12,8,12">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}" Path="UseCoverImages"/>
                                        </MultiBinding>
                                    </Border.Height>
                                </Border>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Game}" SortMemberPath="SortingName" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryName">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <StackPanel VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                            HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}">
                                    <TextBlock Text="{Binding GameName}"
                                               HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                               Style="{StaticResource GameSummaryNameTextStyle}"/>
                                    <TextBlock HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                               Style="{StaticResource OverviewGameMetadataTextStyle}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource GameMetadataText}">
                                                <Binding Path="PlatformText"/>
                                                <Binding Path="PlaytimeText"/>
                                                <Binding Path="RegionText"/>
                                                <Binding Path="ShowMetadataPlatform" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataPlaytime" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataRegion" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Visibility>
                                            <MultiBinding Converter="{StaticResource GameMetadataText}">
                                                <Binding Path="PlatformText"/>
                                                <Binding Path="PlaytimeText"/>
                                                <Binding Path="RegionText"/>
                                                <Binding Path="ShowMetadataPlatform" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataPlaytime" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataRegion" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="44" MinWidth="28" MaxWidth="96"
                                    Header="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                    CanUserResize="True"
                                    CanUserSort="False"
                                    CellStyle="{StaticResource GameSummariesImageCellStyle}"
                                    helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPlatform">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                    Opacity="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>

                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}"
                                        Padding="0,6">
                            <Grid>
                                <Image ToolTip="{Binding Provider}"
                                       Style="{StaticResource GameSummaryProviderIconStyle}">
                                    <Image.Width>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,width,8,16,14">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Image.Width>
                                    <Image.Height>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,height,8,16,14">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Image.Height>
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                            <Binding Path="ProviderIconKey"/>
                                            <Binding Path="ProviderColorHex"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_LastPlayed}" SortMemberPath="LastPlayed" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryLastPlayed">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource DateDisplayMode}">
                                            <Binding Path="LastPlayedLocal"/>
                                            <Binding Path="LastPlayedDateMode" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Playtime}" SortMemberPath="PlaytimeSeconds" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPlaytime">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <TextBlock Text="{Binding PlaytimeText}"
                                           VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Progress}" SortMemberPath="Progression" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryProgression">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}"
                                        Padding="4,6,2,6">
                            <Grid>
                                <Grid Style="{StaticResource OverviewProgressContainerStyle}">
                                    <StackPanel Style="{StaticResource OverviewProgressStackStyle}">
                                        <Grid>
                                            <ProgressBar Value="{Binding Progression, Mode=OneWay}"
                                                         Style="{StaticResource OverviewProgressBarStyle}"/>
                                            <TextBlock Text="{Binding ProgressionText}"
                                                       Style="{StaticResource OverviewProgressPercentTextStyle}"/>
                                        </Grid>
    
                                        <Grid Style="{StaticResource OverviewProgressFooterStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
    
                                            <Image Grid.Column="0"
                                                   Source="{DynamicResource BadgeRarityCompleted}"
                                                   Style="{StaticResource OverviewCompletedFooterIconStyle}"
                                                   ToolTip="{DynamicResource LOCPlayAch_Completed}"
                                                   Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
    
                                            <StackPanel Grid.Column="1"
                                                        Style="{StaticResource OverviewProgressMetaRowStyle}"
                                                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource InverseBoolToVis}}">
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UltraRareCount, Converter={StaticResource IntToVis}}" ToolTip="Ultra Rare">
                                                    <Image Source="{DynamicResource BadgeRarityUltraRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding UltraRareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding RareCount, Converter={StaticResource IntToVis}}" ToolTip="Rare">
                                                    <Image Source="{DynamicResource BadgeRarityRare}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding RareCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding UncommonCount, Converter={StaticResource IntToVis}}" ToolTip="Uncommon">
                                                    <Image Source="{DynamicResource BadgeRarityUncommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding UncommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding CommonCount, Converter={StaticResource IntToVis}}" ToolTip="Common">
                                                    <Image Source="{DynamicResource BadgeRarityCommon}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding CommonCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
    
                                            <StackPanel Grid.Column="1"
                                                        Style="{StaticResource OverviewProgressMetaRowStyle}"
                                                        Visibility="{Binding HasTrophyTypes, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyPlatinumCount, Converter={StaticResource IntToVis}}" ToolTip="Platinum">
                                                    <Image Source="{DynamicResource TrophyPlatinum}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding TrophyPlatinumCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyGoldCount, Converter={StaticResource IntToVis}}" ToolTip="Gold">
                                                    <Image Source="{DynamicResource TrophyGold}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding TrophyGoldCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophySilverCount, Converter={StaticResource IntToVis}}" ToolTip="Silver">
                                                    <Image Source="{DynamicResource TrophySilver}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding TrophySilverCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource OverviewMiniBadgeItemStyle}" Visibility="{Binding TrophyBronzeCount, Converter={StaticResource IntToVis}}" ToolTip="Bronze">
                                                    <Image Source="{DynamicResource TrophyBronze}" Style="{StaticResource OverviewMiniBadgeImageStyle}"/>
                                                    <TextBlock Text="{Binding TrophyBronzeCount}" Style="{StaticResource OverviewMiniBadgeTextStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Total}" SortMemberPath="TotalAchievements" helpers:ColumnVisibilityHelper.ColumnKey="TotalAchievements">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding UnlockedAchievements, Mode=OneWay}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding TotalAchievements, Mode=OneWay}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_CollectionScore}" SortMemberPath="CollectionScore" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryCollectionScore">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding CollectionScore, Mode=OneWay, StringFormat={}{0:N0}}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding CollectionScoreTotal, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_PrestigeScore}" SortMemberPath="PrestigeScore" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPrestigeScore">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCompletedCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding PrestigeScore, Mode=OneWay, StringFormat={}{0:N0}}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding PrestigeScoreTotal, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
