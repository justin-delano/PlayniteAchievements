<UserControl x:Class="PlayniteAchievements.Views.Controls.GameSummariesGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <!-- Game icon/cover image, switching source and decode size with the
                 grid's UseCoverImages and PreserveImageResolution settings. -->
            <Style x:Key="GameImageStyle" TargetType="Image">
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="helpers:AsyncImage.Uri" Value="{Binding GameLogo, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"/>
                <Setter Property="helpers:AsyncImage.DecodePixel" Value="160"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding UseCoverImages, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}" Value="True">
                        <Setter Property="helpers:AsyncImage.Uri" Value="{Binding GameCoverPath, Converter={StaticResource DefaultGameImage}, ConverterParameter=cover}"/>
                        <Setter Property="helpers:AsyncImage.DecodePixel" Value="320"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding PreserveImageResolution, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}" Value="True">
                        <Setter Property="helpers:AsyncImage.DecodePixel" Value="-1"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GameSummariesGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource GameSummariesGridRowBaseStyle}">
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_PreviewMouseLeftButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonUp" Handler="DataGridRow_PreviewMouseRightButtonUp"/>
            </Style>

            <Style x:Key="GameSummaryGridTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource PlayAch.TextBlock.BaseStyle}">
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextAlignment"
                        Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
                <Setter Property="HorizontalAlignment"
                        Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"/>
                <Setter Property="VerticalAlignment"
                        Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"/>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <controls:GridControlBarControl x:Name="ControlBarHost"
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    ControlBar="{Binding ControlBar, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}"
                                    ShowControlBar="{Binding ShowControlBar, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}"/>

    <DataGrid x:Name="GameSummariesGrid"
              Grid.Row="1"
              KeyboardNavigation.DirectionalNavigation="Contained"
              ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}"
              SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}, Mode=TwoWay}"
              SelectionChanged="DataGrid_SelectionChanged"
              Sorting="DataGrid_Sorting"
              LoadingRow="GameSummariesGrid_LoadingRow"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              GridLinesVisibility="None"
              HeadersVisibility="Column"
              BorderThickness="0"
              CanUserResizeColumns="True"
              CanUserResizeRows="False"
              CanUserReorderColumns="True"
              Background="{DynamicResource PlayAch.Brush.Grid.Background}"
              RowBackground="{DynamicResource PlayAch.Brush.Grid.RowBackground}"
              CanUserSortColumns="True"
              EnableRowVirtualization="True"
              VirtualizingStackPanel.IsVirtualizing="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderWithMenuStyle}"
              VirtualizingStackPanel.ScrollUnit="Pixel"
              ScrollViewer.CanContentScroll="True"
              ScrollViewer.VerticalScrollBarVisibility="Visible"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              ScrollViewer.IsDeferredScrollingEnabled="False"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True"
              Tag="ControllerCellFocus"
              helpers:DataGridHoverScrollBarBehavior.IsEnabled="True"
              helpers:DataGridAlignmentBehavior.IsEnabled="True"
              PreviewMouseRightButtonUp="DataGridColumnMenu_PreviewMouseRightButtonUp">
        <DataGrid.CellStyle>
            <Style TargetType="DataGridCell"
                   BasedOn="{StaticResource GameSummariesGridCellStyle}"/>
        </DataGrid.CellStyle>
        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow"
                   BasedOn="{StaticResource GameSummariesGridRowStyle}"/>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
            <DataGridTemplateColumn Width="96" MinWidth="56" MaxWidth="600" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Cover}"
                                    CellStyle="{StaticResource GameSummariesImageCellStyle}"
                                    helpers:ColumnVisibilityHelper.ColumnKey="Cover">
                <DataGridTemplateColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Opacity="0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.HeaderTemplate>
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <!-- Width-driven: the Uniform image fills the column width, so resizing
                             the column grows the art and auto rows grow to match. A configured
                             fixed row height bounds the layout instead, and Uniform stretch then
                             fits the art inside both cell dimensions without clipping. -->
                        <Grid ClipToBounds="False"
                              Margin="8,6"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True"
                              HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                              VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}">
                            <!-- Backing completion-glow layer: two art copies carrying the
                                 completed-gradient start/end glows, cached as one bitmap so the
                                 blur is not re-rasterized while scrolling. Sits outside the
                                 rounded clipping border so the bloom is never cut off. -->
                            <Border CacheMode="BitmapCache"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCompleted}" Value="True"/>
                                                    <Condition Binding="{Binding ShowCompletionGlow, RelativeSource={RelativeSource AncestorType=controls:GameSummariesGridControl}}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Image Style="{StaticResource GameImageStyle}"
                                           Effect="{DynamicResource PlayAch.Effect.CompletedGlowStart}"/>
                                    <Image Style="{StaticResource GameImageStyle}"
                                           Effect="{DynamicResource PlayAch.Effect.CompletedGlowEnd}"/>
                                </Grid>
                            </Border>
                            <Border CornerRadius="{StaticResource PlayAch.Radius.Card}"
                                    ClipToBounds="True"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    UseLayoutRounding="True"
                                    SnapsToDevicePixels="True">
                                <Image Style="{StaticResource GameImageStyle}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Game}" SortMemberPath="SortingName" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryName">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <StackPanel VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                            HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}">
                                    <TextBlock Text="{Binding GameName}"
                                               HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                               Style="{StaticResource GameSummaryNameTextStyle}"/>
                                    <TextBlock HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                               Style="{StaticResource OverviewGameMetadataTextStyle}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource GameMetadataText}">
                                                <Binding Path="PlatformText"/>
                                                <Binding Path="PlaytimeText"/>
                                                <Binding Path="RegionText"/>
                                                <Binding Path="ShowMetadataPlatform" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataPlaytime" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataRegion" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Visibility>
                                            <MultiBinding Converter="{StaticResource GameMetadataText}">
                                                <Binding Path="PlatformText"/>
                                                <Binding Path="PlaytimeText"/>
                                                <Binding Path="RegionText"/>
                                                <Binding Path="ShowMetadataPlatform" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataPlaytime" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                                <Binding Path="ShowMetadataRegion" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="44" MinWidth="28" MaxWidth="96"
                                    Header="{DynamicResource LOCPlayAch_Common_Label_Platform}"
                                    CanUserResize="True"
                                    CanUserSort="False"
                                    CellStyle="{StaticResource GameSummariesImageCellStyle}"
                                    helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPlatform">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                    Opacity="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>

                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}"
                                        Padding="0,6">
                            <Grid>
                                <Image ToolTip="{Binding Provider}"
                                       Style="{StaticResource GameSummaryProviderIconStyle}">
                                    <Image.Width>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,width,8,16,14">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Image.Width>
                                    <Image.Height>
                                        <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,height,8,16,14">
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Image.Height>
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                            <Binding Path="ProviderIconKey"/>
                                            <Binding Path="ProviderColorHex"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="40" MinWidth="28" MaxWidth="96" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Owned}" SortMemberPath="Owned" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryOwned"
                                    CellStyle="{StaticResource AchievementStatusCellStyle}">
                <DataGridTemplateColumn.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Opacity="0"/>
                    </DataTemplate>
                </DataGridTemplateColumn.HeaderTemplate>
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Viewbox Stretch="Uniform"
                                 VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                 HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                 ClipToBounds="False"
                                 UseLayoutRounding="True"
                                 SnapsToDevicePixels="True"
                                 Visibility="{Binding Owned, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Viewbox.Width>
                                <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,width,8,12,18">
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Viewbox.Width>
                            <Viewbox.Height>
                                <MultiBinding Converter="{StaticResource ImageFitDimension}" ConverterParameter="platform,height,8,12,18">
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridRow}" Path="ActualHeight"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGridCell}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Viewbox.Height>

                            <Grid Width="18" Height="18">
                                <Path Data="{StaticResource GeoCheck}"
                                      Stroke="{DynamicResource PlayAch.Brush.Glyph}"
                                      StrokeThickness="2.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_LastPlayed}" SortMemberPath="LastPlayed" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryLastPlayed">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource DateDisplayMode}">
                                            <Binding Path="LastPlayedLocal"/>
                                            <Binding Path="LastPlayedDateMode" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Common_LastUnlock}" SortMemberPath="LastUnlockUtc" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryLastUnlock">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock Style="{StaticResource GameSummaryGridTextStyle}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource DateDisplayMode}">
                                            <Binding Path="LastUnlockLocal"/>
                                            <Binding Path="LastPlayedDateMode" RelativeSource="{RelativeSource AncestorType=controls:GameSummariesGridControl}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Common_Label_Playtime}" SortMemberPath="PlaytimeSeconds" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPlaytime">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock Text="{Binding PlaytimeText}"
                                           VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"/>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Progress}" SortMemberPath="Progression" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryProgression">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}"
                                        Padding="4,6,2,6">
                            <Grid>
                                <Grid Style="{StaticResource OverviewProgressContainerStyle}">
                                    <StackPanel Style="{StaticResource OverviewProgressStackStyle}">
                                        <Grid>
                                            <ProgressBar Value="{Binding Progression, Mode=OneWay}"
                                                         Style="{StaticResource OverviewProgressBarStyle}"/>
                                            <TextBlock Text="{Binding ProgressionText}"
                                                       Style="{StaticResource OverviewProgressPercentTextHaloStyle}"/>
                                            <TextBlock Text="{Binding ProgressionText}"
                                                       Style="{StaticResource OverviewProgressPercentTextStyle}"/>
                                        </Grid>
    
                                        <Grid Style="{StaticResource OverviewProgressFooterStyle}">
                                            <ContentControl Content="{Binding}"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Center">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource ProgressFooterRightTemplate}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}" Value="Center">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ProgressFooterCenterTemplate}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}" Value="Left">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ProgressFooterLeftTemplate}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Total}" SortMemberPath="TotalAchievements" helpers:ColumnVisibilityHelper.ColumnKey="TotalAchievements">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding UnlockedAchievements, Mode=OneWay}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding TotalAchievements, Mode=OneWay}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Score_Collection}" SortMemberPath="CollectionScore" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryCollectionScore">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding CollectionScore, Mode=OneWay, StringFormat={}{0:N0}}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding CollectionScoreTotal, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Score_Prestige}" SortMemberPath="PrestigeScore" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPrestigeScore">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding PrestigeScore, Mode=OneWay, StringFormat={}{0:N0}}" FontWeight="Bold"/><Run Text="/" Foreground="{DynamicResource PlayAch.Brush.Text}"/><Run Text="{Binding PrestigeScoreTotal, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="{DynamicResource PlayAch.Brush.Text}"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Width="*" MinWidth="22" CanUserResize="True" Header="{DynamicResource LOCPlayAch_Column_Points}" SortMemberPath="Points" helpers:ColumnVisibilityHelper.ColumnKey="GameSummaryPoints">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <ContentControl Style="{StaticResource OverviewCellFrameStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                           HorizontalAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap"
                                           TextAlignment="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}, Path=Column.(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                                    <TextBlock.Inlines><Run Text="{Binding Points, Mode=OneWay, StringFormat={}{0:N0}}" FontWeight="Bold"/></TextBlock.Inlines>
                                </TextBlock>
                            </Grid>
                        </ContentControl>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>
    </Grid>
</UserControl>
