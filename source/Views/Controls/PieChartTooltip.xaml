<UserControl x:Class="PlayniteAchievements.Views.Controls.PieChartTooltip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:models="clr-namespace:PlayniteAchievements.Models"
             xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Focusable="False"
             IsHitTestVisible="False"
             mc:Ignorable="d"
             d:DesignHeight="{StaticResource PlayAch.Size.Control.Height}" d:DesignWidth="80">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource PopupBackgroundBrush}"
            BorderBrush="{DynamicResource PopupBorderBrush}"
            BorderThickness="{StaticResource PlayAch.Thickness.Border}"
            CornerRadius="4"
            IsHitTestVisible="False"
            Padding="8,4">
        <ItemsControl ItemsSource="{Binding Data.Points}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type wpf:DataPointViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Compact}" VerticalAlignment="Center">
                            <!-- Badge icons: complex DrawingImages from AchievementResources.xaml -->
                            <Image Source="{Binding ChartPoint.Instance.IconKey, Converter={StaticResource ResourceKeyToImage}}"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Provider icons: created at runtime from geometry + color -->
                            <Image SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                        <Binding Path="ChartPoint.Instance.IconKey"/>
                                        <Binding Path="ChartPoint.Instance.ColorHex"/>
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                        </Grid>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ChartPoint.Instance.PrimaryMetricText}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Body}"/>
                            <TextBlock Text="{Binding ChartPoint.Instance.SecondaryMetricText}"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Opacity="0.72"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
