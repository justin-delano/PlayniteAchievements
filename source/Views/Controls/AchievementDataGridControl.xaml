<UserControl x:Class="PlayniteAchievements.Views.Controls.AchievementDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance vm:AchievementDisplayItem}"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DataGrid x:Name="AchievementsDataGrid"
              ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
              Sorting="DataGrid_Sorting"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              SelectionUnit="FullRow"
              HeadersVisibility="Column"
              GridLinesVisibility="None"
              RowBackground="Transparent"
              BorderThickness="1"
              BorderBrush="{DynamicResource NormalBorderBrush}"
              Background="Transparent"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              CanUserResizeRows="False"
              CanUserResizeColumns="True"
              CanUserReorderColumns="False"
              CanUserSortColumns="True"
              EnableRowVirtualization="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              VirtualizingStackPanel.ScrollUnit="Pixel"
              ScrollViewer.CanContentScroll="True"
              ScrollViewer.IsDeferredScrollingEnabled="False"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              Padding="0"
              ColumnHeaderStyle="{StaticResource AchievementColumnHeaderWithMenuStyle}"
              PreviewMouseRightButtonUp="DataGridColumnMenu_PreviewMouseRightButtonUp">

        <DataGrid.CellStyle>
            <Style TargetType="DataGridCell" BasedOn="{StaticResource AchievementCellStyle}"/>
        </DataGrid.CellStyle>

        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow" BasedOn="{StaticResource AchievementRowStyle}">
                <Setter Property="MinHeight" Value="88"/>
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="AchievementRow_PreviewMouseLeftButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonDown" Handler="AchievementRow_PreviewMouseRightButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonUp" Handler="AchievementRow_PreviewMouseRightButtonUp"/>
            </Style>
        </DataGrid.RowStyle>

        <DataGrid.Columns>
            <!-- Status: Checkmark (unlocked) or Padlock (locked) -->
            <DataGridTemplateColumn x:Name="StatusColumn"
                                    Width="36" MinWidth="36" MaxWidth="36" CanUserSort="False" CanUserResize="False"
                                    Header=" "
                                    helpers:ColumnVisibilityHelper.ColumnKey="Status"
                                    CellTemplate="{StaticResource AchievementStatusTemplate}"/>

            <!-- Achievement Icon -->
            <DataGridTemplateColumn Width="78" MinWidth="78" MaxWidth="78" CanUserResize="False"
                                    CellTemplate="{StaticResource AchievementIconTemplate}"/>

            <!-- Achievement Info -->
            <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Achievement}" SortMemberPath="DisplayName" helpers:ColumnVisibilityHelper.ColumnKey="Achievement"
                                    CellTemplate="{StaticResource AchievementInfoTemplate}"/>
            
            <!-- Game Column - shown in sidebar recent achievements -->
            <DataGridTemplateColumn x:Name="GameColumn"
                                    Width="64" MinWidth="64" MaxWidth="64" CanUserResize="False"
                                    Header="{DynamicResource LOCPlayAch_Column_Game}"
                                    SortMemberPath="SortingName"
                                    helpers:ColumnVisibilityHelper.ColumnKey="Game"
                                    Visibility="Collapsed"
                                    CellTemplate="{StaticResource AchievementGameColumnTemplate}"/>

            <!-- Unlock Date / Progress -->
            <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_UnlockDate}" SortMemberPath="UnlockTime" helpers:ColumnVisibilityHelper.ColumnKey="UnlockDate"
                                    CellTemplate="{StaticResource AchievementUnlockDateTemplate}"/>

            <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Type}" SortMemberPath="CategoryType" helpers:ColumnVisibilityHelper.ColumnKey="CategoryType">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding CategoryTypeDisplay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Category}" SortMemberPath="CategoryLabel" helpers:ColumnVisibilityHelper.ColumnKey="CategoryLabel">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding CategoryLabel}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Trophy -->
            <DataGridTemplateColumn Width="100" MinWidth="90" Header="{DynamicResource LOCPlayAch_Column_Trophy}" CanUserResize="True" SortMemberPath="TrophyType"
                                    CellTemplate="{StaticResource AchievementTrophyTemplate}"/>

            <!-- Rarity -->
            <DataGridTemplateColumn Width="*" Header="{DynamicResource LOCPlayAch_Column_Rarity}" SortMemberPath="GlobalPercent" helpers:ColumnVisibilityHelper.ColumnKey="Rarity"
                                    CellTemplate="{StaticResource AchievementRarityTemplate}"/>

            <DataGridTemplateColumn Width="72" Header="{DynamicResource LOCPlayAch_Column_Points}" SortMemberPath="Points" helpers:ColumnVisibilityHelper.ColumnKey="Points"
                                    CellTemplate="{StaticResource AchievementPointsTemplate}"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
