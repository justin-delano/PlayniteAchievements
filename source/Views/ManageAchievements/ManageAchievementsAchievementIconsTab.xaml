<UserControl x:Class="PlayniteAchievements.Views.ManageAchievements.ManageAchievementsAchievementIconsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels.ManageAchievements"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="920"
             d:DataContext="{d:DesignInstance vm:ManageAchievementsAchievementIconsViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/ManageAchievementsScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ManageAchievementsHeaderCardStyle}"
                Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_CustomIcons_Header}"
                               Style="{StaticResource ManageAchievementsHeaderTitleStyle}" />
                    <TextBlock Text="{DynamicResource LOCPlayAch_ManageAchievements_CustomIcons_Hint}"
                               Style="{StaticResource ManageAchievementsHeaderHintStyle}" />
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource StatusTextStyle}"
                               Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                               Visibility="{Binding HasStatusText, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="{StaticResource PlayAch.Thickness.Left.Md}">
                    <Button x:Name="OpenIconsFolderButton"
                            Content="{DynamicResource LOCPlayAch_ManageAchievements_CustomIcons_OpenFolderButton}"
                            Command="{Binding OpenIconsFolderCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource PlayAch.Thickness.Top.Sm}" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource LOCPlayAch_Common_NoCachedAchievementsForGame}"
                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                   Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   Visibility="{Binding HasAchievements, Converter={StaticResource InverseBoolToVis}}" />

        <ListBox x:Name="AchievementCardsList"
                 Grid.Row="2"
                 Margin="0,2,0,0"
                 ItemsSource="{Binding AchievementRows}"
                 Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}"
                 BorderThickness="0"
                 Background="Transparent"
                 Focusable="False"
                 KeyboardNavigation.IsTabStop="False"
                 HorizontalContentAlignment="Stretch"
                 SelectionMode="Single"
                 KeyboardNavigation.DirectionalNavigation="Continue"
                 KeyboardNavigation.TabNavigation="Continue"
                 ItemContainerStyle="{StaticResource IconCardListItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 VirtualizingStackPanel.ScrollUnit="Pixel"
                 PreviewMouseWheel="AchievementCardsList_PreviewMouseWheel"
                 PreviewMouseLeftButtonDown="AchievementCardsList_PreviewMouseLeftButtonDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource IconCardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" MinWidth="180" />
                                <ColumnDefinition Width="2.85*" MinWidth="320" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="{StaticResource PlayAch.Thickness.Right.Md}"
                                        VerticalAlignment="Center">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}" />
                                            <Setter Property="Opacity" Value="0.7" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Unlocked}" Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTitleHidden}" Value="True">
                                                    <Setter Property="FontStyle" Value="Italic" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding DisplayNameResolved, Mode=OneWay}" />
                                    <Run Text="{Binding HiddenTitleSuffix, Mode=OneWay}"
                                         FontStyle="Italic"
                                         FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                         Foreground="{DynamicResource PlayAch.Brush.Text.Secondary}" />
                                </TextBlock>
                                <TextBlock Text="{Binding DescriptionResolved}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="0.72"
                                           FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="36"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDescriptionHidden}" Value="True">
                                                    <Setter Property="FontStyle" Value="Italic" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ApiNameResolved}"
                                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                                           Opacity="0.58"
                                           FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource VariantBadgeStyle}"
                                            ToolTip="{DynamicResource LOCPlayAch_Common_Unlocked}">
                                        <TextBlock Text="&#x2713;"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PlayAch.Brush.Glyph}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PreviewBorderStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                        <Image Width="30"
                                               Height="{StaticResource PlayAch.Size.Control.Height}"
                                              Stretch="Uniform"
                                               helpers:AsyncImage.Uri="{Binding UnlockedPreviewPath}"
                                               helpers:AsyncImage.DecodePixel="72" />
                                    </Border>

                                    <Grid Grid.Column="2"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                        <TextBox Text="{Binding UnlockedOverrideText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="{Binding UnlockedOverrideToolTip}"
                                                 Tag="Unlocked"
                                                 AllowDrop="True"
                                                 PreviewDragOver="OverrideTextBox_PreviewDragOver"
                                                 Drop="OverrideTextBox_Drop"
                                                 KeyDown="OverrideTextBox_KeyDown">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource EditorTextBoxStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUnlockedOverrideValidationError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.ErrorText}" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <Button Tag="{Binding UnlockedOverrideText}"
                                                CommandParameter="Unlocked"
                                                Style="{StaticResource ClearSearchButtonStyle}"
                                                Focusable="True"
                                                Click="ClearOverrideButton_Click" />
                                    </Grid>

                                    <Button Grid.Column="3"
                                            Content="..."
                                            Tag="Unlocked"
                                            ToolTip="{DynamicResource LOCPlayAch_Button_Browse}"
                                            Style="{StaticResource InlineBrowseButtonStyle}"
                                            Click="BrowseButton_Click" />
                                </Grid>

                                <Border Grid.Row="1"
                                        Height="1"
                                        Background="{StaticResource PlayAch.Brush.Overlay.Shade.14}"
                                        Margin="30,0,0,0" />

                                <Grid Grid.Row="2"
                                      Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource VariantBadgeStyle}"
                                            ToolTip="{DynamicResource LOCPlayAch_Common_Locked}">
                                        <Image Source="{StaticResource BadgeLocked}"
                                               Width="13"
                                               Height="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0.72" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PreviewBorderStyle}"
                                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                        <Image Width="30"
                                               Height="{StaticResource PlayAch.Size.Control.Height}"
                                              Stretch="Uniform"
                                               helpers:AsyncImage.Uri="{Binding LockedPreviewPath}"
                                               helpers:AsyncImage.DecodePixel="72" />
                                    </Border>

                                    <Grid Grid.Column="2"
                                          Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                                        <TextBox Text="{Binding LockedOverrideText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="{Binding LockedOverrideToolTip}"
                                                 Tag="Locked"
                                                 AllowDrop="True"
                                                 PreviewDragOver="OverrideTextBox_PreviewDragOver"
                                                 Drop="OverrideTextBox_Drop"
                                                 KeyDown="OverrideTextBox_KeyDown">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource EditorTextBoxStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLockedOverrideValidationError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource PlayAch.Brush.ErrorText}" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <Button Tag="{Binding LockedOverrideText}"
                                                CommandParameter="Locked"
                                                Style="{StaticResource ClearSearchButtonStyle}"
                                                Focusable="True"
                                                Click="ClearOverrideButton_Click" />
                                    </Grid>

                                    <Button Grid.Column="3"
                                            Content="..."
                                            Tag="Locked"
                                            ToolTip="{DynamicResource LOCPlayAch_Button_Browse}"
                                            Style="{StaticResource InlineBrowseButtonStyle}"
                                            Click="BrowseButton_Click" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>


