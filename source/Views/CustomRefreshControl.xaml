<UserControl x:Class="PlayniteAchievements.Views.CustomRefreshControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="920"
             d:DesignHeight="680">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CustomRefreshScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="{DynamicResource PlayAch.Brush.Window.Background}" Padding="12">
    <Grid TextElement.Foreground="{DynamicResource PlayAch.Brush.Text}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource LOCPlayAch_CustomRefresh_Header}"
                   Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0"
                          Header="{DynamicResource LOCPlayAch_CustomRefresh_PresetsHeader}"
                          Foreground="{DynamicResource PlayAch.Brush.Text}"
                          BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                          Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding PresetOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  Background="{DynamicResource PlayAch.Brush.Surface}"
                                  BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                  Margin="{StaticResource PlayAch.Thickness.Right.Sm}" />

                        <Button Grid.Column="1"
                                Content="{DynamicResource LOCPlayAch_CustomRefresh_Presets_Load}"
                                Click="LoadPresetButton_Click"
                                IsEnabled="{Binding CanLoadPreset}"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                MinWidth="80"
                                Margin="{StaticResource PlayAch.Thickness.Right.Compact}" />

                        <Button Grid.Column="2"
                                Content="{DynamicResource LOCPlayAch_Button_Save}"
                                Click="SavePresetButton_Click"
                                IsEnabled="{Binding CanSavePreset}"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                MinWidth="80"
                                Margin="{StaticResource PlayAch.Thickness.Right.Compact}" />

                        <Button Grid.Column="3"
                                Content="{DynamicResource LOCPlayAch_CustomRefresh_Presets_SaveAs}"
                                Click="SaveAsPresetButton_Click"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                MinWidth="88"
                                Margin="{StaticResource PlayAch.Thickness.Right.Compact}" />

                        <Button Grid.Column="4"
                                Content="{DynamicResource LOCPlayAch_CustomRefresh_Presets_Delete}"
                                Click="DeletePresetButton_Click"
                                IsEnabled="{Binding CanDeletePreset}"
                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                                MinWidth="80" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1"
                          Header="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}"
                          Foreground="{DynamicResource PlayAch.Brush.Text}"
                          BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                          Margin="0,0,0,10">
                    <ItemsControl ItemsSource="{Binding ProviderOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding IsSelectable}"
                                              Foreground="{DynamicResource PlayAch.Brush.Text}"
                                              VerticalAlignment="Center"
                                              Margin="{StaticResource PlayAch.Thickness.Right.Sm}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProviderName}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusText}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               VerticalAlignment="Center"
                                               Opacity="{StaticResource PlayAch.Opacity.Hint}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <GroupBox Grid.Row="2"
                          Header="{DynamicResource LOCPlayAch_CustomRefresh_ScopeHeader}"
                          Foreground="{DynamicResource PlayAch.Brush.Text}"
                          BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                          Margin="0,0,0,10">
                    <StackPanel>
                        <ComboBox ItemsSource="{Binding ScopeOptions}"
                                  SelectedValuePath="Scope"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding SelectedScope, Mode=TwoWay}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  Background="{DynamicResource PlayAch.Brush.Surface}"
                                  BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                  Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}">
                            <CheckBox IsChecked="{Binding UseRecentLimitOverride, Mode=TwoWay}"
                                      Content="{DynamicResource LOCPlayAch_CustomRefresh_UseRecentLimit}"
                                      Foreground="{DynamicResource PlayAch.Brush.Text}" />
                            <TextBox Width="80"
                                     Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                     Text="{Binding RecentLimitOverrideText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Background="{DynamicResource PlayAch.Brush.Surface}"
                                     BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                     IsEnabled="{Binding UseRecentLimitOverride}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding UseIncludeUnplayedOverride, Mode=TwoWay}"
                                      Content="{DynamicResource LOCPlayAch_CustomRefresh_UseIncludeUnplayed}"
                                      Foreground="{DynamicResource PlayAch.Brush.Text}" />
                            <CheckBox Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                      Content="{DynamicResource LOCPlayAch_IncludeUnplayedGames}"
                                      IsChecked="{Binding IncludeUnplayedOverrideValue, Mode=TwoWay}"
                                      Foreground="{DynamicResource PlayAch.Brush.Text}"
                                      IsEnabled="{Binding UseIncludeUnplayedOverride}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="3"
                          Header="{DynamicResource LOCPlayAch_CustomRefresh_TargetingHeader}"
                          Foreground="{DynamicResource PlayAch.Brush.Text}"
                          BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                          Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource LOCPlayAch_CustomRefresh_IncludeHeader}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}" />
                            <TextBox Text="{Binding IncludeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}" />
                            <ListBox ItemsSource="{Binding IncludeGameView}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Background="{DynamicResource PlayAch.Brush.Surface}"
                                     BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                     Height="230">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                                  Content="{Binding DisplayName}"
                                                  Foreground="{DynamicResource PlayAch.Brush.Text}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource LOCPlayAch_CustomRefresh_ExcludeHeader}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}" />
                            <TextBox Text="{Binding ExcludeSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                     Style="{DynamicResource SearchTextBoxStyle}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}" />
                            <ListBox ItemsSource="{Binding ExcludeGameView}"
                                     Foreground="{DynamicResource PlayAch.Brush.Text}"
                                     Background="{DynamicResource PlayAch.Brush.Surface}"
                                     BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                     Height="230">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsExcluded, Mode=TwoWay}"
                                                  Content="{Binding DisplayName}"
                                                  Foreground="{DynamicResource PlayAch.Brush.Text}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="4"
                          Header="{DynamicResource LOCPlayAch_CustomRefresh_ExecutionHeader}"
                          Foreground="{DynamicResource PlayAch.Brush.Text}"
                          BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                          Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox Content="{DynamicResource LOCPlayAch_CustomRefresh_RespectExclusions}"
                                  IsChecked="{Binding RespectUserExclusions, Mode=TwoWay}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}" />

                        <CheckBox Content="{DynamicResource LOCPlayAch_CustomRefresh_ForceIncludeBypass}"
                                  IsChecked="{Binding ForceBypassExclusionsForExplicitIncludes, Mode=TwoWay}"
                                  Foreground="{DynamicResource PlayAch.Brush.Text}"
                                  Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}" />

                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding UseParallelOverride, Mode=TwoWay}"
                                      Content="{DynamicResource LOCPlayAch_CustomRefresh_UseParallelOverride}"
                                      Foreground="{DynamicResource PlayAch.Brush.Text}" />
                            <CheckBox Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                      Content="{DynamicResource LOCPlayAch_Settings_EnableParallelProviderRefresh}"
                                      IsChecked="{Binding RunProvidersInParallelValue, Mode=TwoWay}"
                                      Foreground="{DynamicResource PlayAch.Brush.Text}"
                                      IsEnabled="{Binding UseParallelOverride}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <Border Grid.Row="5"
                        Background="{DynamicResource PlayAch.Brush.Surface}"
                        BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                        Padding="8">
                    <TextBlock Text="{Binding SummaryText}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="{DynamicResource LOCPlayAch_Button_Refresh}"
                    Click="RunButton_Click"
                    IsEnabled="{Binding CanRun}"
                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                    MinWidth="100"
                    Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                    IsDefault="True" />
            <Button Content="{DynamicResource LOCPlayAch_Button_Cancel}"
                    Click="CancelButton_Click"
                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"
                    MinWidth="100"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
    </Border>
</UserControl>

