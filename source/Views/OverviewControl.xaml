<UserControl x:Class="PlayniteAchievements.Views.OverviewControl"
             x:Name="OverviewControlRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:models="clr-namespace:PlayniteAchievements.Models.Achievements"
             xmlns:rootModels="clr-namespace:PlayniteAchievements.Models"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/OverviewScopedControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared LegendItem DataTemplate for all pie charts -->
            <DataTemplate x:Key="LegendItemTemplate">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Grid Width="18" Height="18" Margin="{StaticResource PlayAch.Thickness.Right.Compact}" VerticalAlignment="Center"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <!-- Badge icons: complex DrawingImages from AchievementResources.xaml -->
                        <Image Source="{Binding IconKey, Converter={StaticResource ResourceKeyToImage}}"
                               Effect="{StaticResource BadgeShadow}"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <!-- Provider icons: created at runtime from geometry + color -->
                        <Image SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                    <Binding Path="IconKey"/>
                                    <Binding Path="ColorHex"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Grid>
                    <TextBlock Text="{Binding Count}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DataTemplate>

            <Style x:Key="NavigationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="17"
                                    Width="34" Height="34">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource PlayAch.Brush.Overlay.Tint.20}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Compact, square close button for the selected-game header (kept small so it
                 does not expand the header row like the larger circular NavigationButtonStyle). -->
            <Style x:Key="ClearGameSelectionButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background}"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.72"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource PlayAch.Radius.Small}"
                                    SnapsToDevicePixels="True">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PlayAch.Brush.Button.Background.Hover}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Invisible button style for click areas -->
            <Style x:Key="InvisibleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Arrow"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Tab button style -->
            <Style x:Key="TabButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="{DynamicResource PlayAch.FontSize.Body}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                    <Border x:Name="indicator"
                                            Height="3"
                                            Background="{DynamicResource PlayAch.Brush.CompletedGame}"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,-10"
                                            Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource PlayAch.Brush.Overlay.Tint.10}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource PlayAch.Brush.Overlay.Tint.20}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Underline tab style for the Overview/Friends view switch.
                 Text-only tabs; the active tab (Tag="active") gets full text-brush
                 text and an accent underline bar (the accent stays on the bar only
                 because it can resolve to a gradient on some themes). The single-cell
                 grid keeps the label vertically centered with the window title. -->
            <Style x:Key="OverviewSubViewSwitchButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="Padding" Value="2,2"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text.Secondary}"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Content}"
                                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Margin="{TemplateBinding Padding}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"/>
                                <Border x:Name="Underline"
                                        Height="2"
                                        Margin="2,0"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="1"
                                        Background="{DynamicResource PlayAch.Brush.Accent}"
                                        Visibility="Hidden"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                    <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Underline" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="Tag" Value="active">
                                    <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PlayAch.Brush.Text}"/>
                                    <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Label" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Button style that disables during refresh -->
        <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayAch.Button.BaseStyle}">
                <Setter Property="Padding" Value="10,3"/>
                <Setter Property="MinWidth" Value="88"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>

            <!-- Game name button style with hover effect -->
            <Style x:Key="GameNameButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}"
                                       VerticalAlignment="Center"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       TextTrimming="CharacterEllipsis"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               VerticalAlignment="Center"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PlayAch.Brush.Accent}"
                                               TextTrimming="CharacterEllipsis"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RevealButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource PlayAch.Brush.Window.Background}" Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header with Title, Scores, and Refresh Buttons -->
        <Border Grid.Row="0"
                Background="Transparent"
                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                Padding="8,0,8,4"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveRefreshHeader.ShowProgress, ElementName=OverviewControlRoot}" Value="True">
                            <Setter Property="BorderThickness" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Back button, title, and refresh controls -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,18,0">
                    <Button x:Name="CloseViewButton"
                            Command="{Binding CloseViewCommand}"
                            Content="&#xE72B;"
                            Style="{StaticResource NavigationButtonStyle}"
                            ToolTip="{Binding CloseViewToolTip}"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Title_PluginName}"
                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                               FontWeight="Bold"
                               FontSize="20"
                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                               VerticalAlignment="Center"
                               MaxWidth="230"
                               TextTrimming="CharacterEllipsis"
                               Margin="{StaticResource PlayAch.Thickness.Left.Md}"/>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0"
                                Visibility="{Binding EnableFriendsFeatures, Converter={StaticResource BoolToVis}}">
                        <Button x:Name="OverviewSubViewButton"
                                Content="{DynamicResource LOCPlayAch_ManageAchievements_Tab_Overview}"
                                Click="OverviewSubViewButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OverviewSubViewSwitchButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView, ElementName=OverviewControlRoot}" Value="{x:Static rootModels:OverviewSubView.Overview}">
                                            <Setter Property="Tag" Value="active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="FriendsSubViewButton"
                                Content="{DynamicResource LOCPlayAch_Settings_Friends}"
                                Click="FriendsSubViewButton_Click"
                                Margin="18,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OverviewSubViewSwitchButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView, ElementName=OverviewControlRoot}" Value="{x:Static rootModels:OverviewSubView.Friends}">
                                            <Setter Property="Tag" Value="active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="18,0,0,0">
                        <Button x:Name="RefreshModeSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Content="{Binding ActiveRefreshHeader.RefreshModeSelectionText, ElementName=OverviewControlRoot}"
                                Click="RefreshModeSelectionButton_Click"
                                HorizontalContentAlignment="Center"
                                MinWidth="94"
                                MinHeight="24"
                                Margin="{StaticResource PlayAch.Thickness.Right.Compact}"
                                VerticalAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="RefreshModeSelectionContextMenu"
                                             Style="{StaticResource AchievementSelectorContextMenuStyle}"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                            </Button.ContextMenu>
                        </Button>

                        <Button x:Name="RefreshActionButton"
                                Content="{Binding ActiveRefreshHeader.RefreshOrCancelButtonText, ElementName=OverviewControlRoot}"
                                Command="{Binding ActiveRefreshHeader.RefreshOrCancelCommand, ElementName=OverviewControlRoot}"
                                Style="{StaticResource RefreshButtonStyle}"
                                Margin="0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Collection and Prestige scores -->
                <StackPanel Grid.Row="1"
                             Grid.Column="1"
                             Orientation="Horizontal"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             MaxWidth="740"
                             Margin="18,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowOverviewScoreCards}" Value="True"/>
                                        <Condition Binding="{Binding ActiveSubView, ElementName=OverviewControlRoot}" Value="{x:Static rootModels:OverviewSubView.Overview}"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <controls:ScoreCardControl Width="300"
                                               ScoreCard="{Binding CollectionScoreCard}"
                                               InfoRequested="ScoreCard_InfoRequested"
                                               Visibility="{Binding ShowOverviewCollectionScoreCard, Converter={StaticResource BoolToVis}}"/>

                    <Border Background="{DynamicResource PlayAch.Brush.ControlBorder}"
                            Opacity="{StaticResource PlayAch.Opacity.Disabled}"
                            VerticalAlignment="Center"
                            Width="1"
                            Height="42"
                            Margin="12,2"
                            Visibility="{Binding ShowOverviewScoreCardDivider, Converter={StaticResource BoolToVis}}"/>

                    <controls:ScoreCardControl Width="300"
                                               ScoreCard="{Binding PrestigeScoreCard}"
                                               InfoRequested="ScoreCard_InfoRequested"
                                               Visibility="{Binding ShowOverviewPrestigeScoreCard, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <Button x:Name="FriendsClearSelectionButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        Content="&#x2715;"
                        ToolTip="{DynamicResource LOCPlayAch_FriendsOverview_ClearSelection}"
                        Click="FriendsClearSelectionButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ClearGameSelectionButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowFriendsClearSelection, ElementName=OverviewControlRoot}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>

        <!-- ROW 1: Progress Bar -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,8"
                Visibility="{Binding ActiveRefreshHeader.ShowProgress, ElementName=OverviewControlRoot, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding ActiveRefreshHeader.ProgressMessage, ElementName=OverviewControlRoot}"
                           Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Secondary}"
                           TextTrimming="CharacterEllipsis"
                           Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>
                <ProgressBar Value="{Binding ActiveRefreshHeader.ProgressPercent, ElementName=OverviewControlRoot, Mode=OneWay}"
                              Height="6"
                             Minimum="0"
                             Maximum="100"/>
            </StackPanel>
        </Border>

        <!-- ROW 2: Tab Content -->
        <Grid Grid.Row="2">
            <!-- Overview Tab Content -->
            <Grid x:Name="OverviewContent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSubView, ElementName=OverviewControlRoot}" Value="{x:Static rootModels:OverviewSubView.Overview}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="OverviewLeftColumn" Width="*" MinWidth="560"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="OverviewRightColumn" Width="*" MinWidth="480"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: Header (Row 0) -->
                    <Border Grid.Row="0" Grid.Column="0"
                            Background="Transparent"
                            Height="{StaticResource PlayAch.Size.Header.Height}"
                            Padding="8,0"
                            BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Overview_GameSummaries}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <!-- LEFT: Games List -->
                    <Border Grid.Row="1" Grid.Column="0">
                        <Grid x:Name="OverviewBottomChartsGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                        <controls:GameSummariesGridControl x:Name="GameSummariesGridControl"
                                                                Grid.Row="0"
                                                                Margin="8,8,8,0"
                                                                KeyboardNavigation.DirectionalNavigation="Contained"
                                                                ItemsSource="{Binding GameSummaries}"
                                                                SelectedItem="{Binding SelectedGame, Mode=OneWay}"
                                                                UseCoverImages="{Binding UseCoverImagesGameSummaries}"
                                                                ShowMetadataPlatform="{Binding ShowOverviewGameMetadataPlatform}"
                                                                ShowMetadataPlaytime="{Binding ShowOverviewGameMetadataPlaytime}"
                                                                ShowMetadataRegion="{Binding ShowOverviewGameMetadataRegion}"
                                                                ShowCompletionBorder="{Binding ShowCompletionBorder}"
                                                                ShowColumnHeaders="{Binding ShowOverviewGameSummariesGridColumnHeaders}"
                                                                FixedRowHeight="{Binding OverviewGameSummariesGridRowHeight}"
                                                                DelayInitialRenderUntilNormalized="True"
                                                                ControlBar="{Binding GameSummariesControlBar}"
                                                                ShowControlBar="{Binding ShowOverviewGameSummariesGridControlBar}"
                                                                ColumnSettingsKey="OverviewGameSummaries"
                                                                SelectionChanged="GameSummaries_SelectionChanged"
                                                                RowPreviewMouseLeftButtonDown="GameSummaries_PreviewMouseLeftButtonDown"
                                                                Sorting="DataGrid_Sorting"
                                                                RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>
                    </Border>
                    
                    <!-- RIGHT: Header -->
                    <Grid Grid.Row="0" Grid.Column="2">
                        <!-- Header for when NO game is selected -->
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                                BorderThickness="0,0,0,1"
                                Height="{StaticResource PlayAch.Size.Header.Height}"
                                Padding="8,0"
                                Visibility="{Binding ShowRecentAchievementsPanel, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource LOCPlayAch_RecentAchievements}"
                                       Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Header for when a game IS selected -->
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                                BorderThickness="0,0,0,1"
                                Height="{StaticResource PlayAch.Size.Header.Height}"
                                Padding="8,0"
                                Visibility="{Binding IsSelectedGameContentReady, Converter={StaticResource BoolToVis}}">

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <TextBlock Text="{Binding DisplayedSelectedGame.GameName}"
                                        FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource PlayAch.Brush.Text}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center"
                                        MouseLeftButtonUp="GameNameBreadcrumb_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Cursor" Value="Arrow"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelectedGameDrilledIntoCategory}" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Text=" > "
                                        FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                        Foreground="{DynamicResource PlayAch.Brush.Text}"
                                        Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsSelectedGameDrilledIntoCategory, Converter={StaticResource BoolToVis}}"/>

                                <TextBlock Text="{Binding SelectedGameDrilledCategory}"
                                        FontSize="{DynamicResource PlayAch.FontSize.Body}"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource PlayAch.Brush.Text}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsSelectedGameDrilledIntoCategory, Converter={StaticResource BoolToVis}}"/>

                                <TextBlock Text="{Binding SelectedGameHeaderText}"
                                        FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                        Foreground="{DynamicResource PlayAch.Brush.Text}"
                                        Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                        Margin="{StaticResource PlayAch.Thickness.Left.Sm}"
                                        VerticalAlignment="Center"/>

                                <Button x:Name="ClearGameSelectionButton"
                                        Content="✕"
                                        Style="{StaticResource ClearGameSelectionButtonStyle}"
                                        Click="ClearGameSelection_Click"
                                        Margin="10,0,0,0"/>

                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                            BorderThickness="1,0,0,1"
                            IsHitTestVisible="False"/>

                    <!-- RIGHT: Content (Recent List OR Game Details) -->
                    <Grid Grid.Row="1" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Content Area: Recent List OR Game Details -->
                        <Grid Grid.Row="0">
                            <!-- Default Panel: When no game selected -->
                            <Grid Visibility="{Binding ShowRecentAchievementsPanel, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                            <controls:AchievementDataGridControl x:Name="RecentAchievementsDataGrid"
                                                                 Grid.Row="0"
                                                                 Margin="8,8,8,0"
                                                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                                                 ItemsSource="{Binding RecentAchievements}"
                                                                 ColumnSettingsKey="OverviewRecentAchievements"
                                                                 ShowGameColumn="True"
                                                                 UseCoverImages="{Binding UseCoverImagesRecentAchievements}"
                                                                 ShowRarityGlow="{Binding ShowRarityGlowRecentAchievements}"
                                                                 ColorNamesByRarity="{Binding ColorNamesByRarityRecentAchievements}"
                                                                 ShowColumnHeaders="{Binding ShowOverviewRecentAchievementsGridColumnHeaders}"
                                                                 FixedRowHeight="{Binding OverviewRecentAchievementsGridRowHeight}"
                                                                 DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                                                 DelayInitialRenderUntilNormalized="True"
                                                                 ControlBar="{Binding RecentAchievementsControlBar}"
                                                                 ShowControlBar="{Binding ShowOverviewRecentAchievementsGridControlBar}"
                                                                 UseExternalSorting="True"
                                                                 Sorting="AchievementDataGrid_Sorting"
                                                                 RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                 RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>

                        <!-- Game Detail Panel: When a game is selected -->
                        <Grid Visibility="{Binding IsSelectedGameContentReady, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Game Achievements List -->
                            <controls:AchievementDataGridControl x:Name="GameAchievementsGrid"
                                                                 Grid.Row="0"
                                                                 Margin="8,8,8,0"
                                                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                                                 ItemsSource="{Binding SelectedGameAchievements}"
                                                                 ColumnSettingsKey="OverviewSelectedGameAchievements"
                                                                 EnableCategoryMode="True"
                                                                 HideBackButton="True"
                                                                 HideCategorySummaryRow="{Binding OverviewSelectedGameAchievementsHideCategorySummaryRow}"
                                                                 CategoryUseCoverImages="{Binding OverviewSelectedGameCategorySummariesUseCoverImages}"
                                                                 CategoryShowColumnHeaders="{Binding ShowOverviewSelectedGameCategorySummariesGridColumnHeaders}"
                                                                 CategoryFixedRowHeight="{Binding OverviewSelectedGameCategorySummariesGridRowHeight}"
                                                                 CategoryColumnSettingsKey="OverviewSelectedGameCategorySummaries"
                                                                 CategorySummarySource="{Binding SelectedGameAllAchievements}"
                                                                 DrilledCategory="{Binding SelectedGameDrilledCategory, Mode=OneWayToSource}"
                                                                 DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                                                 ShowRarityGlow="{Binding ShowRarityGlowSelectedGame}"
                                                                 ColorNamesByRarity="{Binding ColorNamesByRaritySelectedGame}"
                                                                 ShowColumnHeaders="{Binding ShowOverviewSelectedGameGridColumnHeaders}"
                                                                 FixedRowHeight="{Binding OverviewSelectedGameGridRowHeight}"
                                                                 DelayInitialRenderUntilNormalized="True"
                                                                 ControlBar="{Binding SelectedGameAchievementsControlBar}"
                                                                 ShowControlBar="{Binding ShowOverviewSelectedGameGridControlBar}"
                                                                 RevealCommand="{Binding DataContext.RevealAchievementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 UseExternalSorting="True"
                                                                 Sorting="GameAchievementsGrid_Sorting"
                                                                 RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                 RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="3"
                            MinHeight="225"
                            Margin="0,0,0,-20"
                            Padding="0,8,0,20"
                            Background="Transparent"
                            BorderBrush="{DynamicResource PlayAch.Brush.ControlBorder}"
                            BorderThickness="0,1,0,0">
                        <Border.Resources>
                            <DataTemplate x:Key="OverviewTimelineContentTemplate">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TimelineSectionTitle}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}">
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_7D}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=SevenDays}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="SevenDays"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_14D}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=FourteenDays}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="FourteenDays"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1M}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneMonth}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="OneMonth"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_3M}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=ThreeMonths}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="ThreeMonths"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1Y}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneYear}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="OneYear"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_Common_All}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=All}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="All"/>
                                    </StackPanel>

                                    <lvc:CartesianChart Grid.Row="2"
                                                        Series="{Binding GlobalTimeline.TimelineSeries}"
                                                        LegendLocation="None"
                                                        Hoverable="True"
                                                        DisableAnimations="True">
                                        <lvc:CartesianChart.Resources>
                                            <Style TargetType="lvc:ColumnSeries">
                                                <Setter Property="Fill" Value="{DynamicResource PlayAch.Brush.Accent}" />
                                            </Style>
                                        </lvc:CartesianChart.Resources>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Labels="{Binding GlobalTimeline.TimelineLabels}"
                                                      ShowLabels="True"
                                                      LabelsRotation="45"
                                                      FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                                      Foreground="{DynamicResource PlayAch.Brush.Text}">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Step="1" IsEnabled="False"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis MinValue="0"
                                                      LabelFormatter="{Binding GlobalTimeline.YAxisFormatter}"
                                                      FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                                      Foreground="{DynamicResource PlayAch.Brush.Text}">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Stroke="{DynamicResource PlayAch.Brush.Border}" Opacity="0.2"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </DataTemplate>
                        </Border.Resources>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowOverviewPieCharts}" Value="False"/>
                                            <Condition Binding="{Binding ShowOverviewBarCharts}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid x:Name="ChartsRowGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" x:Name="PieChartsColumn"/>
                                <ColumnDefinition Width="1*" x:Name="BarChartColumn"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Pie Charts -->
                            <Border x:Name="OverviewPieChartsHost"
                                    Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowOverviewPieCharts}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShowOverviewBarCharts}" Value="False">
                                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid x:Name="OverviewPieChartsGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                <!-- Games Completion Pie Chart -->
                                <Grid x:Name="GamesPieChartPanel" Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{DynamicResource LOCPlayAch_Overview_GamesPieChart}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding GamesPieChart.PieSeries}"
                                                                      LegendItems="{Binding GamesPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding GamesPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding GamesPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding GamesPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowOverviewPiePercentages}"
                                                                      IconOffset="12"
                                                                      SliceClick="OnGamesPieChartSliceClick"/>
                                </Grid>

                                <!-- Provider Distribution Pie Chart -->
                                <Grid x:Name="ProviderPieChartPanel" Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{DynamicResource LOCPlayAch_Overview_ProviderDistribution}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons x:Name="ProviderPieChartControl"
                                                                      Grid.Row="1"
                                                                      PieSeries="{Binding ProviderPieChart.PieSeries}"
                                                                      LegendItems="{Binding ProviderPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding ProviderPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding ProviderPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding ProviderPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowOverviewPiePercentages}"
                                                                      IconOffset="12"
                                                                      SliceClick="OnProviderPieChartSliceClick"/>
                                </Grid>

                                <!-- Rarity Pie Chart with Custom Legend -->
                                <Grid x:Name="RarityPieChartPanel" Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding RarityPieChartTitle}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding RarityPieChart.PieSeries}"
                                                                      LegendItems="{Binding RarityPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding RarityPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding RarityPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding RarityPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowOverviewPiePercentages}"
                                                                      IconOffset="12"/>
                                </Grid>

                                <!-- Trophy Pie Chart -->
                                <Grid x:Name="TrophyPieChartPanel" Grid.Column="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TrophyPieChartTitle}"
                                               Style="{DynamicResource PlayAch.TextBlock.BaseStyle}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Opacity="{StaticResource PlayAch.Opacity.Subtle}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding TrophyPieChart.PieSeries}"
                                                                      LegendItems="{Binding TrophyPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding TrophyPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding TrophyPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding TrophyPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowOverviewPiePercentages}"
                                                                      IconOffset="12"/>
                                </Grid>
                                </Grid>
                            </Border>

                            <!-- RIGHT: Timeline -->
                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ShowOverviewPieCharts}" Value="True"/>
                                                    <Condition Binding="{Binding ShowOverviewBarCharts}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentControl Content="{Binding}"
                                                ContentTemplate="{StaticResource OverviewTimelineContentTemplate}"/>
                            </Border>

                            <!-- FULL-WIDTH Timeline When Pie Charts Are Hidden -->
                            <Border Grid.ColumnSpan="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ShowOverviewPieCharts}" Value="False"/>
                                                    <Condition Binding="{Binding ShowOverviewBarCharts}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentControl Content="{Binding}"
                                                ContentTemplate="{StaticResource OverviewTimelineContentTemplate}"/>
                            </Border>
                        </Grid>
                    </Border>

                <GridSplitter Grid.Column="1"
                            Grid.Row="1"
                            Style="{StaticResource CenterLineSplitterStyle}"
                            DragCompleted="OverviewGridSplitter_DragCompleted"
                            Focusable="False"
                            IsTabStop="False"/>
            </Grid>

            <ContentControl x:Name="FriendsOverviewContentHost">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSubView, ElementName=OverviewControlRoot}" Value="{x:Static rootModels:OverviewSubView.Friends}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
    </Border>
</UserControl>


