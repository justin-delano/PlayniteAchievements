<UserControl x:Class="PlayniteAchievements.Views.SingleGameControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:models="clr-namespace:PlayniteAchievements.Models.Achievements"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:EnumToBoolConverter x:Key="EnumToBool"/>
            <converters:DefaultGameImageConverter x:Key="DefaultGameImage"/>
            <converters:IntToVisibilityConverter x:Key="IntToVis"/>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <Style x:Key="SecondaryMetadataTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Opacity" Value="0.6" />
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <!-- Style for Expander Header ToggleButton -->
            <Style x:Key="ExpanderHeaderStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Padding" Value="0,0,0,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Path x:Name="Arrow" Grid.Column="1"
                                          Data="M 0,0 L 4,4 L 8,0"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.5"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="180"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Game Header -->
        <Border Grid.Row="0"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,0,0,8"
            Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Game Icon -->
                <Border Grid.Column="0"
                    Height="48"
                        CornerRadius="4"
                    ClipToBounds="True"
                        Margin="0,0,12,0">
                    <Image Height="48"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       helpers:AsyncImage.Uri="{Binding GameIconPath, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"
                       helpers:AsyncImage.DecodePixel="96"/>
                </Border>
                
                <!-- Game Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameName}"
                                   FontSize="{DynamicResource FontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{DynamicResource FontSizeSmall}">
                            <Run Text="("/>
                            <Run Text="{Binding UnlockedAchievements, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalAchievements, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource LOCPlayAch_Achievements}"/>
                            <Run Text=")"/>
                        </TextBlock>

                        <Button Content="{DynamicResource LOCPlayAch_Button_Refresh}" Command="{Binding RefreshGameCommand}" Margin="12,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding RefreshStatusMessage}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="{Binding IsStatusMessageVisible, Converter={StaticResource BoolToVis}}" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding SecondaryMetadataText}"
                               Style="{StaticResource SecondaryMetadataTextStyle}"
                               Visibility="{Binding HasSecondaryMetadataText, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Complete Badge -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}">
                    <Image Source="{StaticResource BadgeCompletedGame}"
                           Style="{StaticResource RarityIcon}"
                           Effect="{StaticResource BadgeShadow}"
                           Width="24" Height="24"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Completed}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats and Timeline -->
        <Border Grid.Row="1"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,0,0,8"
            Padding="16,12,16,12"
                Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Stats Header -->
                <ToggleButton Grid.Row="0"
                              IsChecked="{Binding IsStatsVisible, Mode=TwoWay}"
                              Style="{StaticResource ExpanderHeaderStyle}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_Section_Stats}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"/>
                </ToggleButton>

                <!-- Collapsible Stats Section -->
                <StackPanel Grid.Row="1" Grid.RowSpan="2"
                            Visibility="{Binding IsStatsVisible, Converter={StaticResource BoolToVis}}">
                    <!-- Progress Bar -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Progress}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.7"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <ProgressBar Value="{Binding Progression, Mode=OneWay}"
                                         Style="{StaticResource GameProgressBar}"/>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Text="{Binding ProgressionText, Mode=OneWay}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Rarity Distribution (shown when no trophy types) -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="{Binding HasTrophyTypes, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Label_Rarity}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Rarity_UltraRare}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding UltraRareCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource BadgePlatinumHexagon}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding UltraRareCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Rarity_Rare}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding RareCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource BadgeGoldPentagon}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding RareCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Rarity_Uncommon}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding UncommonCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource BadgeSilverSquare}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding UncommonCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Rarity_Common}" VerticalAlignment="Center"
                                    Visibility="{Binding CommonCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource BadgeBronzeTriangle}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding CommonCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Trophy Distribution (shown when trophy types exist) -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="{Binding HasTrophyTypes, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource LOCPlayAch_Label_Trophies}"
                                   Style="{DynamicResource BaseTextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Trophy_Platinum}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding TrophyPlatinumCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource TrophyPlatinum}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding TrophyPlatinumCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Trophy_Gold}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding TrophyGoldCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource TrophyGold}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding TrophyGoldCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Trophy_Silver}" Margin="0,0,12,0" VerticalAlignment="Center"
                                    Visibility="{Binding TrophySilverCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource TrophySilver}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding TrophySilverCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" ToolTip="{DynamicResource LOCPlayAch_Trophy_Bronze}" VerticalAlignment="Center"
                                    Visibility="{Binding TrophyBronzeCount, Converter={StaticResource IntToVis}}">
                            <Image Source="{StaticResource TrophyBronze}" Style="{StaticResource RarityIcon}" Effect="{StaticResource BadgeShadow}" Width="18" Height="18"/>
                            <TextBlock Text="{Binding TrophyBronzeCount}" VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Timeline Header -->
                <ToggleButton Grid.Row="4"
                              IsChecked="{Binding IsTimelineVisible, Mode=TwoWay}"
                              Style="{StaticResource ExpanderHeaderStyle}">
                    <TextBlock Text="{DynamicResource LOCPlayAch_Section_Timeline}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"/>
                </ToggleButton>

                <!-- Collapsible Timeline Section -->
                <StackPanel Grid.Row="6"
                            Visibility="{Binding IsTimelineVisible, Converter={StaticResource BoolToVis}}">
                    <!-- Time Range Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_7D}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=SevenDays}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="SevenDays"/>
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_14D}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=FourteenDays}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="FourteenDays"/>
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1M}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneMonth}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="OneMonth"/>
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_3M}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=ThreeMonths}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="ThreeMonths"/>
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1Y}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneYear}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="OneYear"/>
                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_All}" GroupName="TimeRange"
                                     Style="{StaticResource TimeRangeButtonStyle}"
                                     IsChecked="{Binding Timeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=All}"
                                     Command="{Binding Timeline.SetTimeRangeCommand}" CommandParameter="All"/>
                    </StackPanel>

                    <!-- LiveCharts Timeline -->
                    <lvc:CartesianChart Height="120"
                                        Series="{Binding Timeline.TimelineSeries}"
                                        LegendLocation="None"
                                        Hoverable="True"
                                        DisableAnimations="True">
                        <lvc:CartesianChart.Resources>
                            <Style TargetType="lvc:ColumnSeries">
                                <Setter Property="Fill" Value="{DynamicResource HighlightGlyphBrush}" />
                            </Style>
                        </lvc:CartesianChart.Resources>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding Timeline.TimelineLabels}"
                                      ShowLabels="True"
                                      LabelsRotation="45"
                                      FontSize="{DynamicResource FontSizeSmall}"
                                      Foreground="{DynamicResource TextBrush}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" IsEnabled="False"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis MinValue="0"
                                      LabelFormatter="{Binding Timeline.YAxisFormatter}"
                                      FontSize="{DynamicResource FontSizeSmall}"
                                      Foreground="{DynamicResource TextBrush}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Stroke="{DynamicResource NormalBorderBrush}" Opacity="0.2"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search Achievements -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,8"
                Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                    <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Achievements}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.5"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Tag="{Binding SearchText}"
                            Click="ClearSearch_Click"
                            Style="{StaticResource ClearSearchButtonStyle}"/>
                </Grid>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0">
                <Button x:Name="CategoryTypeFilterSelectionButton"
                        Style="{StaticResource AchievementSelectorButtonStyle}"
                        Content="{Binding SelectedCategoryTypeFilterText}"
                        Click="CategoryTypeFilterSelectionButton_Click"
                        Width="120"
                        Height="30"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        ToolTip="{DynamicResource LOCPlayAch_GameOptions_Category_Filter_Type}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="CategoryTypeFilterSelectionContextMenu"
                                     ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="CategoryLabelFilterSelectionButton"
                        Style="{StaticResource AchievementSelectorButtonStyle}"
                        Content="{Binding SelectedCategoryLabelFilterText}"
                        Click="CategoryLabelFilterSelectionButton_Click"
                        Width="140"
                        Height="30"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        ToolTip="{DynamicResource LOCPlayAch_GameOptions_Category_Filter_Label}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="CategoryLabelFilterSelectionContextMenu"
                                     ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                    </Button.ContextMenu>
                </Button>
                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Unlocked}"
                      IsChecked="{Binding ShowUnlocked}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
                <CheckBox Content="{DynamicResource LOCPlayAch_Common_Locked}"
                      IsChecked="{Binding ShowLocked}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
                <CheckBox Content="{DynamicResource LOCPlayAch_Filter_Hidden}"
                      IsChecked="{Binding ShowHidden}"
                      VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- No Achievements Placeholder -->
        <Grid Grid.Row="3"
              Visibility="{Binding HasAchievements, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <TextBlock Text="{DynamicResource LOCPlayAch_NoAchievementsTitle}"
                           FontSize="{DynamicResource FontSizeLarge}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource LOCPlayAch_NoAchievementsMessage}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource LOCPlayAch_NoAchievementsMessageAlt}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.5"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           FontSize="{DynamicResource FontSizeSmall}"/>
            </StackPanel>
        </Grid>

        <!-- Achievements List -->
        <controls:AchievementDataGridControl x:Name="AchievementsDataGridControl"
                                             Grid.Row="3"
                                             Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}"
                                             ItemsSource="{Binding Achievements}"
                                             RevealCommand="{Binding RevealAchievementCommand}"
                                             ColumnSettingsKey="SingleGame"
                                             UseExternalSorting="True"
                                             Sorting="OnGridSorting"/>
    </Grid>
</UserControl>


