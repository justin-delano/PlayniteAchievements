<UserControl x:Class="PlayniteAchievements.Views.GameOptionsNotesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:GameOptionsNotesViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanConverter x:Key="BoolToVis" Mode="ToVisibility" />
            <converters:BooleanConverter x:Key="InverseBoolToVis" Mode="InvertedToVisibility" />

            <DataTemplate x:Key="NotesAchievementInfoTemplate">
                <StackPanel Margin="12,10"
                            VerticalAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                            HorizontalAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}"
                            Background="Transparent">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellTextAlignment)}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Unlocked}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTitleHidden}" Value="True">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding DisplayNameResolved, Mode=OneWay}"/>
                        <Run Text="{Binding HiddenTitleSuffix, Mode=OneWay}"
                             FontStyle="Italic"
                             FontSize="{DynamicResource FontSizeSmall}"
                             Foreground="{DynamicResource TextBrushDarker}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding DescriptionResolved}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.7"
                               TextWrapping="Wrap"
                               TextAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"
                               MaxHeight="44"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDescriptionHidden}" Value="True">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ApiNameResolved}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.58"
                               TextWrapping="Wrap"
                               TextAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Notes_Header}"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{DynamicResource LOCPlayAch_GameOptions_Notes_Hint}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12" MinHeight="34" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="170" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchTextBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ClearableSearchTextBoxStyle}"
                         Height="30"
                         VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource LOCPlayAch_Common_FilterAchievementsPlaceholder}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.5"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="ClearSearchButton"
                        Tag="{Binding SearchText}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource ClearSearchButtonStyle}" />
            </Grid>

            <ComboBox x:Name="StateFilterComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding NoteOptions}"
                      SelectedItem="{Binding SelectedNoteOption, Mode=TwoWay}"
                      DisplayMemberPath="DisplayName"
                      Height="30"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource LOCPlayAch_Common_NoCachedAchievementsForGame}"
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   Margin="0"
                   Visibility="{Binding HasAchievements, Converter={StaticResource InverseBoolToVis}}" />

        <DataGrid x:Name="NotesDataGrid"
                  Grid.Row="2"
                  Margin="0,2,0,0"
                  ItemsSource="{Binding AchievementRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Visibility="{Binding HasAchievements, Converter={StaticResource BoolToVis}}"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowBackground="Transparent"
                  BorderThickness="0"
                  Background="Transparent"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  RowHeight="104"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ColumnHeaderStyle="{StaticResource AchievementColumnHeaderStyle}"
                  helpers:DataGridAlignmentBehavior.IsEnabled="True"
                  Tag="ControllerCellFocus"
                  PreviewMouseLeftButtonDown="NotesDataGrid_PreviewMouseLeftButtonDown">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource GameOptionsControllerCellStyle}" />
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource GameOptionsDataGridRowStyle}">
                    <Setter Property="MinHeight" Value="68" />
                    <Setter Property="ClipToBounds" Value="True" />
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="36" MinWidth="36" MaxWidth="36" CanUserResize="False"
                                        CellStyle="{StaticResource GameOptionsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementStatusTemplate}" />

                <DataGridTemplateColumn Width="64" MinWidth="64" MaxWidth="64" CanUserResize="False"
                                        CellStyle="{StaticResource GameOptionsIconCellStyle}"
                                        CellTemplate="{StaticResource AchievementIconTemplate}" />

                <DataGridTemplateColumn Width="2*" Header="{DynamicResource LOCPlayAch_Column_Achievement}"
                                        CellTemplate="{StaticResource NotesAchievementInfoTemplate}" />

                <DataGridTemplateColumn Width="2*" Header="{DynamicResource LOCPlayAch_GameOptions_Notes_Note}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,8"
                                        VerticalAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellVerticalAlignment)}"
                                        HorizontalAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellHorizontalAlignment)}">
                                <TextBlock Text="{Binding NoteStatusText}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           Opacity="0.85"
                                           TextAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellTextAlignment)}" />
                                <Border Background="#08000000"
                                        BorderBrush="{DynamicResource NormalBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,4,0,0"
                                        Padding="6"
                                        MaxHeight="70"
                                        ClipToBounds="True"
                                        Visibility="{Binding HasAchievementNote, Converter={StaticResource BoolToVis}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="VerticalOnly">
                                        <TextBlock helpers:AchievementNoteInlineFormatter.FormattedText="{Binding AchievementNote}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Opacity="0.68"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:DataGridAlignmentBehavior.CellTextAlignment)}"
                                                   Padding="0,0,8,0" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="142"
                                        MinWidth="132"
                                        Header="{DynamicResource LOCPlayAch_Common_Actions}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="{DynamicResource LOCPlayAch_Common_View}"
                                        Click="ViewButton_Click"
                                        IsEnabled="{Binding HasAchievementNote}"
                                        Padding="9,4"
                                        Margin="0,0,6,0" />
                                <Button Content="{DynamicResource LOCPlayAch_Common_Edit}"
                                        Click="EditButton_Click"
                                        Padding="9,4" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
