<modern:AchievementCompactListControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementCompactUnlockedListControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                   xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
                   xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                   mc:Ignorable="d"
                   d:DesignHeight="82" d:DesignWidth="600"
                   UseLayoutRounding="True"
                   SnapsToDevicePixels="True"
                   ShowRarityGlow="{Binding Persisted.ModernUnlockedListShowRarityGlow}">

    <modern:AchievementCompactListControlBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </modern:AchievementCompactListControlBase.Resources>

    <Grid>
    <!-- Virtualized horizontal compact list -->
    <ItemsControl x:Name="AchievementsList"
                  ItemsSource="{Binding DisplayItems, Mode=OneWay, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
        <ItemsControl.Style>
            <Style TargetType="ItemsControl">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Persisted.EnableAchievementCompactUnlockedListControl, RelativeSource={RelativeSource AncestorType=local:ThemeControlBase}}"
                                 Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ItemsControl.Style>
        <ItemsControl.Template>
            <ControlTemplate TargetType="ItemsControl">
                <ScrollViewer CanContentScroll="True"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="{StaticResource PlayAch.Thickness.None}"
                              ClipToBounds="False"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ItemsPresenter/>
                </ScrollViewer>
            </ControlTemplate>
        </ItemsControl.Template>

        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel Orientation="Horizontal"
                                        IsItemsHost="True"
                                        VirtualizationMode="Recycling"
                                        ClipToBounds="False"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="ClipToBounds" Value="False"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>
        </ItemsControl.ItemContainerStyle>

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- Use shared compact item control -->
                <controls:AchievementCompactItemControl
                    IconSize="{Binding IconSize, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}"
                    Margin="4"/>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Empty state message, sized to the icon row height like the legacy control -->
    <Border MinHeight="{Binding IconSize, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}"
            Margin="4">
        <Border.Style>
            <Style TargetType="{x:Type Border}">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DisplayItems.Count, RelativeSource={RelativeSource AncestorType=modern:AchievementCompactListControlBase}}"
                                 Value="0">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Persisted.EnableAchievementCompactUnlockedListControl, RelativeSource={RelativeSource AncestorType=local:ThemeControlBase}}"
                                 Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <TextBlock Text="{DynamicResource LOCPlayAch_NoUnlockedAchievements}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextBrushDarker}"/>
    </Border>
    </Grid>
</modern:AchievementCompactListControlBase>


