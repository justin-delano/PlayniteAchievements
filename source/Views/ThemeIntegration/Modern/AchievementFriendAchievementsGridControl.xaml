<base:ThemeControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementFriendAchievementsGridControl"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                       xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
                       xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                       xmlns:sys="clr-namespace:System;assembly=mscorlib"
                       mc:Ignorable="d"
                       d:DesignHeight="300" d:DesignWidth="700">
    <controls:AchievementDataGridControl ItemsSource="{Binding DisplayItems, RelativeSource={RelativeSource AncestorType=modern:AchievementFriendAchievementsGridControl}}"
                                         ColumnSettingsKey="FriendsOverviewRecentAchievements"
                                         ShowGameColumn="True"
                                         ShowFriendColumn="True"
                                         HideStatusColumn="True"
                                         UseCoverImages="{Binding DataContext.Persisted.FriendsOverviewAchievementsUseCoverImages, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         ShowRarityGlow="{Binding DataContext.Persisted.FriendsOverviewAchievementsShowRarityGlow, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         ColorNamesByRarity="{Binding DataContext.Persisted.FriendsOverviewAchievementsColorNamesByRarity, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         ShowColumnHeaders="{Binding DataContext.Persisted.ShowFriendsOverviewAchievementsGridColumnHeaders, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         FixedRowHeight="{Binding DataContext.Persisted.FriendsOverviewAchievementsGridRowHeight, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                         DelayInitialRenderUntilNormalized="True"/>
</base:ThemeControlBase>
