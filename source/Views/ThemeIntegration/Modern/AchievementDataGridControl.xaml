<base:ThemeControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementDataGridControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                   xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
                   xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                   mc:Ignorable="d"
                   d:DesignHeight="300" d:DesignWidth="600">

    <base:ThemeControlBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </base:ThemeControlBase.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Breadcrumb, shown only once a category is selected. The game name is the clickable
             back link (matching the other surfaces' breadcrumb headers); the category itself is
             plain text since it's the current location, not a navigation target. -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,8"
                    Visibility="{Binding IsCategorySelected, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding GameName, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}}"
                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       TextTrimming="CharacterEllipsis"
                       Cursor="Hand"
                       TextDecorations="Underline"
                       MouseLeftButtonUp="GameNameBreadcrumb_Click"/>
            <TextBlock Text=" > "
                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       Opacity="{StaticResource PlayAch.Opacity.Subtle}"/>
            <TextBlock Text="{Binding SelectedCategoryName, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}}"
                       FontSize="{DynamicResource PlayAch.FontSize.Body}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <controls:AchievementDataGridControl x:Name="AchievementsGrid"
                                             Grid.Row="1"
                                             ItemsSource="{Binding DisplayItems, Mode=OneWay, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}}"
                                             ColumnSettingsKey="DesktopTheme"
                                             EnableCategoryMode="True"
                                             HideBackButton="True"
                                             HideCategorySummaryRow="{Binding DataContext.Persisted.DesktopThemeAchievementGridHideCategorySummaryRow, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             DrilledCategory="{Binding SelectedCategoryName, Mode=OneWayToSource, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}}"
                                             CategoryUseCoverImages="{Binding DataContext.Persisted.DesktopThemeCategorySummariesUseCoverImages, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             CategoryShowCompletionGlow="{Binding DataContext.Persisted.DesktopThemeCategorySummariesShowCompletionGlow, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             CategoryShowColumnHeaders="{Binding DataContext.Persisted.ShowDesktopThemeCategorySummariesGridColumnHeaders, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             CategoryFixedRowHeight="{Binding DataContext.Persisted.DesktopThemeCategorySummariesGridRowHeight, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             CategoryColumnSettingsKey="DesktopThemeCategorySummaries"
                                             ControlBar="{Binding ControlBar, RelativeSource={RelativeSource AncestorType=modern:AchievementDataGridControl}}"
                                             ShowControlBar="{Binding DataContext.Persisted.ShowDesktopThemeAchievementGridControlBar, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             ShowRarityGlow="{Binding DataContext.Persisted.ModernDataGridShowRarityGlow, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             ColorNamesByRarity="{Binding DataContext.Persisted.ModernDataGridColorNamesByRarity, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             ColorRarityColumnsByRarity="{Binding DataContext.Persisted.ModernDataGridColorRarityColumnsByRarity, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             ShowColumnHeaders="{Binding DataContext.Persisted.ShowDesktopThemeAchievementGridColumnHeaders, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             FixedRowHeight="{Binding DataContext.Persisted.DesktopThemeAchievementGridRowHeight, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                             UseExternalSorting="True"
                                             Sorting="AchievementsGrid_Sorting"
                                             RowPreviewMouseRightButtonDown="AchievementsGrid_RowPreviewMouseRightButtonDown"
                                             RowPreviewMouseRightButtonUp="AchievementsGrid_RowPreviewMouseRightButtonUp">
            <controls:AchievementDataGridControl.Style>
                <Style TargetType="controls:AchievementDataGridControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.Persisted.EnableAchievementDataGridControl, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                     Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:AchievementDataGridControl.Style>
        </controls:AchievementDataGridControl>
    </Grid>
</base:ThemeControlBase>


