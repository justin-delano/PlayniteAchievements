<base:ThemeControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementPieChartControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                   xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                   mc:Ignorable="d"
                   d:DesignHeight="200" d:DesignWidth="200">

    <controls:PieChartWithRadialIcons PieSeries="{Binding PieSeries, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, Mode=OneWay}"
                                      LegendItems="{Binding LegendItems, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, Mode=OneWay}"
                                      IconOffset="12">
        <controls:PieChartWithRadialIcons.Style>
            <Style TargetType="controls:PieChartWithRadialIcons">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.Persisted.EnableAchievementPieChartControl, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                 Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </controls:PieChartWithRadialIcons.Style>
    </controls:PieChartWithRadialIcons>
</base:ThemeControlBase>

