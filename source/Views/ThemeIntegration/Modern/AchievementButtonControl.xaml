<base:ThemeControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementButtonControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
                   xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                   mc:Ignorable="d"
                   d:DesignHeight="40" d:DesignWidth="200">

    <base:ThemeControlBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanConverter x:Key="BooleanToVisibilityConverter" Mode="ToVisibility" />
            <converters:BooleanConverter x:Key="InverseBoolToVisConverter" Mode="InvertedToVisibility" />
            <converters:HeightToFontSizeConverter x:Key="HeightToFontSizeConverter" />
        </ResourceDictionary>
    </base:ThemeControlBase.Resources>

    <Button x:Name="PART_PluginButton" Click="PART_PluginButton_Click">
        <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.Persisted.EnableAchievementButtonControl, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                 Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Button.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Trophy icon (shown when DisplayDetails=False) -->
            <TextBlock Grid.Column="0"
                       Text="&#xedd7;" FontFamily="{DynamicResource FontIcoFont}"
                       VerticalAlignment="Center"
                       Visibility="{Binding DisplayDetails, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, Converter={StaticResource InverseBoolToVisConverter}}"
                       FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, FallbackValue=14}"/>

            <!-- Details grid (shown when DisplayDetails=True) -->
            <Grid Grid.Column="1" HorizontalAlignment="Stretch"
                  Visibility="{Binding DisplayDetails, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Completed game indicator (checkmark) -->
                <TextBlock Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                           Text="&#xea33;" FontFamily="{DynamicResource CommonFont}"
                           Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                           VerticalAlignment="Center" Padding="5,3,5,5"
                           FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}, FallbackValue=14}"/>

                <!-- "Achievements" label -->
                <TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3"
                           Margin="0,-3,0,-3"
                           Text="{DynamicResource LOCPlayAch_Achievements}" Padding="5,3,5,5"
                           FontSize="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource HeightToFontSizeConverter}, FallbackValue=12}"/>

                <!-- Progress count (X/Y) -->
                <TextBlock Grid.Column="1" Grid.Row="2"
                           Margin="0,-3,0,-3" Padding="5,3,5,5"
                           FontSize="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource HeightToFontSizeConverter}, FallbackValue=12}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}/{1}">
                            <Binding Path="UnlockedCount" FallbackValue="0"/>
                            <Binding Path="AchievementCount" FallbackValue="0"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <!-- Progress bar -->
                <StackPanel Grid.Column="3" Grid.Row="2" x:Name="PART_GridProgressBar">
                    <ProgressBar Height="12" Width="{Binding ElementName=PART_GridProgressBar, Path=ActualWidth}"
                                 Maximum="{Binding AchievementCount, Mode=OneWay, FallbackValue=100}"
                                 Value="{Binding UnlockedCount, Mode=OneWay, FallbackValue=30}">
                        <ProgressBar.Style>
                            <Style TargetType="{x:Type ProgressBar}" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Foreground" Value="{Binding ElementName=PART_PluginButton, Path=Foreground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </Grid>
        </Grid>
    </Button>
</base:ThemeControlBase>

