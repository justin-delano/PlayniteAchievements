<base:ThemeControlBase x:Class="PlayniteAchievements.Views.ThemeIntegration.Modern.AchievementFriendSummariesGridControl"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:base="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Base"
                       xmlns:modern="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Modern"
                       xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
                       mc:Ignorable="d"
                       d:DesignHeight="300" d:DesignWidth="600">
    <controls:FriendSummariesGridControl ItemsSource="{Binding DisplayItems, RelativeSource={RelativeSource AncestorType=modern:AchievementFriendSummariesGridControl}}"
                                         ShowColumnHeaders="{Binding DataContext.Persisted.ShowFriendsOverviewFriendSummariesGridColumnHeaders, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         FixedRowHeight="{Binding DataContext.Persisted.FriendsOverviewFriendSummariesGridRowHeight, RelativeSource={RelativeSource AncestorType=base:ThemeControlBase}}"
                                         DelayInitialRenderUntilNormalized="True"/>
</base:ThemeControlBase>
