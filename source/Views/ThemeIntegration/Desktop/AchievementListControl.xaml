                   d:DesignHeight="300" d:DesignWidth="600">

    <controls:AchievementDataGridControl ItemsSource="{Binding DisplayItems, Mode=OneWay, RelativeSource={RelativeSource AncestorType=desktop:AchievementListControl}}"
