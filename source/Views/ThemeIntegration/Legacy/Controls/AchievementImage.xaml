<UserControl x:Class="PlayniteAchievements.Views.ThemeIntegration.Legacy.Controls.AchievementImage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PlayniteAchievements.Views.ThemeIntegration.Legacy.Controls"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" d:DesignHeight="48" d:DesignWidth="48"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Height="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Height}"
          Width="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Width}"
          ClipToBounds="False"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- Border for image container -->
        <Border>
            <Grid ClipToBounds="False"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Image Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       helpers:AsyncImage.DecodePixel="256"
                       SnapsToDevicePixels="True"
                       IsHitTestVisible="False"
                       Width="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Width}"
                       Height="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Height}"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                    <helpers:AsyncImage.Uri>
                        <MultiBinding Converter="{StaticResource LockedIconSelectorConverter}">
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="IsLocked" />
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="IconCustom" />
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="Icon" />
                        </MultiBinding>
                    </helpers:AsyncImage.Uri>
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=EnableRaretyIndicator}" Value="True"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsLocked}" Value="False"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ShowRarityGlow}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Effect" Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Rarity, Converter={StaticResource PercentToRarityGlowConverter}}"/>
                                </MultiDataTrigger>
                                <!-- Hardcore achievements use a solid border instead of the soft glow. -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=EnableRaretyIndicator}" Value="True"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsLocked}" Value="False"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ShowRarityGlow}" Value="True"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsHardcore}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <Image Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       helpers:AsyncImage.DecodePixel="256"
                       SnapsToDevicePixels="True"
                       Width="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Width}"
                       Height="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Height}"
                       x:Name="PART_Image"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Loaded="Image_Loaded" ImageFailed="Image_ImageFailed">
                    <helpers:AsyncImage.Uri>
                        <MultiBinding Converter="{StaticResource LockedIconSelectorConverter}">
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="IsLocked" />
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="IconCustom" />
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="Icon" />
                        </MultiBinding>
                    </helpers:AsyncImage.Uri>
                </Image>
            </Grid>
        </Border>

        <!-- Solid rarity border for Hardcore achievements (replaces the glow). -->
        <Border BorderThickness="3"
                Background="Transparent"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True"
                BorderBrush="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Rarity, Converter={StaticResource RarityToSolidBrush}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=EnableRaretyIndicator}" Value="True"/>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsLocked}" Value="False"/>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ShowRarityGlow}" Value="True"/>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsHardcore}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Custom icon text overlay (only shown when using custom locked icon) -->
        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IconText, FallbackValue='🔒'}"
                   VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Name="PART_IconText" FontWeight="Bold"
                   Foreground="Black"
                   Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect Color="White" Opacity="{StaticResource PlayAch.Opacity.Hint}" BlurRadius="3" ShadowDepth="0" />
            </TextBlock.Effect>
        </TextBlock>

        <!-- Progress bar overlay (always visible per compatibility request). -->
        <Grid x:Name="PART_RarityOverlay"
              VerticalAlignment="Bottom"
              Visibility="Collapsed">
            <ProgressBar Height="12" Name="PART_ProgressBar" Maximum="100" />
            <Label Name="PART_Label"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
        </Grid>
    </Grid>
</UserControl>
