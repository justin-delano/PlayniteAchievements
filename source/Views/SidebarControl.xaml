<UserControl x:Class="PlayniteAchievements.Views.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PlayniteAchievements.Views.Converters"
             xmlns:helpers="clr-namespace:PlayniteAchievements.Views.Helpers"
             xmlns:models="clr-namespace:PlayniteAchievements.Models.Achievements"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:vm="clr-namespace:PlayniteAchievements.ViewModels"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:EnumToBoolConverter x:Key="EnumToBool"/>
            <converters:IntToVisibilityConverter x:Key="IntToVis"/>
            <converters:ResourceKeyToImageSourceConverter x:Key="ResourceKeyToImage"/>
            <converters:ProviderIconConverter x:Key="ProviderIconConverter"/>
            <converters:DefaultGameImageConverter x:Key="DefaultGameImage"/>
            <converters:PercentToRarityGlowConverter x:Key="PercentToRarityGlow"/>
            <converters:DataGridCompletedBorderThicknessConverter x:Key="OverviewCompletedBorderThickness"/>

            <!-- Shared LegendItem DataTemplate for all pie charts -->
            <DataTemplate x:Key="LegendItemTemplate">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Grid Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <!-- Badge icons: complex DrawingImages from AchievementResources.xaml -->
                        <Image Source="{Binding IconKey, Converter={StaticResource ResourceKeyToImage}}"
                               Effect="{StaticResource BadgeShadow}"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <!-- Provider icons: created at runtime from geometry + color -->
                        <Image SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource ProviderIconConverter}">
                                    <Binding Path="IconKey"/>
                                    <Binding Path="ColorHex"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Grid>
                    <TextBlock Text="{Binding Count}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DataTemplate>

            <Style x:Key="NavigationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="17"
                                    Width="34" Height="34">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource HighlightGlyphBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScoreInfoButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.72"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ToolTip" Value="{DynamicResource LOCPlayAch_Score_Info_ButtonTooltip}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    CornerRadius="9"
                                    Background="{TemplateBinding Background}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Invisible button style for click areas -->
            <Style x:Key="InvisibleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Arrow"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CanReveal}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Tab button style -->
            <Style x:Key="TabButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                    <Border x:Name="indicator"
                                            Height="3"
                                            Background="#2196F3"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,-10"
                                            Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Button style that disables during refresh -->
            <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="10,3"/>
                <Setter Property="MinWidth" Value="88"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>

            <Style x:Key="HeaderScoreLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Opacity" Value="0.86"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>

            <Style x:Key="HeaderScoreTierTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="ExtraBold"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HeaderScoreMetricTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HeaderScorePanelStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="HeaderScoreMetricChipStyle" TargetType="Border">
                <Setter Property="Background" Value="#28FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="6,1"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="ClipToBounds" Value="True"/>
            </Style>

            <Style x:Key="HeaderScoreProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource GameProgressBar}">
                <Setter Property="Height" Value="6"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="HeaderScoreTooltipBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PopupBackgroundBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Width" Value="300"/>
                <Setter Property="MaxWidth" Value="300"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="HeaderScoreTooltipTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                <Setter Property="FontWeight" Value="ExtraBold"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="HeaderScoreTooltipMetaStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="Opacity" Value="0.72"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>

            <Style x:Key="HeaderScoreTooltipLineBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#14FFFFFF"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="HeaderScoreTooltipLineTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- Game name button style with hover effect -->
            <Style x:Key="GameNameButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}"
                                       VerticalAlignment="Center"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               VerticalAlignment="Center"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource HighlightGlyphBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RevealButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                        <Setter Property="Cursor" Value="Hand"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Style for Game Icon/Cover in Grid -->
            <Style x:Key="GameImageBorderStyle" TargetType="Border">
                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="ClipToBounds" Value="True"/>
                <Setter Property="Width" Value="64"/>
                <Setter Property="Height" Value="64"/>
                <Setter Property="Margin" Value="6,8,6,7"/>
                    <Setter Property="Background">
                        <Setter.Value>
                        <ImageBrush Stretch="Uniform"
                                    helpers:AsyncImage.Uri="{Binding GameLogo, Converter={StaticResource DefaultGameImage}, ConverterParameter=icon}"
                                    helpers:AsyncImage.DecodePixel="96"/>
                        </Setter.Value>
                    </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.UseCoverImages, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Width" Value="64"/>
                        <Setter Property="Height" Value="96"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <ImageBrush Stretch="Uniform"
                                            helpers:AsyncImage.Uri="{Binding GameCoverPath, Converter={StaticResource DefaultGameImage}, ConverterParameter=cover}"
                                            helpers:AsyncImage.DecodePixel="128"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Width" Value="48"/>
                        <Setter Property="Height" Value="48"/>
                        <Setter Property="Margin" Value="4,4"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding DataContext.UseCoverImages, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                            <Condition Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Width" Value="48"/>
                        <Setter Property="Height" Value="68"/>
                        <Setter Property="Margin" Value="4,4"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GamesOverviewDataGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="IsTabStop" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                <ContentPresenter VerticalAlignment="Stretch"
                                                  HorizontalAlignment="Stretch"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=ContextMenu.IsOpen}" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                        <Setter Property="Background" Value="#40FFFFFF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsKeyboardFocusWithin}" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True"/>
                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#50FFFFFF"/>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True"/>
                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsKeyboardFocusWithin}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#45FFFFFF"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GamesOverviewDataGridRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinHeight" Value="112"/>
                <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                <EventSetter Event="PreviewMouseRightButtonUp" Handler="DataGridRow_PreviewMouseRightButtonUp"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="MinHeight" Value="80"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewGameNameTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewGameMetadataTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Opacity" Value="0.6"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Margin" Value="0,2,0,0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewProviderIconStyle" TargetType="Image">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Width" Value="24"/>
                        <Setter Property="Height" Value="24"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewProgressContainerStyle" TargetType="Grid">
                <Setter Property="Margin" Value="2,4,10,4"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Margin" Value="2,1,6,1"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource GameProgressBar}">
                <Setter Property="Height" Value="22"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Height" Value="16"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewProgressPercentTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewProgressMetaRowStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="OverviewProgressFooterStyle" TargetType="Grid">
                <Setter Property="VerticalAlignment" Value="Bottom"/>
                <Setter Property="Margin" Value="0,0,4,16"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Margin" Value="0,0,2,10"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewMiniBadgeItemStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="4,0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Margin" Value="2,0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewMiniBadgeImageStyle" TargetType="Image" BasedOn="{StaticResource RarityIcon}">
                <Setter Property="Effect" Value="{StaticResource BadgeShadow}"/>
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Width" Value="14"/>
                        <Setter Property="Height" Value="14"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewMiniBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="3,0,0,0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Margin" Value="2,0,0,0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="OverviewCompletedFooterIconStyle" TargetType="Image" BasedOn="{StaticResource OverviewMiniBadgeImageStyle}">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="4,0,0,0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.EnableCompactGridMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                        <Setter Property="Margin" Value="2,0,0,0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CenterLineSplitterStyle" TargetType="GridSplitter">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="ResizeDirection" Value="Columns"/>
                <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
                <Setter Property="ShowsPreview" Value="True"/>
                <Setter Property="Cursor" Value="SizeWE"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                                <!-- Visible divider line -->
                                <Border x:Name="Line"
                                        Width="2"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource NormalBorderBrush}"
                                        Opacity="1"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Line" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: Header with Title, Scores, and Refresh Buttons -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,0,16,4"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Back button, title, and refresh controls -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="0,0,18,0">
                    <Button x:Name="CloseViewButton"
                            Command="{Binding CloseViewCommand}"
                            Content="&#xE72B;"
                            Style="{StaticResource NavigationButtonStyle}"
                            ToolTip="Back to Library"/>

                    <TextBlock Text="{DynamicResource LOCPlayAch_Title_PluginName}"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               FontWeight="Bold"
                               FontSize="20"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               MaxWidth="230"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,0,0"/>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="24,0,0,0">
                        <Button x:Name="RefreshModeSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Content="{Binding RefreshModeSelectionText}"
                                Click="RefreshModeSelectionButton_Click"
                                HorizontalContentAlignment="Center"
                                Width="94"
                                Height="24"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="RefreshModeSelectionContextMenu"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                            </Button.ContextMenu>
                        </Button>

                        <Button x:Name="RefreshActionButton"
                                Content="{Binding RefreshOrCancelButtonText}"
                                Command="{Binding RefreshOrCancelCommand}"
                                Style="{StaticResource RefreshButtonStyle}"
                                Margin="0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Collection and Prestige scores -->
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            MaxWidth="740"
                            Margin="18,0,0,0"
                            Visibility="{Binding ShowSidebarScoreCards, Converter={StaticResource BoolToVis}}">

                    <Border Width="300"
                            Style="{StaticResource HeaderScorePanelStyle}"
                            Background="{Binding CollectionScoreAccentBackgroundBrush}"
                            BorderBrush="{Binding CollectionScoreAccentBrush}"
                            Visibility="{Binding ShowSidebarCollectionScoreCard, Converter={StaticResource BoolToVis}}">
                        <Border.ToolTip>
                            <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Placement="Bottom"
                                     HorizontalOffset="0"
                                     VerticalOffset="4"
                                     Width="300"
                                     Padding="0"
                                     BorderThickness="0"
                                     Background="{DynamicResource PopupBackgroundBrush}"
                                     HorizontalContentAlignment="Stretch"
                                     HasDropShadow="True">
                                <Border Style="{StaticResource HeaderScoreTooltipBorderStyle}"
                                        BorderBrush="{Binding CollectionScoreAccentBrush}">
                                    <StackPanel>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding CollectionCurrentLevelPointsText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"/>
                                        </Border>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding CollectionPointsUntilNextLevelText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"/>
                                        </Border>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding CollectionNextTierThresholdText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"
                                                       Foreground="{Binding CollectionNextTierAccentBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Row="0"
                                  Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CollectionScoreLabel}"
                                           Style="{StaticResource HeaderScoreLabelTextStyle}"
                                           TextAlignment="Left"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="132"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="&#xE946;"
                                        Style="{StaticResource ScoreInfoButtonStyle}"
                                        Click="ScoreInfoButton_Click"
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding CollectionScorePointsText}"
                                           Style="{StaticResource HeaderScoreMetricTextStyle}"
                                           TextAlignment="Right"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Image Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Grid.Column="0"
                                   Width="30"
                                   Height="30"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Source="{Binding CollectionScoreBadgeIconKey, Converter={StaticResource ResourceKeyToImage}}"
                                   Effect="{StaticResource BadgeShadow}"
                                   Style="{StaticResource RarityIcon}"/>
                            <ProgressBar Grid.Row="1"
                                         Grid.Column="1"
                                         Value="{Binding CollectorLevelProgress, Mode=OneWay}"
                                         Style="{StaticResource HeaderScoreProgressBarStyle}"
                                         BorderBrush="{Binding CollectionScoreAccentBrush}"
                                         Foreground="{Binding CollectionScoreAccentBrush}"
                                         Margin="0,3,0,0"/>
                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,1,0,0"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CollectionTierText}"
                                           Style="{StaticResource HeaderScoreTierTextStyle}"
                                           Foreground="{Binding CollectionScoreAccentBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CollectionLevelText}"
                                           Style="{StaticResource HeaderScoreTierTextStyle}"
                                           Foreground="{Binding CollectionScoreAccentBrush}"
                                           TextAlignment="Left"
                                           MaxWidth="150"
                                           Margin="10,1,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource NormalBorderBrush}"
                            Opacity="0.55"
                            VerticalAlignment="Center"
                            Width="1"
                            Height="42"
                            Margin="12,2"
                            Visibility="{Binding ShowSidebarScoreCardDivider, Converter={StaticResource BoolToVis}}"/>

                    <Border Width="300"
                            Style="{StaticResource HeaderScorePanelStyle}"
                            Background="{Binding PrestigeScoreAccentBackgroundBrush}"
                            BorderBrush="{Binding PrestigeScoreAccentBrush}"
                            Visibility="{Binding ShowSidebarPrestigeScoreCard, Converter={StaticResource BoolToVis}}">
                        <Border.ToolTip>
                            <ToolTip DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Placement="Bottom"
                                     HorizontalOffset="0"
                                     VerticalOffset="4"
                                     Width="300"
                                     Padding="0"
                                     BorderThickness="0"
                                     Background="{DynamicResource PopupBackgroundBrush}"
                                     HorizontalContentAlignment="Stretch"
                                     HasDropShadow="True">
                                <Border Style="{StaticResource HeaderScoreTooltipBorderStyle}"
                                        BorderBrush="{Binding PrestigeScoreAccentBrush}">
                                    <StackPanel>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding PrestigeCurrentLevelPointsText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"/>
                                        </Border>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding PrestigePointsUntilNextLevelText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"/>
                                        </Border>
                                        <Border Style="{StaticResource HeaderScoreTooltipLineBorderStyle}">
                                            <TextBlock Text="{Binding PrestigeNextTierThresholdText}"
                                                       Style="{StaticResource HeaderScoreTooltipLineTextStyle}"
                                                       Foreground="{Binding PrestigeNextTierAccentBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </ToolTip>
                        </Border.ToolTip>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Grid.Column="0"
                                   Width="30"
                                   Height="30"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Source="{Binding PrestigeScoreBadgeIconKey, Converter={StaticResource ResourceKeyToImage}}"
                                   Effect="{StaticResource BadgeShadow}"
                                   Style="{StaticResource RarityIcon}"/>
                            <Grid Grid.Row="0"
                                  Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding PrestigeScoreLabel}"
                                           Style="{StaticResource HeaderScoreLabelTextStyle}"
                                           TextAlignment="Left"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="132"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="&#xE946;"
                                        Style="{StaticResource ScoreInfoButtonStyle}"
                                        Click="ScoreInfoButton_Click"
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding PrestigeScorePointsText}"
                                           Style="{StaticResource HeaderScoreMetricTextStyle}"
                                           TextAlignment="Right"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Grid.Row="1"
                                         Grid.Column="1"
                                         Value="{Binding PrestigeLevelProgress, Mode=OneWay}"
                                         Style="{StaticResource HeaderScoreProgressBarStyle}"
                                         BorderBrush="{Binding PrestigeScoreAccentBrush}"
                                         Foreground="{Binding PrestigeScoreAccentBrush}"
                                         Margin="0,3,0,0"/>
                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,1,0,0"
                                  ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding PrestigeTierText}"
                                           Style="{StaticResource HeaderScoreTierTextStyle}"
                                           Foreground="{Binding PrestigeScoreAccentBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PrestigeLevelText}"
                                           Style="{StaticResource HeaderScoreTierTextStyle}"
                                           Foreground="{Binding PrestigeScoreAccentBrush}"
                                           TextAlignment="Left"
                                           MaxWidth="150"
                                           Margin="10,1,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ROW 1: Progress Bar -->
        <Border Grid.Row="1"
                Background="Transparent"
                Padding="16,8"
                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressMessage}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.8"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,6"/>
                <ProgressBar Value="{Binding ProgressPercent}"
                             Height="6"
                             Minimum="0"
                             Maximum="100"/>
            </StackPanel>
        </Border>

        <!-- ROW 2: Tab Content -->
        <Grid Grid.Row="2">
            <!-- Overview Tab Content -->
            <Grid x:Name="OverviewContent" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="OverviewLeftColumn" Width="*" MinWidth="560"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="OverviewRightColumn" Width="*" MinWidth="480"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: Filters Row -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="16,10"
                        KeyboardNavigation.DirectionalNavigation="Continue">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="LeftSearchTextBox"
                                     Text="{Binding LeftSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Games}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.5"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LeftSearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LeftSearchText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button x:Name="ClearLeftSearchButton"
                                    Tag="{Binding LeftSearchText}"
                                    Click="ClearLeftSearch_Click"
                                    Style="{StaticResource ClearSearchButtonStyle}"/>
                        </Grid>

                        <Button x:Name="ProviderFilterSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Grid.Column="1"
                                Content="{Binding SelectedProviderFilterText}"
                                Click="ProviderFilterSelectionButton_Click"
                                Width="170"
                                Height="30"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ProviderFilterSelectionContextMenu"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                        </Button.ContextMenu>
                    </Button>

                        <Button x:Name="CompletenessFilterSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Grid.Column="2"
                                Content="{Binding SelectedCompletenessFilterText}"
                                Click="CompletenessFilterSelectionButton_Click"
                                Width="170"
                                Height="30"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="CompletenessFilterSelectionContextMenu"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                        </Button.ContextMenu>
                    </Button>

                        <Button x:Name="PlayStatusFilterSelectionButton"
                                Style="{StaticResource AchievementSelectorButtonStyle}"
                                Grid.Column="3"
                                Content="{Binding SelectedPlayStatusFilterText}"
                                Click="PlayStatusFilterSelectionButton_Click"
                                Width="170"
                                Height="30"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="PlayStatusFilterSelectionContextMenu"
                                             ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                        </Button.ContextMenu>
                    </Button>

                    </Grid>
                </Border>

                <!-- RIGHT: Filters Row -->
                <Border Grid.Row="0" Grid.Column="2"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="0,0,0,0"
                        Padding="16,10"
                        KeyboardNavigation.DirectionalNavigation="Continue">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="180"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="RightSearchTextBox"
                                     Text="{Binding RightSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ClearableSearchTextBoxStyle}"/>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Filter_Achievements}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.5"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RightSearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RightSearchText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button x:Name="ClearRightSearchButton"
                                    Tag="{Binding RightSearchText}"
                                    Click="ClearRightSearch_Click"
                                    Style="{StaticResource ClearSearchButtonStyle}"/>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsSelectedGameContentReady, Converter={StaticResource BoolToVis}}">
                            <Button x:Name="SelectedGameTypeFilterSelectionButton"
                                    Style="{StaticResource AchievementSelectorButtonStyle}"
                                    Content="{Binding SelectedGameTypeFilterText}"
                                    Click="SelectedGameTypeFilterSelectionButton_Click"
                                    Width="120"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    ToolTip="{DynamicResource LOCPlayAch_GameOptions_Category_Filter_Type}">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="SelectedGameTypeFilterSelectionContextMenu"
                                                 ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="SelectedGameCategoryFilterSelectionButton"
                                    Style="{StaticResource AchievementSelectorButtonStyle}"
                                    Content="{Binding SelectedGameCategoryFilterText}"
                                    Click="SelectedGameCategoryFilterSelectionButton_Click"
                                    Width="140"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    ToolTip="{DynamicResource LOCPlayAch_GameOptions_Category_Filter_Label}">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="SelectedGameCategoryFilterSelectionContextMenu"
                                                 ItemContainerStyle="{StaticResource AchievementMultiSelectMenuItemStyle}"/>
                                </Button.ContextMenu>
                            </Button>
                            <CheckBox x:Name="SelectedGameUnlockedFilterCheckBox"
                                  Content="{DynamicResource LOCPlayAch_Common_Unlocked}"
                                  IsChecked="{Binding ShowSelectedGameUnlocked}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                            <CheckBox x:Name="SelectedGameLockedFilterCheckBox"
                                  Content="{DynamicResource LOCPlayAch_Common_Locked}"
                                  IsChecked="{Binding ShowSelectedGameLocked}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                            <CheckBox x:Name="SelectedGameHiddenFilterCheckBox"
                                  Content="{DynamicResource LOCPlayAch_Filter_Hidden}"
                                  IsChecked="{Binding ShowSelectedGameHidden}"
                                  VerticalAlignment="Center"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- LEFT: Header (Row 1) -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            Padding="16,10,16,10"
                            BorderBrush="{DynamicResource NormalBorderBrush}"
                            BorderThickness="0,0,1,1">
                        <Grid>
                            <TextBlock Text="{DynamicResource LOCPlayAch_Sidebar_GamesOverview}"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <!-- LEFT: Games List -->
                    <Border Grid.Row="2" Grid.Column="0"
                            BorderBrush="{DynamicResource NormalBorderBrush}"
                            BorderThickness="0,0,1,0">
                        <Grid x:Name="SidebarBottomChartsGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                        <controls:GamesOverviewDataGridControl x:Name="GamesOverviewDataGridControl"
                                                                Grid.Row="0"
                                                                KeyboardNavigation.DirectionalNavigation="Contained"
                                                                ItemsSource="{Binding GamesOverview}"
                                                                SelectedItem="{Binding SelectedGame, Mode=OneWay}"
                                                                UseCoverImages="{Binding UseCoverImages}"
                                                                EnableCompactGridMode="{Binding EnableCompactGridMode}"
                                                                ShowGameMetadata="{Binding ShowSidebarGameMetadata}"
                                                                ShowCompletionBorder="{Binding ShowCompletionBorder}"
                                                                ShowColumnHeaders="{Binding ShowOverviewGridColumnHeaders}"
                                                                FixedRowHeight="{Binding SidebarOverviewGridRowHeight}"
                                                                ColumnSettingsKey="SidebarOverview"
                                                                SelectionChanged="GamesOverview_SelectionChanged"
                                                                RowPreviewMouseLeftButtonDown="GamesOverview_PreviewMouseLeftButtonDown"
                                                                Sorting="DataGrid_Sorting"
                                                                RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>
                    </Border>
                    
                    <!-- RIGHT: Header -->
                    <Grid Grid.Row="1" Grid.Column="2">
                        <!-- Header for when NO game is selected -->
                        <Border Background="{DynamicResource ControlBackgroundBrush}"
                                Height="38"
                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Visibility="{Binding ShowRecentAchievementsPanel, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource LOCPlayAch_RecentAchievements}"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="16,0"/>
                        </Border>

                        <!-- Header for when a game IS selected -->
                        <Border Background="{DynamicResource ControlBackgroundBrush}"
                                Height="38"
                                BorderBrush="{DynamicResource NormalBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Visibility="{Binding IsSelectedGameContentReady, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayedSelectedGame.GameName}"
                                               FontSize="{DynamicResource FontSize}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center">
                                        <Run Text="("/>
                                        <Run Text="{Binding SelectedGameHeaderUnlockedCount, Mode=OneWay}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding SelectedGameHeaderTotalCount, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding SelectedGameHeaderCountQualifier, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>

                                <Button x:Name="ClearGameSelectionButton"
                                        Grid.Column="1"
                                        Content="✕"
                                        Click="ClearGameSelection_Click"
                                        Width="24"
                                        Height="24"
                                        Padding="0"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- RIGHT: Content (Recent List OR Game Details) -->
                    <Grid Grid.Row="2" Grid.Column="2" ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Content Area: Recent List OR Game Details -->
                        <Grid Grid.Row="0" ClipToBounds="False">
                            <!-- Default Panel: When no game selected -->
                            <Grid Visibility="{Binding ShowRecentAchievementsPanel, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                            <controls:AchievementDataGridControl x:Name="RecentAchievementsDataGrid"
                                                                 Grid.Row="0"
                                                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                                                 ItemsSource="{Binding RecentAchievements}"
                                                                 ColumnSettingsKey="Sidebar"
                                                                 ShowGameColumn="True"
                                                                 HideStatusColumn="True"
                                                                 UseCoverImages="{Binding UseCoverImages}"
                                                                 ShowColumnHeaders="{Binding ShowAchievementGridColumnHeaders}"
                                                                 FixedRowHeight="{Binding SidebarRecentAchievementsGridRowHeight}"
                                                                 DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                                                 UseExternalSorting="True"
                                                                 Sorting="AchievementDataGrid_Sorting"
                                                                 RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                 RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>

                        <!-- Game Detail Panel: When a game is selected -->
                        <Grid Visibility="{Binding IsSelectedGameContentReady, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Game Achievements List -->
                            <controls:AchievementDataGridControl x:Name="GameAchievementsGrid"
                                                                 Grid.Row="0"
                                                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                                                 ItemsSource="{Binding SelectedGameAchievements}"
                                                                 ColumnSettingsKey="SidebarGame"
                                                                 DataGridMaxHeight="{x:Static sys:Double.NaN}"
                                                                 ShowColumnHeaders="{Binding ShowAchievementGridColumnHeaders}"
                                                                 FixedRowHeight="{Binding SidebarSelectedGameGridRowHeight}"
                                                                 RevealCommand="{Binding DataContext.RevealAchievementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                 UseExternalSorting="True"
                                                                 Sorting="GameAchievementsGrid_Sorting"
                                                                 RowPreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                                                 RowPreviewMouseRightButtonUp="DataGridRow_PreviewMouseRightButtonUp"/>
                        </Grid>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="3"
                            MinHeight="225"
                            Margin="-20,0,-20,-20"
                            Padding="20,8,20,20"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource NormalBorderBrush}"
                            BorderThickness="0,3,0,0">
                        <Border.Resources>
                            <DataTemplate x:Key="SidebarTimelineContentTemplate">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TimelineSectionTitle}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               Margin="0,0,0,6"/>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_7D}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=SevenDays}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="SevenDays"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_14D}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=FourteenDays}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="FourteenDays"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1M}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneMonth}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="OneMonth"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_3M}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=ThreeMonths}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="ThreeMonths"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_1Y}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=OneYear}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="OneYear"/>
                                        <RadioButton Content="{DynamicResource LOCPlayAch_TimeRange_All}" GroupName="GlobalTimeRangeDefault"
                                                     Style="{StaticResource TimeRangeButtonStyle}"
                                                     IsChecked="{Binding GlobalTimeline.TimelineRange, Converter={StaticResource EnumToBool}, ConverterParameter=All}"
                                                     Command="{Binding GlobalTimeline.SetTimeRangeCommand}" CommandParameter="All"/>
                                    </StackPanel>

                                    <lvc:CartesianChart Grid.Row="2"
                                                        Series="{Binding GlobalTimeline.TimelineSeries}"
                                                        LegendLocation="None"
                                                        Hoverable="True"
                                                        DisableAnimations="True">
                                        <lvc:CartesianChart.Resources>
                                            <Style TargetType="lvc:ColumnSeries">
                                                <Setter Property="Fill" Value="{DynamicResource HighlightGlyphBrush}" />
                                            </Style>
                                        </lvc:CartesianChart.Resources>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Labels="{Binding GlobalTimeline.TimelineLabels}"
                                                      ShowLabels="True"
                                                      LabelsRotation="45"
                                                      FontSize="{DynamicResource FontSizeSmall}"
                                                      Foreground="{DynamicResource TextBrush}">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Step="1" IsEnabled="False"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis MinValue="0"
                                                      LabelFormatter="{Binding GlobalTimeline.YAxisFormatter}"
                                                      FontSize="{DynamicResource FontSizeSmall}"
                                                      Foreground="{DynamicResource TextBrush}">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator Stroke="{DynamicResource NormalBorderBrush}" Opacity="0.2"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </DataTemplate>
                        </Border.Resources>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowSidebarPieCharts}" Value="False"/>
                                            <Condition Binding="{Binding ShowSidebarBarCharts}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid x:Name="ChartsRowGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" x:Name="PieChartsColumn"/>
                                <ColumnDefinition Width="1*" x:Name="BarChartColumn"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Pie Charts -->
                            <Border x:Name="SidebarPieChartsHost"
                                    Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowSidebarPieCharts}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShowSidebarBarCharts}" Value="False">
                                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid x:Name="SidebarPieChartsGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                <!-- Games Completion Pie Chart -->
                                <Grid x:Name="GamesPieChartPanel" Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{DynamicResource LOCPlayAch_Sidebar_GamesPieChart}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding GamesPieChart.PieSeries}"
                                                                      LegendItems="{Binding GamesPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding GamesPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding GamesPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding GamesPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowSidebarPiePercentages}"
                                                                      IconOffset="12"
                                                                      SliceClick="OnGamesPieChartSliceClick"/>
                                </Grid>

                                <!-- Provider Distribution Pie Chart -->
                                <Grid x:Name="ProviderPieChartPanel" Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{DynamicResource LOCPlayAch_Sidebar_ProviderDistribution}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons x:Name="ProviderPieChartControl"
                                                                      Grid.Row="1"
                                                                      PieSeries="{Binding ProviderPieChart.PieSeries}"
                                                                      LegendItems="{Binding ProviderPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding ProviderPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding ProviderPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding ProviderPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowSidebarPiePercentages}"
                                                                      IconOffset="12"
                                                                      SliceClick="OnProviderPieChartSliceClick"/>
                                </Grid>

                                <!-- Rarity Pie Chart with Custom Legend -->
                                <Grid x:Name="RarityPieChartPanel" Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding RarityPieChartTitle}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding RarityPieChart.PieSeries}"
                                                                      LegendItems="{Binding RarityPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding RarityPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding RarityPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding RarityPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowSidebarPiePercentages}"
                                                                      IconOffset="12"/>
                                </Grid>

                                <!-- Trophy Pie Chart -->
                                <Grid x:Name="TrophyPieChartPanel" Grid.Column="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding TrophyPieChartTitle}"
                                               Style="{DynamicResource BaseTextBlockStyle}"
                                               Foreground="{DynamicResource TextBrush}"
                                               Opacity="0.7"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Top"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="6,0,6,4"/>
                                    <controls:PieChartWithRadialIcons Grid.Row="1"
                                                                      PieSeries="{Binding TrophyPieChart.PieSeries}"
                                                                      LegendItems="{Binding TrophyPieChart.LegendItems}"
                                                                      HighlightedLabels="{Binding TrophyPieChart.HighlightedLabels}"
                                                                      ExactUnlockedCount="{Binding TrophyPieChart.ExactUnlockedCount}"
                                                                      ExactTotalCount="{Binding TrophyPieChart.ExactTotalCount}"
                                                                      ShowCenterPercentage="{Binding ShowSidebarPiePercentages}"
                                                                      IconOffset="12"/>
                                </Grid>
                                </Grid>
                            </Border>

                            <!-- RIGHT: Timeline -->
                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ShowSidebarPieCharts}" Value="True"/>
                                                    <Condition Binding="{Binding ShowSidebarBarCharts}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentControl Content="{Binding}"
                                                ContentTemplate="{StaticResource SidebarTimelineContentTemplate}"/>
                            </Border>

                            <!-- FULL-WIDTH Timeline When Pie Charts Are Hidden -->
                            <Border Grid.ColumnSpan="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ShowSidebarPieCharts}" Value="False"/>
                                                    <Condition Binding="{Binding ShowSidebarBarCharts}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentControl Content="{Binding}"
                                                ContentTemplate="{StaticResource SidebarTimelineContentTemplate}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Visible divider line (always shows) -->
                    <Border Grid.Column="1"
                        Grid.RowSpan="3"
                        Width="2"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource PanelSeparatorBrush}"
                        Opacity="0.35"
                        IsHitTestVisible="False"/>
                    <GridSplitter Grid.Column="1"
                        Grid.RowSpan="3"
                        Style="{StaticResource CenterLineSplitterStyle}"
                        DragCompleted="OverviewGridSplitter_DragCompleted"
                        Focusable="False"
                        IsTabStop="False"
                        Panel.ZIndex="100"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


