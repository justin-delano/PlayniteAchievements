<!-- SettingsControl.xaml -->
<UserControl x:Class="PlayniteAchievements.Views.SettingsControl"
             x:Name="SettingsControlRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:PlayniteAchievements.Views.Controls"
             xmlns:models="clr-namespace:PlayniteAchievements.Models"
             xmlns:settings="clr-namespace:PlayniteAchievements.Models.Settings"
             xmlns:nav="clr-namespace:PlayniteAchievements.Views.Settings.Navigation"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="700">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/SettingsScopedControlStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/RarityBadges.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <TabControl x:Name="SettingsTabControl" SelectionChanged="TabControl_SelectionChanged" BorderThickness="0">
            <!-- ================== TAB: GENERAL SETTINGS ================== -->
            <TabItem x:Name="GeneralTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_Common_General}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" Text="&#xEF39;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Common_General}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">

                        <!-- Settings Header -->
                        <Border Style="{StaticResource SectionBorderStyle}"
                                Background="{DynamicResource PlayAch.Brush.Panel}"
                                BorderBrush="{DynamicResource PlayAch.Brush.Border}">
                            <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Description}"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0"/>
                        </Border>

                        <!-- Prominent quick links to other settings tabs -->
                        <Grid Margin="0,12,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource ProminentLinkButtonStyle}"
                                    Click="JumpToTab_Click"
                                    CommandParameter="Display"
                                    ToolTip="{DynamicResource LOCPlayAch_Settings_TabDisplay}"
                                    AutomationProperties.Name="{DynamicResource LOCPlayAch_Settings_TabDisplay}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                                               FontSize="20" Margin="0,0,10,0" Text="&#xEFB3;" Foreground="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TabDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Style="{StaticResource ProminentLinkButtonStyle}"
                                    Click="JumpToTab_Click"
                                    CommandParameter="Providers"
                                    ToolTip="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}"
                                    AutomationProperties.Name="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                                               FontSize="20" Margin="0,0,10,0" Text="&#xEF7B;" Foreground="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Style="{StaticResource ProminentLinkButtonStyle}"
                                    Click="JumpToTab_Click"
                                    CommandParameter="ThemeMigration"
                                    ToolTip="{DynamicResource LOCPlayAch_ThemeMigration_Title}"
                                    AutomationProperties.Name="{DynamicResource LOCPlayAch_ThemeMigration_Title}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="{DynamicResource PlayAch.FontFamily.Icon}"
                                               FontSize="20" Margin="0,0,10,0" Text="&#xEFD2;" Foreground="{DynamicResource PlayAch.Brush.Accent}"/>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Title}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- ================== LANGUAGE ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Language}"
                                           Style="{StaticResource SectionHeaderStyle}"/>

                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Language}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_LanguageHint}"
                                                   Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              Width="200"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding Persisted.GlobalLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="English" Tag="english"/>
                                        <ComboBoxItem Content="German (Deutsch)" Tag="german"/>
                                        <ComboBoxItem Content="French (Français)" Tag="french"/>
                                        <ComboBoxItem Content="Spanish (Español)" Tag="spanish"/>
                                        <ComboBoxItem Content="Italian (Italiano)" Tag="italian"/>
                                        <ComboBoxItem Content="Portuguese" Tag="portuguese"/>
                                        <ComboBoxItem Content="Brazilian Portuguese" Tag="brazilian"/>
                                        <ComboBoxItem Content="Russian (Русский)" Tag="russian"/>
                                        <ComboBoxItem Content="Polish (Polski)" Tag="polish"/>
                                        <ComboBoxItem Content="Dutch (Nederlands)" Tag="dutch"/>
                                        <ComboBoxItem Content="Swedish (Svenska)" Tag="swedish"/>
                                        <ComboBoxItem Content="Finnish (Suomi)" Tag="finnish"/>
                                        <ComboBoxItem Content="Danish (Dansk)" Tag="danish"/>
                                        <ComboBoxItem Content="Norwegian (Norsk)" Tag="norwegian"/>
                                        <ComboBoxItem Content="Hungarian (Magyar)" Tag="hungarian"/>
                                        <ComboBoxItem Content="Czech (Čeština)" Tag="czech"/>
                                        <ComboBoxItem Content="Romanian (Română)" Tag="romanian"/>
                                        <ComboBoxItem Content="Turkish (Türkçe)" Tag="turkish"/>
                                        <ComboBoxItem Content="Greek (Ελληνικά)" Tag="greek"/>
                                        <ComboBoxItem Content="Bulgarian (Български)" Tag="bulgarian"/>
                                        <ComboBoxItem Content="Ukrainian (Українська)" Tag="ukrainian"/>
                                        <ComboBoxItem Content="Thai (ไทย)" Tag="thai"/>
                                        <ComboBoxItem Content="Vietnamese (Tiếng Việt)" Tag="vietnamese"/>
                                        <ComboBoxItem Content="Japanese (日本語)" Tag="japanese"/>
                                        <ComboBoxItem Content="Korean (한국어)" Tag="koreana"/>
                                        <ComboBoxItem Content="Simplified Chinese (简体中文)" Tag="schinese"/>
                                        <ComboBoxItem Content="Traditional Chinese (繁體中文)" Tag="tchinese"/>
                                        <ComboBoxItem Content="Arabic (العربية)" Tag="arabic"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ================== SYNC & UPDATES ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Section_SyncUpdates}"
                                           Style="{StaticResource SectionHeaderStyle}"/>

                                <!-- Periodic Updates -->
                                <Grid Style="{StaticResource SettingRowStyle}" Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                            <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnablePeriodicUpdates}"
                                                          IsChecked="{Binding Persisted.EnablePeriodicUpdates}"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_HoursBetweenUpdates}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                            <TextBox Text="{Binding Persisted.PeriodicUpdateHours, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                     IsEnabled="{Binding Persisted.EnablePeriodicUpdates}"
                                                 TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <!-- In-Game Polling -->
                                <Grid Style="{StaticResource SettingRowStyle}" Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableInGamePolling}"
                                                  IsChecked="{Binding Persisted.EnableInGamePolling}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_EnableInGamePolling_Description}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="18,2,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_InGamePollIntervalSeconds}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <TextBox Text="{Binding Persisted.InGamePollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 IsEnabled="{Binding Persisted.EnableInGamePolling}"
                                                 TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="18,0,0,16"
                                            IsEnabled="{Binding Persisted.EnableInGamePolling}">
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_InGamePollRefreshFriends}"
                                              IsChecked="{Binding Persisted.InGamePollRefreshFriends}"
                                              Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                    <Grid IsEnabled="{Binding Persisted.InGamePollRefreshFriends}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{DynamicResource LOCPlayAch_Settings_InGameFriendRefreshMultiplier}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding Persisted.InGameFriendRefreshMultiplier, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 TextAlignment="Right"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{DynamicResource LOCPlayAch_Settings_InGameFriendBatchSize}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding Persisted.InGameFriendBatchSize, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 TextAlignment="Right"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_IncludeHiddenGamesInBulkRefreshes}"
                                              IsChecked="{Binding Persisted.IncludeHiddenGamesInBulkScans}"
                                              Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_IncludeHiddenGamesInBulkRefreshes_Description}"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="18,0,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Recent Refresh -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_RefreshMode_Recent}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecentRefresh_Description}"
                                                   Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_RecentRefresh_RecentGames}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                            <TextBox Text="{Binding Persisted.RecentRefreshGamesCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Include Unplayed Games -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                            <CheckBox Content="{DynamicResource LOCPlayAch_IncludeUnplayedGames}"
                                                          IsChecked="{Binding Persisted.IncludeUnplayedGames}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_IncludeUnplayedGames_Help}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="20,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Default Overview Refresh Mode -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_DefaultOverviewRefreshMode}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_DefaultOverviewRefreshMode_Description}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              SelectedValue="{Binding Persisted.DefaultOverviewRefreshMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="{DynamicResource LOCPlayAch_RefreshMode_Recent}"    Tag="{x:Static models:RefreshModeType.Recent}"/>
                                        <ComboBoxItem Content="{DynamicResource LOCPlayAch_RefreshMode_Full}"      Tag="{x:Static models:RefreshModeType.Full}"/>
                                        <ComboBoxItem Content="{DynamicResource LOCPlayAch_RefreshMode_Installed}" Tag="{x:Static models:RefreshModeType.Installed}"/>
                                        <ComboBoxItem Content="{DynamicResource LOCPlayAch_RefreshMode_Favorites}" Tag="{x:Static models:RefreshModeType.Favorites}"/>
                                        <ComboBoxItem Content="{DynamicResource LOCPlayAch_RefreshMode_Missing}"   Tag="{x:Static models:RefreshModeType.Missing}"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Provider Execution Mode -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableParallelProviderRefresh}"
                                                  IsChecked="{Binding Persisted.EnableParallelProviderRefresh}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_EnableParallelProviderRefresh_Help}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="20,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ================== HOTKEYS ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_Title}"
                                           Style="{StaticResource SectionHeaderStyle}"/>

                                <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,0,0,14"
                                           TextWrapping="Wrap"/>

                                <CheckBox Content="{DynamicResource LOCPlayAch_Hotkeys_Enable}"
                                          IsChecked="{Binding Persisted.EnableAchievementHotkeys}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>

                                <CheckBox Content="{DynamicResource LOCPlayAch_Hotkeys_EnableGlobal}"
                                          IsChecked="{Binding Persisted.EnableGlobalAchievementHotkeys}"
                                          IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                          Margin="18,0,0,8"/>

                                <TextBlock Text="{DynamicResource LOCPlayAch_Hotkeys_GlobalHelp}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="18,0,0,14"
                                           TextWrapping="Wrap"/>

                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Menu_ViewAchievements}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button x:Name="ViewAchievementsHotkeyCaptureButton"
                                            Grid.Column="1"
                                            Content="{Binding ViewAchievementsHotkeyButtonText, ElementName=SettingsControlRoot}"
                                            Click="HotkeyCapture_Click"
                                            CommandParameter="ViewAchievements"
                                            PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            Margin="12,0,8,0"/>

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                            Click="ResetHotkey_Click"
                                            CommandParameter="ViewAchievements"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                                </Grid>

                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Menu_ManageAchievements}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button x:Name="ManageAchievementsHotkeyCaptureButton"
                                            Grid.Column="1"
                                            Content="{Binding ManageAchievementsHotkeyButtonText, ElementName=SettingsControlRoot}"
                                            Click="HotkeyCapture_Click"
                                            CommandParameter="ManageAchievements"
                                            PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            Margin="12,0,8,0"/>

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                            Click="ResetHotkey_Click"
                                            CommandParameter="ManageAchievements"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                                </Grid>

                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Menu_OpenOverview}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button x:Name="OverviewHotkeyCaptureButton"
                                            Grid.Column="1"
                                            Content="{Binding OverviewHotkeyButtonText, ElementName=SettingsControlRoot}"
                                            Click="HotkeyCapture_Click"
                                            CommandParameter="Overview"
                                            PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            Margin="12,0,8,0"/>

                                    <Button Grid.Column="2"
                                            Content="{DynamicResource LOCPlayAch_Button_Reset}"
                                            Click="ResetHotkey_Click"
                                            CommandParameter="Overview"
                                            IsEnabled="{Binding Persisted.EnableAchievementHotkeys}"
                                            MinWidth="{StaticResource PlayAch.Size.Button.ResetMinWidth}"/>
                                </Grid>

                                <TextBlock Text="{Binding HotkeyCaptureStatusText, ElementName=SettingsControlRoot}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>


                        <!-- ================== TAGGING ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TaggingHeader}"
                                           Style="{StaticResource SectionHeaderStyle}"/>

                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TaggingDescription}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}"
                                           TextWrapping="Wrap"/>

                                <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableTagging}"
                                          IsChecked="{Binding Persisted.TaggingSettings.EnableTagging, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                <!-- Tag Configuration Grid - only visible when tagging is enabled -->
                                <StackPanel Margin="18,0,0,0"
                                            Visibility="{Binding Persisted.TaggingSettings.EnableTagging, Converter={StaticResource BooleanToVisibilityConverter}}">

                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TaggingSection}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                    <!-- Tag List -->
                                    <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Has Achievements Tag -->
                                        <CheckBox Grid.Row="0" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.HasAchievementsConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Tagging_HasAchievements}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="0" Grid.Column="2"
                                                 x:Name="HasAchievementsTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.HasAchievementsConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- In Progress Tag -->
                                        <CheckBox Grid.Row="1" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.InProgressConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Tagging_InProgress}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="1" Grid.Column="2"
                                                 x:Name="InProgressTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.InProgressConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- Completed Tag -->
                                        <CheckBox Grid.Row="2" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.CompletedConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Completed}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="2" Grid.Column="2"
                                                 x:Name="CompletedTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.CompletedConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- No Achievements Tag -->
                                        <CheckBox Grid.Row="3" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.NoAchievementsConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Tagging_NoAchievements}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="3" Grid.Column="2"
                                                 x:Name="NoAchievementsTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.NoAchievementsConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- Customized Tag -->
                                        <CheckBox Grid.Row="4" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.CustomizedConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Tagging_Customized}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="4" Grid.Column="2"
                                                 x:Name="CustomizedTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.CustomizedConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- Not Customized Tag -->
                                        <CheckBox Grid.Row="5" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.NotCustomizedConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_Tagging_NotCustomized}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="5" Grid.Column="2"
                                                 x:Name="NotCustomizedTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.NotCustomizedConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- Excluded Tag -->
                                        <CheckBox Grid.Row="6" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.ExcludedConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_ManageAchievements_Status_Excluded}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,6"/>
                                        <TextBox Grid.Row="6" Grid.Column="2"
                                                 x:Name="ExcludedTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.ExcludedConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="{StaticResource PlayAch.Thickness.Bottom.Compact}"/>

                                        <!-- Excluded from Summaries Tag -->
                                        <CheckBox Grid.Row="7" Grid.Column="0"
                                                  IsChecked="{Binding Persisted.TaggingSettings.ExcludedFromSummariesConfig.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1"
                                                   Text="{DynamicResource LOCPlayAch_ManageAchievements_Status_ExcludedFromSummaries}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>
                                        <TextBox Grid.Row="7" Grid.Column="2"
                                                 x:Name="ExcludedFromSummariesTagTextBox"
                                                 Text="{Binding Persisted.TaggingSettings.ExcludedFromSummariesConfig.DisplayName, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                 Margin="0,0,0,0"/>
                                    </Grid>

                                    <!-- Completion Status -->
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_SetCompletionStatus}"
                                              IsChecked="{Binding Persisted.TaggingSettings.SetCompletionStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,12,0,8"/>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="{DynamicResource LOCPlayAch_Settings_ApplyAndSync}"
                                                Click="ApplyAndSync_Click"
                                                Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"/>
                                        <Button Content="{DynamicResource LOCPlayAch_Settings_RemoveAllTags}"
                                                Click="RemoveAllTags_Click"
                                                Padding="{StaticResource PlayAch.Thickness.ButtonPadding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ================== THEME INTEGRATION ================== -->
                        <!-- <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Theme Integration"
                                           Style="{StaticResource SectionHeaderStyle}"/>

                                <TextBlock Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}">
                                    PlayniteAchievements is the single source for both Desktop and Fullscreen themes.
                                    Both modern and SuccessStory-compatible properties are always populated so themes can bind to either surface.
                                </TextBlock>

                                 <Separator Margin="0,16,0,16" />

                                <TextBlock Text="Modern PlayniteAchievements theme integration"
                                           FontWeight="SemiBold"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}" />

                                <TextBlock Style="{StaticResource MutedTextStyle}"
                                           Margin="0,0,0,0">
                                    Modern controls and properties (prefixed differently) are always available to themes.
                                    Theme authors should use the modern PlayniteAchievements prefix for new themes.
                                </TextBlock>
                            </StackPanel>
                        </Border> -->

                        <!-- ================== MAINTENANCE ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Maintenance_Title}"
                                           Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Maintenance_Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}"/>

                                <Border Style="{StaticResource SettingGroupCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CachedAchievementData_Title}"
                                                   Style="{StaticResource SubSectionHeaderStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_CachedAchievementData_Description}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_CachedAchievementData_ClearDescription}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="WipeCache_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_ClearUnownedFriendData_Description}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="ClearUnownedFriendGameData_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingGroupCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_AchievementIconCache_Title}"
                                                   Style="{StaticResource SubSectionHeaderStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_IconCache_Description}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_IconCache_ClearAllDescription}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="ClearAllIconCache_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_IconCache_ClearCompressedDescription}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="ClearCompressedIconCache_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_IconCache_ClearFullResolutionDescription}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="ClearFullResolutionIconCache_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_IconCache_ClearLockedDescription}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Button_Clear}"
                                                    Click="ClearLockedIconCache_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingGroupCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Utilities_Title}"
                                                   Style="{StaticResource SubSectionHeaderStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Utilities_Description}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_ResetFirstTimeSetup}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Settings_ResetFirstTimeSetupButton}"
                                                    Click="ResetFirstTimeSetup_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid Style="{StaticResource SettingRowStyle}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_ExportDatabase}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Settings_ExportDatabaseButton}"
                                                    Click="ExportDatabase_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource LOCPlayAch_Settings_OpenDataFolder}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="{DynamicResource LOCPlayAch_Settings_OpenDataFolderButton}"
                                                    Click="OpenDataFolder_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="16,0,0,0"
                                                    MinWidth="130"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================== TAB: DISPLAY ================== -->
            <TabItem x:Name="DisplayTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_Settings_TabDisplay}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" Text="&#xEFB3;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TabDisplay}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="DisplaySettingsContent"/>
            </TabItem>

            <!-- ================== TAB: PROVIDERS ================== -->
            <TabItem x:Name="ProvidersTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" Text="&#xef7b;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_CustomRefresh_ProvidersHeader}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <nav:SettingsMasterDetailControl
                    ItemsSource="{Binding ProviderNavigationItems, ElementName=SettingsControlRoot}"
                    SelectedItem="{Binding SelectedProviderNavigationItem, ElementName=SettingsControlRoot, Mode=TwoWay}"
                    ShowSearch="True"
                    EnableGrouping="True"/>
            </TabItem>

            <!-- ================== TAB: FRIENDS ================== -->
            <TabItem x:Name="FriendsTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_Settings_Friends}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" Text="&#xED0D;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Friends}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ContentControl x:Name="FriendsSettingsContent"/>
            </TabItem>

            <!-- ================== TAB: THEME MIGRATION ================== -->
            <TabItem x:Name="ThemeMigrationTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_ThemeMigration_Title}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" Text="&#xEFD2;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Title}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">

                        <!-- ================== MIGRATION SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Title}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Lg}"
                                           TextWrapping="Wrap"/>

                                <!-- Theme Dropdown -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <ComboBox ItemsSource="{Binding AvailableThemes, ElementName=SettingsControlRoot}"
                                              DisplayMemberPath="BestDisplayName"
                                              SelectedValuePath="Path"
                                              SelectedValue="{Binding SelectedThemePath, ElementName=SettingsControlRoot}"
                                              VerticalContentAlignment="Center"
                                              IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"/>
                                </Grid>

                                <!-- Migration Buttons -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            x:Name="ThemeMigrationPresetButtons"
                                            Margin="0,12,0,0">
                                    <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationLimited}"
                                            Click="MigrateThemeLimited_Click"
                                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"
                                            ToolTipService.ShowOnDisabled="True">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="250"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationFull}"
                                            x:Name="ThemeMigrationFullButton"
                                            Click="MigrateThemeFull_Click"
                                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"
                                            ToolTipService.ShowOnDisabled="True">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="250"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>

                                <Border Background="{StaticResource PlayAch.Brush.Overlay.Shade.12}"
                                        x:Name="ThemeMigrationCustomContainer"
                                        BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                        BorderThickness="{StaticResource PlayAch.Thickness.Border}"
                                        CornerRadius="{StaticResource PlayAch.Radius.Card}"
                                        Margin="0,16,0,0"
                                        Padding="{StaticResource PlayAch.Thickness.None}"
                                        IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}">
                                    <Expander x:Name="ThemeMigrationCustomExpander"
                                              IsExpanded="False"
                                              Expanded="ThemeMigrationCustomExpander_Expanded"
                                              Collapsed="ThemeMigrationCustomExpander_Collapsed"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <Expander.Header>
                                            <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Custom}"
                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                       FontWeight="SemiBold"
                                                       Margin="-4,8,0,8"/>
                                        </Expander.Header>

                                        <StackPanel Margin="12,0,12,12">
                                            <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       HorizontalAlignment="Left"
                                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                                       MaxWidth="520"/>

                                            <Grid Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"
                                                  HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="176"/>
                                                    <ColumnDefinition Width="108"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="108"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource LOCPlayAch_ThemeMigration_AllLegacy}"
                                                        Click="ThemeMigrationSetAllLegacy_Click"
                                                        Style="{StaticResource MigrationChoiceButtonBaseStyle}"
                                                        Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>
                                                <Button Grid.Column="3"
                                                        Content="{DynamicResource LOCPlayAch_ThemeMigration_AllModern}"
                                                        Click="ThemeMigrationSetAllModern_Click"
                                                        Style="{StaticResource MigrationChoiceButtonBaseStyle}"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding ThemeMigrationCustomOptions, ElementName=SettingsControlRoot}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10"
                                                              HorizontalAlignment="Left">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="176"/>
                                                                <ColumnDefinition Width="108"/>
                                                                <ColumnDefinition Width="54"/>
                                                                <ColumnDefinition Width="108"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="{StaticResource PlayAch.Thickness.Right.Md}"/>

                                                            <Button Grid.Column="1"
                                                                    Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeLegacy}"
                                                                    Style="{StaticResource MigrationChoiceLegacyButtonStyle}"
                                                                    Click="ThemeMigrationRowSetLegacy_Click"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="{StaticResource PlayAch.Thickness.Right.Sm}"/>

                                                            <ToggleButton Grid.Column="2"
                                                                          Style="{StaticResource MigrationSwitchToggleStyle}"
                                                                          IsChecked="{Binding IsModern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                            <Button Grid.Column="3"
                                                                    Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeModern}"
                                                                    Style="{StaticResource MigrationChoiceModernButtonStyle}"
                                                                    Click="ThemeMigrationRowSetModern_Click"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="{StaticResource PlayAch.Thickness.Left.Sm}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationCustom}"
                                                    Click="MigrateThemeCustom_Click"
                                                    Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                                    Margin="{StaticResource PlayAch.Thickness.Top.Compact}"
                                                    MinWidth="100"
                                                    HorizontalAlignment="Right"
                                                    IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"/>
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <!-- No themes message -->
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoThemesMessage}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                           Visibility="{Binding ShowNoThemesMessage, ElementName=SettingsControlRoot, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- ================== REVERT SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Revert}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>

                                <!-- Revertable Theme Dropdown and Revert Button -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding RevertableThemes, ElementName=SettingsControlRoot}"
                                              DisplayMemberPath="BestDisplayName"
                                              SelectedValuePath="Path"
                                              SelectedValue="{Binding SelectedRevertThemePath, ElementName=SettingsControlRoot}"
                                              VerticalContentAlignment="Center"
                                              IsEnabled="{Binding HasRevertableThemes, ElementName=SettingsControlRoot}"/>

                                    <Button Grid.Column="1"
                                            Content="{DynamicResource LOCPlayAch_ThemeMigration_RevertButton}"
                                            Click="RevertTheme_Click"
                                            Padding="{StaticResource PlayAch.Thickness.ButtonPadding.Wide}"
                                            Margin="16,0,0,0"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasRevertableThemes, ElementName=SettingsControlRoot}"/>
                                </Grid>

                                <!-- No revertable themes message -->
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoRevertableThemes}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                                           Visibility="{Binding ShowNoRevertableThemesMessage, ElementName=SettingsControlRoot, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================== TAB: NOTIFICATIONS ================== -->
            <TabItem x:Name="NotificationsTab" AutomationProperties.Name="{DynamicResource LOCPlayAch_Settings_TabNotifications}">
                <TabItem.Header>
                    <StackPanel Style="{StaticResource TabHeaderWithIconStyle}">
                        <TextBlock Style="{StaticResource HeaderIconStyle}" FontFamily="Segoe MDL2 Assets" Text="&#xE7E7;"/>
                        <TextBlock Text="{DynamicResource LOCPlayAch_Settings_TabNotifications}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Background="{DynamicResource PlayAch.Brush.Panel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20">
                            <!-- General notifications -->
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Section_Notifications}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableNotifications}"
                                              IsChecked="{Binding Persisted.EnableNotifications}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_NotifyPeriodicUpdates}"
                                              IsChecked="{Binding Persisted.NotifyPeriodicUpdates}"
                                              Margin="18,0,0,10"
                                              IsEnabled="{Binding Persisted.EnableNotifications}"/>
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_NotifyOnRebuild}"
                                              IsChecked="{Binding Persisted.NotifyOnRebuild}"
                                              Margin="18,0,0,0"
                                              IsEnabled="{Binding Persisted.EnableNotifications}"/>
                                </StackPanel>
                            </Border>

                            <!-- Live mockup + example toast buttons -->
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ToastPreviewHeader}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                                    <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                                            BorderBrush="{DynamicResource PlayAch.Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="18"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,10">
                                        <ContentControl x:Name="ToastMockupHost"
                                                        ContentTemplate="{DynamicResource PlayAch.Template.AchievementToast}"/>
                                    </Border>

                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ToastPreviewHint}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <WrapPanel>
                                        <Button x:Name="ToastPreviewCommonButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="common"
                                                Content="{DynamicResource LOCPlayAch_Rarity_Common}"
                                                Margin="0,0,8,8"/>
                                        <Button x:Name="ToastPreviewUncommonButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="uncommon"
                                                Content="{DynamicResource LOCPlayAch_Rarity_Uncommon}"
                                                Margin="0,0,8,8"/>
                                        <Button x:Name="ToastPreviewRareButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="rare"
                                                Content="{DynamicResource LOCPlayAch_Rarity_Rare}"
                                                Margin="0,0,8,8"/>
                                        <Button x:Name="ToastPreviewUltraRareButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="ultrarare"
                                                Content="{DynamicResource LOCPlayAch_Rarity_UltraRare}"
                                                Margin="0,0,8,8"/>
                                        <Button x:Name="ToastPreviewCapstoneButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="capstone"
                                                Content="{DynamicResource LOCPlayAch_Completed}"
                                                Margin="0,0,8,8"/>
                                        <Button x:Name="ToastPreviewFriendButton"
                                                Click="ToastPreviewButton_Click"
                                                CommandParameter="friend"
                                                Content="{DynamicResource LOCPlayAch_Settings_ToastPreviewFriend}"
                                                Margin="0,0,8,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Behavior -->
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel IsEnabled="{Binding Persisted.EnableNotifications}">
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ToastBehavior}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableUnlockToasts}"
                                              IsChecked="{Binding Persisted.EnableUnlockToasts}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableFriendUnlockToasts}"
                                              IsChecked="{Binding Persisted.EnableFriendUnlockToasts}"
                                              Margin="0,0,0,12"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{DynamicResource LOCPlayAch_Settings_ToastDurationSeconds}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding Persisted.ToastDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 TextAlignment="Right"
                                                 Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{DynamicResource LOCPlayAch_Settings_MaxConcurrentToasts}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding Persisted.MaxConcurrentToasts, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="{StaticResource PlayAch.Size.Input.NarrowWidth}"
                                                 TextAlignment="Right"
                                                 Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{DynamicResource LOCPlayAch_Settings_ToastPosition}"
                                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  SelectedValue="{Binding Persisted.ToastPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  MinWidth="140">
                                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_BottomRight}" Tag="{x:Static settings:ToastScreenCorner.BottomRight}"/>
                                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_BottomLeft}" Tag="{x:Static settings:ToastScreenCorner.BottomLeft}"/>
                                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_TopRight}" Tag="{x:Static settings:ToastScreenCorner.TopRight}"/>
                                            <ComboBoxItem Content="{DynamicResource LOCPlayAch_Settings_ToastPosition_TopLeft}" Tag="{x:Static settings:ToastScreenCorner.TopLeft}"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Appearance -->
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_Appearance}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                                    <WrapPanel>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowHeader}"
                                                  IsChecked="{Binding Persisted.ToastShowHeader}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowName}"
                                                  IsChecked="{Binding Persisted.ToastShowName}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowDescription}"
                                                  IsChecked="{Binding Persisted.ToastShowDescription}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowGameName}"
                                                  IsChecked="{Binding Persisted.ToastShowGameName}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowCategory}"
                                                  IsChecked="{Binding Persisted.ToastShowCategory}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityBadge}"
                                                  IsChecked="{Binding Persisted.ToastShowRarityBadge}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityPercent}"
                                                  IsChecked="{Binding Persisted.ToastShowRarityPercent}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastShowRarityGlow}"
                                                  IsChecked="{Binding Persisted.ToastShowRarityGlow}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="{DynamicResource LOCPlayAch_Settings_ToastRarityColoredName}"
                                                  IsChecked="{Binding Persisted.ToastRarityColoredName}"
                                                  Margin="0,0,14,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Screenshots -->
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotsHeader}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="{StaticResource PlayAch.Thickness.Bottom.Md}"/>
                                    <Border Style="{StaticResource SectionAccentRuleStyle}"/>

                                    <CheckBox Content="{DynamicResource LOCPlayAch_Settings_EnableUnlockScreenshots}"
                                              IsChecked="{Binding Persisted.EnableUnlockScreenshots}"
                                              Margin="0,0,0,10"/>

                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotDirectory}"
                                               Foreground="{DynamicResource PlayAch.Brush.Text}"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Persisted.UnlockScreenshotDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="{DynamicResource LOCPlayAch_Button_Browse}"
                                                Click="ScreenshotDirectory_Browse_Click"
                                                Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ScreenshotDirectoryHint}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>






