                                    <CheckBox Grid.Column="1"
                                              Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                                              IsChecked="{Binding Persisted.EnableAchievementButtonControl}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                                <Border Style="{StaticResource SettingGroupCardStyle}"
                                        Visibility="{Binding Persisted.EnableAchievementButtonControl, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="PREVIEW"
                                                   Style="{StaticResource ContextLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <modern:AchievementButtonControl Width="40" DisplayDetails="False" Margin="0,0,16,0"
                                                Style="{StaticResource PreviewThemeControlStyle}"
                                                ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <modern:AchievementButtonControl Width="200" DisplayDetails="True"
                                                Style="{StaticResource PreviewThemeControlStyle}"
                                                ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ================== VIEW ITEM PREVIEW SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_ViewItemPreview}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0"/>
                                    <CheckBox Grid.Column="1"
                                              Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                                              IsChecked="{Binding Persisted.EnableAchievementViewItemControl}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                                <Border Style="{StaticResource SettingGroupCardStyle}"
                                        Visibility="{Binding Persisted.EnableAchievementViewItemControl, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="PREVIEW"
                                                   Style="{StaticResource ContextLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <modern:AchievementViewItemControl Width="60" ShowProgressBar="False" Margin="0,0,16,0"
                                                Style="{StaticResource PreviewThemeControlStyle}"
                                                ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <modern:AchievementViewItemControl Width="100" ShowProgressBar="True"
                                                Style="{StaticResource PreviewThemeControlStyle}"
                                                ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ================== PIE CHART PREVIEW SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_PieChartPreview}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0"/>
                                    <CheckBox Grid.Column="1"
                                              Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                                              IsChecked="{Binding Persisted.EnableAchievementPieChartControl}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                                <Border Style="{StaticResource SettingGroupCardStyle}"
                                        Visibility="{Binding Persisted.EnableAchievementPieChartControl, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="PREVIEW"
                                                   Style="{StaticResource ContextLabelStyle}"/>
                                        <modern:AchievementPieChartControl
                                            Width="260"
                                            Height="260"
                                            Style="{StaticResource PreviewThemeControlStyle}"
                                            ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ================== BAR CHART PREVIEW SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LOCPlayAch_Settings_BarChartPreview}"
                                               Style="{StaticResource SectionHeaderStyle}"
                                               Margin="0"/>
                                    <CheckBox Grid.Column="1"
                                              Content="{DynamicResource LOCPlayAch_Common_Enabled}"
                                              IsChecked="{Binding Persisted.EnableAchievementBarChartControl}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource SectionAccentRuleStyle}"/>
                                <Border Style="{StaticResource SettingGroupCardStyle}"
                                        Visibility="{Binding Persisted.EnableAchievementBarChartControl, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="PREVIEW"
                                                   Style="{StaticResource ContextLabelStyle}"/>
                                        <modern:AchievementBarChartControl Width="280" Height="120"
                                            Style="{StaticResource PreviewThemeControlStyle}"
                                            ThemeDataOverride="{Binding PreviewThemeData, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="ThemeMigrationTab" Header="{DynamicResource LOCPlayAch_ThemeMigration_Title}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">

                        <!-- ================== MIGRATION SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Title}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,0,0,16"
                                           TextWrapping="Wrap"/>

                                <!-- Theme Dropdown -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <ComboBox ItemsSource="{Binding AvailableThemes, ElementName=SettingsControlRoot}"
                                              DisplayMemberPath="BestDisplayName"
                                              SelectedValuePath="Path"
                                              SelectedValue="{Binding SelectedThemePath, ElementName=SettingsControlRoot}"
                                              VerticalContentAlignment="Center"
                                              IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"/>
                                </Grid>

                                <!-- Migration Buttons -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            x:Name="ThemeMigrationPresetButtons"
                                            Margin="0,12,0,0">
                                    <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationLimited}"
                                            Click="MigrateThemeLimited_Click"
                                            Padding="14,6"
                                            Margin="0,0,8,0"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"
                                            ToolTipService.ShowOnDisabled="True">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="250"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationFull}"
                                            Click="MigrateThemeFull_Click"
                                            Padding="14,6"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"
                                            ToolTipService.ShowOnDisabled="True">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="250"/>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>

                                <Border Background="#12000000"
                                        BorderBrush="{DynamicResource NormalBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,16,0,0"
                                        Padding="0"
                                        IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}">
                                    <Expander x:Name="ThemeMigrationCustomExpander"
                                              IsExpanded="False"
                                              Expanded="ThemeMigrationCustomExpander_Expanded"
                                              Collapsed="ThemeMigrationCustomExpander_Collapsed"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <Expander.Header>
                                            <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Custom}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       Margin="-4,8,0,8"/>
                                        </Expander.Header>

                                        <StackPanel Margin="12,0,12,12">
                                            <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Description}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       HorizontalAlignment="Left"
                                                       Margin="0,0,0,12"
                                                       MaxWidth="520"/>

                                            <Grid Margin="0,0,0,12"
                                                  HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="176"/>
                                                    <ColumnDefinition Width="108"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="108"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="1"
                                                        Content="{DynamicResource LOCPlayAch_ThemeMigration_AllLegacy}"
                                                        Click="ThemeMigrationSetAllLegacy_Click"
                                                        Style="{StaticResource MigrationChoiceButtonBaseStyle}"
                                                        Margin="0,0,8,0"/>
                                                <Button Grid.Column="3"
                                                        Content="{DynamicResource LOCPlayAch_ThemeMigration_AllModern}"
                                                        Click="ThemeMigrationSetAllModern_Click"
                                                        Style="{StaticResource MigrationChoiceButtonBaseStyle}"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding ThemeMigrationCustomOptions, ElementName=SettingsControlRoot}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10"
                                                              HorizontalAlignment="Left">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="176"/>
                                                                <ColumnDefinition Width="108"/>
                                                                <ColumnDefinition Width="54"/>
                                                                <ColumnDefinition Width="108"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource TextBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,12,0"/>

                                                            <Button Grid.Column="1"
                                                                    Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeLegacy}"
                                                                    Style="{StaticResource MigrationChoiceLegacyButtonStyle}"
                                                                    Click="ThemeMigrationRowSetLegacy_Click"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,8,0"/>

                                                            <ToggleButton Grid.Column="2"
                                                                          Style="{StaticResource MigrationSwitchToggleStyle}"
                                                                          IsChecked="{Binding IsModern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                            <Button Grid.Column="3"
                                                                    Content="{DynamicResource LOCPlayAch_ThemeMigration_ModeModern}"
                                                                    Style="{StaticResource MigrationChoiceModernButtonStyle}"
                                                                    Click="ThemeMigrationRowSetModern_Click"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="8,0,0,0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="{DynamicResource LOCPlayAch_ThemeMigration_MigrationCustom}"
                                                    Click="MigrateThemeCustom_Click"
                                                    Padding="14,6"
                                                    Margin="0,6,0,0"
                                                    MinWidth="100"
                                                    HorizontalAlignment="Right"
                                                    IsEnabled="{Binding HasThemesToMigrate, ElementName=SettingsControlRoot}"/>
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <!-- No themes message -->
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoThemesMessage}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding ShowNoThemesMessage, ElementName=SettingsControlRoot, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- ================== REVERT SECTION ================== -->
                        <Border Style="{StaticResource SectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_Revert}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,12"/>

                                <!-- Revertable Theme Dropdown and Revert Button -->
                                <Grid Style="{StaticResource SettingRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding RevertableThemes, ElementName=SettingsControlRoot}"
                                              DisplayMemberPath="BestDisplayName"
                                              SelectedValuePath="Path"
                                              SelectedValue="{Binding SelectedRevertThemePath, ElementName=SettingsControlRoot}"
                                              VerticalContentAlignment="Center"
                                              IsEnabled="{Binding HasRevertableThemes, ElementName=SettingsControlRoot}"/>

                                    <Button Grid.Column="1"
                                            Content="{DynamicResource LOCPlayAch_ThemeMigration_RevertButton}"
                                            Click="RevertTheme_Click"
                                            Padding="14,6"
                                            Margin="16,0,0,0"
                                            MinWidth="100"
                                            IsEnabled="{Binding HasRevertableThemes, ElementName=SettingsControlRoot}"/>
                                </Grid>

                                <!-- No revertable themes message -->
                                <TextBlock Text="{DynamicResource LOCPlayAch_ThemeMigration_NoRevertableThemes}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding ShowNoRevertableThemesMessage, ElementName=SettingsControlRoot, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>





