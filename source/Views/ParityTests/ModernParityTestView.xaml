<UserControl x:Class="PlayniteAchievements.Views.ParityTests.ModernParityTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PlayniteAchievements.Views.ParityTests"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/CommonResources.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/PlayniteAchievements;component/Resources/AchievementResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="8"
                Background="{DynamicResource PlayAch.Brush.Surface}">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Text="PlayniteAchievements — Modern Theme Controls" />
                <TextBlock Margin="{StaticResource PlayAch.Thickness.Top.Sm}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="0.85">
                    <Run Text="Game: " />
                    <Run Text="{Binding GameName, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="  (" />
                    <Run Text="{Binding GameId, Mode=OneWay}" />
                    <Run Text=")" />
                </TextBlock>
                <TextBlock Margin="{StaticResource PlayAch.Thickness.Top.Xs}"
                           Foreground="{DynamicResource PlayAch.Brush.Text}"
                           Opacity="{StaticResource PlayAch.Opacity.Hint}">
                    <Run Text="Achievements: " />
                    <Run Text="{Binding Settings.UnlockedCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="/" />
                    <Run Text="{Binding Settings.AchievementCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="  (" />
                    <Run Text="{Binding Settings.ProgressPercentage, Mode=OneWay, StringFormat={}{0:0.#}}" />
                    <Run Text="%)" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Controls Grid -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,12,0,0">
            <StackPanel>

                <!-- Row 0: Toast -->
                <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                        CornerRadius="{StaticResource PlayAch.Radius.Card}"
                        Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="AchievementToast"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                        <local:GameViewControlHost ControlName="AchievementToast"
                                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Row 1: Small Controls Side by Side -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- AchievementViewItem -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}">
                        <StackPanel>
                            <TextBlock Text="AchievementViewItem"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Xs}"/>
                            <TextBlock Text="Shows X/Y count in game list views"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}" Opacity="{StaticResource PlayAch.Opacity.Muted}"
                                       FontSize="{DynamicResource PlayAch.FontSize.Caption}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementViewItem" />
                        </StackPanel>
                    </Border>

                    <!-- AchievementButton -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="AchievementButton"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementButton" />
                        </StackPanel>
                    </Border>

                    <!-- AchievementProgressBar -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                        <StackPanel>
                            <TextBlock Text="AchievementProgressBar"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementProgressBar" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 2: Stats -->
                <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                        CornerRadius="{StaticResource PlayAch.Radius.Card}"
                        Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="AchievementStats"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                        <local:GameViewControlHost ControlName="AchievementStats" />
                    </StackPanel>
                </Border>

                <!-- Row 3: Charts Side by Side -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- AchievementBarChart -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}">
                        <StackPanel>
                            <TextBlock Text="AchievementBarChart"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementBarChart" Height="240" />
                        </StackPanel>
                    </Border>

                    <!-- AchievementPieChart -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                        <StackPanel>
                            <TextBlock Text="AchievementPieChart"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementPieChart" Height="240" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 4: Compact Lists Side by Side -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- AchievementCompactList -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Right.Sm}">
                        <StackPanel>
                            <TextBlock Text="AchievementCompactList"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementCompactList" Height="220" />
                        </StackPanel>
                    </Border>

                    <!-- AchievementCompactLockedList -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="CompactLocked"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementCompactLockedList" Height="220" />
                        </StackPanel>
                    </Border>

                    <!-- AchievementCompactUnlockedList -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource PlayAch.Brush.Surface}"
                            CornerRadius="{StaticResource PlayAch.Radius.Card}"
                            Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                            Margin="{StaticResource PlayAch.Thickness.Left.Sm}">
                        <StackPanel>
                            <TextBlock Text="CompactUnlocked"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PlayAch.Brush.Text}"
                                       Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                            <local:GameViewControlHost ControlName="AchievementCompactUnlockedList" Height="220" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 5: Full Achievement List -->
                <Border Background="{DynamicResource PlayAch.Brush.Surface}"
                        CornerRadius="{StaticResource PlayAch.Radius.Card}"
                        Padding="{StaticResource PlayAch.Thickness.CardPadding}"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="AchievementDataGrid"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PlayAch.Brush.Text}"
                                   Margin="{StaticResource PlayAch.Thickness.Bottom.Sm}"/>
                        <local:GameViewControlHost ControlName="AchievementDataGrid" Height="400" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

